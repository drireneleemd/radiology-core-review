        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__label"><span>Radiology-Pathology Collection</span></div><div class="meta-panel__onlineDate">Sep 1 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Approach to Cystic Lesions in the Abdomen and Pelvis, with Radiologic-Pathologic Correlation</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Joseph H.</span> <span property="familyName">Yacoub</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-7831-1680" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-7831-1680</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Jennifer A.</span> <span property="familyName">Clark</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Edina E.</span> <span property="familyName">Paal</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Maria A.</span> <span property="familyName">Manning</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-1054-0011" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-1054-0011</a> <a href="/cdn-cgi/l/email-protection#472a2a2629292e29200726243569283520" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="2d40404c434344434a6d4c4e5f03425f4a">[email&#160;protected]</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">41</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">5</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2021200207" property="sameAs">https://doi.org/10.1148/rg.2021200207</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
