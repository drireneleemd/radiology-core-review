        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="MR Imaging and CT of the Biliary Tract1" /><meta name="dc.Creator" content="Benjamin M.  Yeh" /><meta name="dc.Creator" content="Peter S.  Liu" /><meta name="dc.Creator" content="Jorge A.  Soto" /><meta name="dc.Creator" content="Carlos A.  Corvera" /><meta name="dc.Creator" content="Hero K.  Hussain" /><meta name="dc.Description" content="The use of MR imaging and CT in the evaluation of biliary disease is discussed and illustrated in terms of optimal technique, benefits, and limitations." /><meta name="Description" content="The use of MR imaging and CT in the evaluation of biliary disease is discussed and illustrated in terms of optimal technique, benefits, and limitations." /><meta name="dc.Description" content="Magnetic resonance (MR) imaging and computed tomography (CT) can be useful in the diagnosis of biliary disease, with both modalities allowing detailed evaluation of the biliary tract. Careful inter..." /><meta name="Description" content="Magnetic resonance (MR) imaging and computed tomography (CT) can be useful in the diagnosis of biliary disease, with both modalities allowing detailed evaluation of the biliary tract. Careful inter..." /><meta name="dc.Publisher" content=" Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2009-10-01" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.296095514" /><meta name="dc.Identifier" scheme="publisher-id" content="0291669" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.296095514" /><meta name="dc.Language" content="en" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2009" />
        
        

        
