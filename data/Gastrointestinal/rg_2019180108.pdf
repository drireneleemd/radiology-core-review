        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Dec 7 2018</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Encapsulating Peritoneal Sclerosis: The Abdominal Cocoon</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Manphool</span> <span property="familyName">Singhal</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Satheesh</span> <span property="familyName">Krishna</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-6603-7621" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-6603-7621</a> <a href="/cdn-cgi/l/email-protection#ddaebca9b5b8b8aeb5b6afb4aeb5b3bcf3b7b8a4bcafbcb79da8a9b2afb2b3a9b2f3bebc" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="b7c4d6c3dfd2d2c4dfdcc5dec4dfd9d699ddd2ced6c5d6ddf7c2c3d8c5d8d9c3d899d4d6">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Anupam</span> <span property="familyName">Lal</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Sabarish</span> <span property="familyName">Narayanasamy</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Amanjit</span> <span property="familyName">Bal</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Thakur D.</span> <span property="familyName">Yadav</span>, <span property="honorificSuffix">MS</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Rakesh</span> <span property="familyName">Kochhar</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Saroj K.</span> <span property="familyName">Sinha</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">Niranjan</span> <span property="familyName">Khandelwal</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con10"><span property="givenName">Adnan M.</span> <span property="familyName">Sheikh</span>, <span property="honorificSuffix">MD</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">39</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">1</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2019180108" property="sameAs">https://doi.org/10.1148/rg.2019180108</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
