        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Mar 5 2026</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Update on Management of Incidental Findings Seen on Imaging Studies of the Abdomen and Pelvis</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Chirag</span> <span property="familyName">Govardhan</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-2500-4334" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-2500-4334</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Benjamin W.</span> <span property="familyName">Carney</span>, <span property="honorificSuffix">MD, MS</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-4547-0503" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-4547-0503</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Michael C.</span> <span property="familyName">Larson</span>, <span property="honorificSuffix">MD, PhD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Ramit</span> <span property="familyName">Lamba</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Ghaneh</span> <span property="familyName">Fananapazir</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-3009-850X" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-3009-850X</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Michael T.</span> <span property="familyName">Corwin</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-8930-9765" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-8930-9765</a> <a href="/cdn-cgi/l/email-protection#2c41584f435e5b45426c44494d40584402594f484d5a455f02494859" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="5a372e3935282d33341a323f3b362e32742f393e3b2c3329743f3e2f">[email&#160;protected]</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">46</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">4</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.250104" property="sameAs">https://doi.org/10.1148/rg.250104</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__cme info-panel__item"><a href="/servlet/linkout?doi=10.1148%2Frg.250104&suffix=s0&url=https://api3.rsna.org/lms/v1/sendToJournalCMETest?doi=10.1148%2Frg.250104" class="btn btn--cme" data-toggle="tooltip"><i aria-hidden="true" class="icon-checkmark2"></i><span class="link-text">CME</span></a></div><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
