        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Utility of High-Resolution MR Imaging in Demonstrating Transmural Pathologic Changes in Crohn Disease1" /><meta name="dc.Creator" content="Rakesh  Sinha" /><meta name="dc.Creator" content="Prabhakar  Rajiah" /><meta name="dc.Creator" content="Paul  Murphy" /><meta name="dc.Creator" content="Peter  Hawker" /><meta name="dc.Creator" content="Scott  Sanders" /><meta name="dc.Description" content="High-resolution MR imaging provides accurate demonstration of pathologic changes and may aid diagnosis, assessment of disease activity, and detection of complications related to Crohn disease." /><meta name="Description" content="High-resolution MR imaging provides accurate demonstration of pathologic changes and may aid diagnosis, assessment of disease activity, and detection of complications related to Crohn disease." /><meta name="dc.Description" content="Magnetic resonance (MR) imaging has emerged as an imaging modality that can be used to help diagnose and evaluate Crohn disease of the small and large bowel. MR imaging has high diagnostic accuracy..." /><meta name="Description" content="Magnetic resonance (MR) imaging has emerged as an imaging modality that can be used to help diagnose and evaluate Crohn disease of the small and large bowel. MR imaging has high diagnostic accuracy..." /><meta name="dc.Publisher" content=" Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2009-10-01" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.296095503" /><meta name="dc.Identifier" scheme="publisher-id" content="0291847" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.296095503" /><meta name="dc.Language" content="en" /><meta name="dc.Coverage" content="world" /><m