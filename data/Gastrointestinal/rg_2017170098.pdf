        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Nov 13 2017</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">2017 Version of LI-RADS for CT and MR Imaging: An Update</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Khaled M.</span> <span property="familyName">Elsayes</span>, <span property="honorificSuffix">MD</span></a> <a href="/cdn-cgi/l/email-protection#8ae1e7efe6f9ebf3eff9cae7eeebe4eeeff8f9e5e4a4e5f8ed" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="42292f272e31233b2731022f26232c262730312d2c6c2d3025">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Jonathan C.</span> <span property="familyName">Hooker</span>, <span property="honorificSuffix">BS</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Michelle M.</span> <span property="familyName">Agrons</span>, <span property="honorificSuffix">MD, DVM</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Ania Z.</span> <span property="familyName">Kielar</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">An</span> <span property="familyName">Tang</span>, <span property="honorificSuffix">MD, MSc</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-8967-5503" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-8967-5503</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Kathryn J.</span> <span property="familyName">Fowler</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Victoria</span> <span property="familyName">Chernyak</span>, <span property="honorificSuffix">MD, MS</span></a></span><span data-displayed-on="all">, <span>… <span data-action="reveal">Show All</span> …</span> </span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Mustafa R.</span> <span property="familyName">Bashir</span>, <span property="honorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">Yuko</span> <span property="familyName">Kono</span>, <span property="honorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con10"><span property="givenName">Richard K.</span> <span property="familyName">Do</span>, <span property="honorificSuffix">MD, PhD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con11"><span property="givenName">Donald G.</span> <span property="familyName">Mitchell</span>, <span property="honorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con12"><span property="givenName">Aya</span> <span property="familyName">Kamaya</span>, <span property="honorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con13"><span property="givenName">Elizabeth M.</span> <span property="familyName">Hecht</span>, <span property="honorificSuffix">MD</span></a></span></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con14"><span property="givenName">Claude B.</span> <span property="familyName">Sirlin</span>, <span property="honorificSuffix">MD</span></a></span><span data-displayed-on="none" data-on-display="all" aria-hidden="true"> <span data-action="hide">Show Fewer</span></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">37</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">7</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2017170098" property="sameAs">https://doi.org/10.1148/rg.2017170098</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
