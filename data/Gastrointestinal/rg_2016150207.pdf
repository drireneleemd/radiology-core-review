        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Jun 10 2016</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Imaging Findings of Congestive Hepatopathy</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Michael L.</span> <span property="familyName">Wells</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Eric R.</span> <span property="familyName">Fenstad</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Joseph T.</span> <span property="familyName">Poterucha</span>, <span property="honorificSuffix">DO</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">David M.</span> <span property="familyName">Hough</span>, <span property="honorificSuffix">MB, ChB</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Phillip M.</span> <span property="familyName">Young</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Philip A.</span> <span property="familyName">Araoz</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Richard L.</span> <span property="familyName">Ehman</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Sudhakar K.</span> <span property="familyName">Venkatesh</span>, <span property="honorificSuffix">MD, FRCR</span></a> <a href="/cdn-cgi/l/email-protection#c197a4afaaa0b5a4b2a9efb2b4a5a9a0aaa0b381aca0b8aeefa4a5b4" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="396f5c5752584d5c4a51174a4c5d515852584b7954584056175c5d4c">[email&#160;protected]</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">36</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">4</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2016150207" property="sameAs">https://doi.org/10.1148/rg.2016150207</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
