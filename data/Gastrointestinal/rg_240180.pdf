        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Aug 21 2025</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Pancreas Transplantation: Anatomy, Imaging, and Complications</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Melanie P.</span> <span property="familyName">Caserta</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-7202-4552" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-7202-4552</a> <a href="/cdn-cgi/l/email-protection#4704263422353326690a222b26292e22072a263e2869222332" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="31725042544345501f7c545d505f5854715c50485e1f545544">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Rachel L.</span> <span property="familyName">Perez</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Dillon M.</span> <span property="familyName">Brown</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Cameron R.</span> <span property="familyName">Adler</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-8712-4118" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-8712-4118</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Madhura A.</span> <span property="familyName">Desai</span>, <span property="honorificSuffix">MD, PhD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-0152-0900" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-0152-0900</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Jordan D.</span> <span property="familyName">LeGout</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-3608-726X" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-3608-726X</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Mary Jennings</span> <span property="familyName">Clingan</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-6469-3753" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-6469-3753</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Anil Nicholas</span> <span property="familyName">Kurup</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-9873-6822" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-9873-6822</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">Jacob N.</span> <span property="familyName">Clendenon</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con10"><span property="givenName">Shennen A.</span> <span property="familyName">Mao</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con11"><span property="givenName">Nirvikar</span> <span property="familyName">Dahiya</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-4001-0823" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-4001-0823</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con12"><span property="givenName">Lauren F.</span> <span property="familyName">Alexander</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-5454-1505" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-5454-1505</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">45</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">9</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.240180" property="sameAs">https://doi.org/10.1148/rg.240180</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__cme info-