        <main data-widget-def="ux3-layout-widget" data-widget-id="center" class="content" id="main">
        



        
        <div class="content journal-branding">



        
        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>RSNA Education Exhibits</span></div><div class="meta-panel__onlineDate">Jan 1 2008</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">MR Imaging of the Gallbladder: A Pictorial Essay1</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Onofrio A.</span> <span property="familyName">Catalano</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Dushyant V.</span> <span property="familyName">Sahani</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Sanjeeva P.</span> <span property="familyName">Kalva</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Matthew S.</span> <span property="familyName">Cushing</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Peter F.</span> <span property="familyName">Hahn</span>, <span property="honorificSuffix">MD, PhD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Jeffrey J.</span> <span property="familyName">Brown</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Robert R.</span> <span property="familyName">Edelman</span>, <span property="honorificSuffix">MD</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">28</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">1</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.281065183" property="sameAs">https://doi.org/10.1148/rg.281065183</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
