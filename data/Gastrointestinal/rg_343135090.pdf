        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Imaging of Trauma in the Pregnant Patient" /><meta name="dc.Creator" content="Constantine A.  Raptis" /><meta name="dc.Creator" content="Vincent M.  Mellnick" /><meta name="dc.Creator" content="Demetrios A.  Raptis" /><meta name="dc.Creator" content="Douglas  Kitchin" /><meta name="dc.Creator" content="Kathryn J.  Fowler" /><meta name="dc.Creator" content="Meghan  Lubner" /><meta name="dc.Creator" content="Sanjeev  Bhalla" /><meta name="dc.Creator" content="Christine O.  Menias" /><meta name="dc.Description" content="Radiologists must be familiar with the imaging workup of pregnant trauma patients to efficiently diagnose and triage both non–pregnancy-related and pregnancy-specific injuries." /><meta name="Description" content="Radiologists must be familiar with the imaging workup of pregnant trauma patients to efficiently diagnose and triage both non–pregnancy-related and pregnancy-specific injuries." /><meta name="dc.Description" content="The pregnant trauma patient presents an important and challenging encounter for the clinical team and radiologist. In this article, we present several key aspects of the imaging workup of pregnant ..." /><meta name="Description" content="The pregnant trauma patient presents an important and challenging encounter for the clinical team and radiologist. In this article, we present several key aspects of the imaging workup of pregnant ..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2014-05-01" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="manuscript" content="135090" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.343135090" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.343135090" /><meta name="dc.Language" content="EN" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="2014 by the Radiological Society of North America, Inc." />
        
        

        
