        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Genitourinary Imaging</span></div><div class="meta-panel__onlineDate">Jan 22 2026</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Retroperitoneum and Pelvic Extraperitoneum: Anatomic Landmarks, Imaging Features, and Patterns of Disease Spread</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Ayman H.</span> <span property="familyName">Gaballah</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-2540-9246" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-2540-9246</a> <a href="/cdn-cgi/l/email-protection#95f4fdf2f4f7f4f9f9f4fdd5f8f1f4fbf1f0e7e6fafbbbfae7f2" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="1978717e787b787575787159747d78777d7c6b6a767737766b7e">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Maged</span> <span property="familyName">Algazzar</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-4968-3554" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-000