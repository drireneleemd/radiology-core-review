        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Multidetector CT of Blunt Traumatic Venous Injuries in the Chest, Abdomen, and Pelvis" /><meta name="dc.Creator" content="Brian P.  Holly" /><meta name="dc.Creator" content="Scott D.  Steenburg" /><meta name="dc.Description" content="Multidetector CT imaging of blunt traumatic venous injuries is reviewed, with emphasis on the various findings that allow the radiologist to correctly identify an acute venous injury." /><meta name="Description" content="Multidetector CT imaging of blunt traumatic venous injuries is reviewed, with emphasis on the various findings that allow the radiologist to correctly identify an acute venous injury." /><meta name="dc.Description" content="Venous injuries as a result of blunt trauma are rare. Even though current protocols for multidetector computed tomography (CT) of patients with trauma are designed to evaluate primarily the solid o..." /><meta name="Description" content="Venous injuries as a result of blunt trauma are rare. Even though current protocols for multidetector computed tomography (CT) of patients with trauma are designed to evaluate primarily the solid o..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2011-09-06" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="publisher-id" content="105221" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.315105221" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.315105221" /><meta name="dc.Language" content="en" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2011" />
        
        

        
