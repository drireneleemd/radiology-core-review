onorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con18"><span property="givenName">Jorge A.</span> <span property="familyName">Soto</span>, <span property="honorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con19"><span property="givenName">Bachir</span> <span property="familyName">Taouli</span>, <span property="honorificSuffix">MD, MHA</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con20"><span property="givenName">Stuart A.</span> <span property="familyName">Taylor</span>, <span property="honorificSuffix">MD</span></a></span></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con21"><span property="givenName">Mark E.</span> <span property="familyName">Baker</span>, <span property="honorificSuffix">MD</span></a></span><span data-displayed-on="none" data-on-display="all" aria-hidden="true"> <span data-action="hide">Show Fewer</span></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">40</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">2</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2020190091" property="sameAs">https://doi.org/10.1148/rg.2020190091</a></div></div><div class="core-relations my-3"><div class="relation mb-3"><div class="relation--head"><i class="icon-info"></i><a href="/doi/10.1148/rg.2020190213">See related article</a></div></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
