        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Jan 17 2020</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Small Bowel Crohn Disease at CT and MR Enterography: Imaging Atlas and Glossary of Terms</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Flavius F.</span> <span property="familyName">Guglielmo</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-7861-3593" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-7861-3593</a> <a href="/cdn-cgi/l/email-protection#492f25283f203c3a672e3c2e25202c25242609232c2f2f2c3b3a2627672c2d3c" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="1e78727f68776b6d30796b7972777b7273715e747b78787b6c6d7170307b7a6b">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Sudha A.</span> <span property="familyName">Anupindi</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Joel G.</span> <span property="familyName">Fletcher</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-8941-5434" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-8941-5434</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Mahmoud M.</span> <span property="familyName">Al-Hawary</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-3699-1147" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-3699-1147</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Jonathan R.</span> <span property="familyName">Dillman</span>, <span property="honorificSuffix">MD, MSc</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-0124-0164" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-0124-0164</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">David J.</span> <span property="familyName">Grand</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">David H.</span> <span property="familyName">Bruining</span>, <span property="honorificSuffix">MD</span></a></span><span data-displayed-on="all">, <span>… <span data-action="reveal">Show All</span> …</span> </span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Manjil</span> <span property="familyName">Chatterji</span>, <span property="honorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">Kassa</span> <span property="familyName">Darge</span>, <span pr