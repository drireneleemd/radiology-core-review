        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Jul 8 2011</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Imaging Assessment of Congenital and Acquired Abnormalities of the Portal Venous System</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Wai-Kit</span> <span property="familyName">Lee</span>, <span property="honorificSuffix">MBBS</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Silvia D.</span> <span property="familyName">Chang</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Vinay A.</span> <span property="familyName">Duddalwar</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Jules M.</span> <span property="familyName">Comin</span>, <span property="honorificSuffix">MBBS</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Warren</span> <span property="familyName">Perera</span>, <span property="honorificSuffix">MBBS</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Wing-Fai E.</span> <span property="familyName">Lau</span>, <span property="honorificSuffix">MBBS</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Elhamy K.</span> <span property="familyName">Bekhit</span>, <span property="honorificSuffix">MBBS</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Oliver F.</span> <span property="familyName">Hennessy</span>, <span property="honorificSuffix">MD</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">31</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">4</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.314105104" property="sameAs">https://doi.org/10.1148/rg.314105104</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
