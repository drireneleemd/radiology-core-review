                </button>
            </div>
            <div class="modal-body">
                <form action="https://www2.rsna.org/timssnet/login/newCASAccount.cfm?tCreateAccount&redirectUri=&local=true" class="registration-form raa-form" method="post"><input type="hidden" name="redirectUri" value="/doi/abs/10.1148/rg.255045184?journalCode=radiographics" />
                    <div class="form-row">
                        <div class="col">
                            <div class="form-group">
                                <label for="3280a779-a547-4761-bbad-b645500b26d6.email">Email</label>
                                <input id="3280a779-a547-4761-bbad-b645500b26d6.email" class="email form-control" type="email" name="email" value=""required="required" />
                            </div>
                        </div>
                    </div>
                    <div class="form-row">
