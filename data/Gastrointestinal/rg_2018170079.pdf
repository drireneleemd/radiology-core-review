        <div class="content journal-branding">



        
        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Mar 12 2018</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Liver Iron Quantification with MR Imaging: A Primer for Radiologists</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Roxanne</span> <span property="familyName">Labranche</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Guillaume</span> <span property="familyName">Gilbert</span>, <span property="honorificSuffix">PhD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Milena</span> <span property="familyName">Cerny</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Kim-Nhien</span> <span property="familyName">Vu</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Denis</span> <span property="familyName">Soulières</span>, <span property="honorificSuffix">MD, MSc</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Damien</span> <span property="familyName">Olivié</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Jean-Sébastien</span> <span property="familyName">Billiard</span>, <span property="honorificSuffix">MD, FRCPC</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Takeshi</span> <span property="familyName">Yokoo</span>, <span property="honorificSuffix">MD, PhD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">An</span> <span property="familyName">Tang</span>, <span property="honorificSuffix">MD, MSc, FRCPC</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-8967-5503" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-8967-5503</a> <a href="/cdn-cgi/l/email-protection#c9a8a7e7bda8a7ae89bca4a6a7bdbbaca8a5e7aaa8" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="98f9f6b6ecf9f6ffd8edf5f7f6eceafdf9f4b6fbf9">[email&#160;protected]</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">38</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">2</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2018170079" property="sameAs">https://doi.org/10.1148/rg.2018170079</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
