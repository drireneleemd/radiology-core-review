        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Imaging Manifestations of Abdominal Fat Necrosis and Its Mimics" /><meta name="dc.Creator" content="Aya  Kamaya" /><meta name="dc.Creator" content="Michael P.  Federle" /><meta name="dc.Creator" content="Terry S.  Desser" /><meta name="dc.Description" content="The typical imaging features of fat necrosis are discussed, as well as some atypical features that may mimic more ominous conditions such as liposarcoma and carcinomatosis." /><meta name="Description" content="The typical imaging features of fat necrosis are discussed, as well as some atypical features that may mimic more ominous conditions such as liposarcoma and carcinomatosis." /><meta name="dc.Description" content="Intraabdominal fat is a metabolically active tissue that may undergo necrosis through a number of mechanisms. Fat necrosis is a common finding at abdominal cross-sectional imaging, and it may cause..." /><meta name="Description" content="Intraabdominal fat is a metabolically active tissue that may undergo necrosis through a number of mechanisms. Fat necrosis is a common finding at abdominal cross-sectional imaging, and it may cause..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2011-11-08" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="publisher-id" content="115046" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.317115046" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.317115046" /><meta name="dc.Language" content="en" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2011" />
        
        

        
