        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="CT Enterography: Principles, Trends, and Interpretation of Findings1" /><meta name="dc.Creator" content="Khaled M.  Elsayes" /><meta name="dc.Creator" content="Mahmoud M.  Al-Hawary" /><meta name="dc.Creator" content="Jagalpathy  Jagdish" /><meta name="dc.Creator" content="Halemane S.  Ganesh" /><meta name="dc.Creator" content="Joel F.  Platt" /><meta name="dc.Description" content="The principles and current technique of CT enterography are discussed, and the enteric and extraenteric findings in various small bowel diseases are described and illustrated." /><meta name="Description" content="The principles and current technique of CT enterography are discussed, and the enteric and extraenteric findings in various small bowel diseases are described and illustrated." /><meta name="dc.Description" content="Computed tomographic (CT) enterography is an emerging alternative to traditional fluoroscopy for the assessment of disorders of the small bowel. The greatly improved spatial and temporal resolution..." /><meta name="Description" content="Computed tomographic (CT) enterography is an emerging alternative to traditional fluoroscopy for the assessment of disorders of the small bowel. The greatly improved spatial and temporal resolution..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2010-11-01" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="publisher-id" content="105052" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.307105052" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.307105052" /><meta name="dc.Language" content="en" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2010" />
        
        

        
