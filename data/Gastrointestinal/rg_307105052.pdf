        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Education Exhibits</span></div><div class="meta-panel__onlineDate">Nov 1 2010</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">CT Enterography: Principles, Trends, and Interpretation of Findings<sup>1</sup></h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Khaled M.</span> <span property="familyName">Elsayes</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Mahmoud M.</span> <span property="familyName">Al-Hawary</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Jagalpathy</span> <span property="familyName">Jagdish</span>, <span property="honorificSuffix">FRCR</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Halemane S.</span> <span property="familyName">Ganesh</span>, <span property="honorificSuffix">FRCR</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Joel F.</span> <span property="familyName">Platt</span>, <span property="honorificSuffix">MD</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">30</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">7</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.307105052" property="sameAs">https://doi.org/10.1148/rg.307105052</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
