        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Multimodality Imaging of Neoplastic and Nonneoplastic Solid Lesions of the Pancreas" /><meta name="dc.Creator" content="Gavin  Low" /><meta name="dc.Creator" content="Anukul  Panu" /><meta name="dc.Creator" content="Noam  Millo" /><meta name="dc.Creator" content="Edward  Leen" /><meta name="dc.Description" content="Solid lesions of the pancreas are reviewed in terms of relevant clinical information and key radiologic features that allow confident lesion characterization and differentiation from other disease ..." /><meta name="Description" content="Solid lesions of the pancreas are reviewed in terms of relevant clinical information and key radiologic features that allow confident lesion characterization and differentiation from other disease ..." /><meta name="dc.Description" content="Solid lesions of the pancreas represent a heterogeneous group of entities that can be broadly classified as either neoplastic or nonneoplastic. Neoplastic lesions include pancreatic adenocarcinoma,..." /><meta name="Description" content="Solid lesions of the pancreas represent a heterogeneous group of entities that can be broadly classified as either neoplastic or nonneoplastic. Neoplastic lesions include pancreatic adenocarcinoma,..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2011-07-08" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="publisher-id" content="105731" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.314105731" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.314105731" /><meta name="dc.Language" content="en" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2011" />
        
        

        
