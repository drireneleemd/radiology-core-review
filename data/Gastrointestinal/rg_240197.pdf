        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Internal Hernias after Roux-en-Y Gastric Bypass: Clues to a                     Challenging Diagnosis" /><meta name="dc.Creator" content="Cecil                             G.  Wood III" /><meta name="dc.Creator" content="Jeanne                             M.  Horowitz" /><meta name="dc.Creator" content="Linda                             C.  Kelahan" /><meta name="dc.Creator" content="Ezra                             N.  Teitelbaum" /><meta name="dc.Creator" content="Paul  Nikolaidis" /><meta name="dc.Creator" content="Chun  Feng" /><meta name="dc.Creator" content="Frank                             H.  Miller" /><meta name="dc.Description" content="Internal hernias in patients who have undergone Roux-en-Y gastric bypass can result in serious complications such as small bowel obstruction and bowel necrosis, and CT can facilitate early diagnosis." /><meta name="Description" content="Internal hernias in patients who have undergone Roux-en-Y gastric bypass can result in serious complications such as small bowel obstruction and bowel necrosis, and CT can facilitate early diagnosis." /><meta name="dc.Description" content="Roux-en-Y gastric bypass (RYGB) is a common and effective treatment of obesity. The development of an internal hernia after RYGB is the result of herniation of the small bowel through mesenteric de..." /><meta name="Description" content="Roux-en-Y gastric bypass (RYGB) is a common and effective treatment of obesity. The development of an internal hernia after RYGB is the result of herniation of the small bowel through mesenteric de..." /><meta name="dc.Publisher" content=" Radiological Society of North America " /><meta name="dc.Date" scheme="WTN8601" content="2025-09-11" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="manuscript" content="240197" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.240197" /><meta name="dc.Identifier" scheme="url" content="https://doi.org/10.1148/rg.240197" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.240197" /><meta name="dc.Language" content="EN" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© 2025 by the Radiological Society of North America,                     Inc." />
        
        

        
