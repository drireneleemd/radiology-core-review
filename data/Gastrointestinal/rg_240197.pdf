        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Abdominopelvic Emergency Imaging</span></div><div class="meta-panel__onlineDate">Sep 11 2025</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Internal Hernias after Roux-en-Y Gastric Bypass: Clues to a Challenging Diagnosis</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Cecil G.</span> <span property="familyName">Wood</span>, <span>III</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-3275-5075" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-3275-5075</a> <a href="/cdn-cgi/l/email-protection#7a191f1913163a1415080e120d1f090e1f0814541f1e0f" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="8cefe9efe5e0cce2e3fef8e4fbe9fff8e9fee2a2e9e8f9">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Jeanne M.</span> <span property="familyName">Horowitz</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-8056-8901" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-8056-8901</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Linda C.</span> <span property="familyName">Kelahan</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-2142-6003" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-2142-6003</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Ezra N.</span> <span property="familyName">Teitelbaum</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Paul</span> <span property="familyName">Nikolaidis</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Chun</span> <span property="familyName">Feng</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Frank H.</span> <span property="familyName">Miller</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-9506-9411" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-9506-9411</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">45</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">10</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.240197" property="sameAs">https://doi.org/10.1148/rg.240197</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__cme info-panel__item"><a href="/servlet/linkout?doi=10.1148%2Frg.240197&suffix=s0&url=https://api3.rsna.org/lms/v1/sendToJournalCMETest?doi=10.1148%2Frg.240197" class="btn btn--cme" data-toggle="tooltip"><i aria-hidden="true" class="icon-checkmark2"></i><span class="link-text">CME</span></a></div><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
