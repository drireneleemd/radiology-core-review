        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Acquired Constricting and Restricting Lesions of the Descending Duodenum" /><meta name="dc.Creator" content="Alberto I.  Carbo" /><meta name="dc.Creator" content="Guillermo P.  Sangster" /><meta name="dc.Creator" content="Jessica  Caraway" /><meta name="dc.Creator" content="Maureen G.  Heldmann" /><meta name="dc.Creator" content="Jaiyeola  Thomas" /><meta name="dc.Creator" content="Amol  Takalkar" /><meta name="dc.Description" content="The duodenal and juxtaduodenal processes that may produce descending duodenal narrowing or obstruction are discussed, as is the role of multiple imaging modalities used to diagnose the conditions." /><meta name="Description" content="The duodenal and juxtaduodenal processes that may produce descending duodenal narrowing or obstruction are discussed, as is the role of multiple imaging modalities used to diagnose the conditions." /><meta name="dc.Description" content="The descending duodenum is a structure with distinct pathologic processes and anatomic relationships that requires a systematic approach to the differential diagnosis. Because of its tubular shape ..." /><meta name="Description" content="The descending duodenum is a structure with distinct pathologic processes and anatomic relationships that requires a systematic approach to the differential diagnosis. Because of its tubular shape ..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2014-09-10" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="manuscript" content="130055" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.345130055" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.345130055" /><meta name="dc.Language" content="EN" 