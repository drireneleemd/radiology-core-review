        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__label"><span>From the Radiologic Pathology Archives</span></div><div class="meta-panel__onlineDate">Jul 17 2020</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Pancreatic Ductal Adenocarcinoma and Its Variants: Pearls and Perils</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Khoschy</span> <span property="familyName">Schawkat</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-0902-192X" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-0902-192X</a> <a href="/cdn-cgi/l/email-protection#cca7bfafa4adbba7ad8caea5a8a1afe2a4adbebaadbea8e2a9a8b9" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="b6ddc5d5ded7c1ddd7f6d4dfd2dbd598ded7c4c0d7c4d298d3d2c3">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Maria A.</span> <span property="familyName">Manning</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-1054-0011" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-1054-0011</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Jonathan N.</span> <span property="familyName">Glickman</span>, <span property="honorificSuffix">MD, PhD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Koenraad J.</span> <span property="familyName">Mortele</span>, <span property="honorificSuffix">MD</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">40</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">5</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2020190184" property="sameAs">https://doi.org/10.1148/rg.2020190184</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
