<div tabindex="-1" id="modal--changePassword"
     aria-labelledby="modalChangePasswordLabel"
     class="modal fade change-password-drawer" aria-modal="true" role="dialog">
    <div role="document" class="modal-dialog modal-fullscreen-sm-down">
        <div class="modal-content">
