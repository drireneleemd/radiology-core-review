        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Multisystem Radiology</span></div><div class="meta-panel__onlineDate">May 3 2013</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Imaging of Vascular Complications and Their Consequences Following Transplantation in the Abdomen</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Gavin</span> <span property="familyName">Low</span>, <span property="honorificSuffix">MBChB, MRCS, FRCR</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Ann M.</span> <span property="familyName">Crockett</span>, <span property="honorificSuffix">RVT, RDMS, RDCS</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Katherine</span> <span property="familyName">Leung</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Anil H.</span> <span property="familyName">Walji</span>, <span property="honorificSuffix">MD, PhD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Vimal H.</span> <span property="familyName">Patel</span>, <span property="honorificSuffix">MD, DMRD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">A. M. James</span> <span property="familyName">Shapiro</span>, <span property="honorificSuffix">MD, PhD, FRCSC, FRS(Canada)</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">David J.</span> <span property="familyName">Lomas</span>, <span property="honorificSuffix">MB BChir, FRCP, FRCR</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Richard A.</span> <span property="familyName">Coulden</span>, <span property="honorificSuffix">MBBS, FRCP, FRCR</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">33</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">3</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.333125728" property="sameAs">https://doi.org/10.1148/rg.333125728</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
