        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Midgut Neuroendocrine Tumors: Imaging Assessment for Surgical Resection" /><meta name="dc.Creator" content="Lorna R.  Woodbridge" /><meta name="dc.Creator" content="Bernadine M.  Murtagh" /><meta name="dc.Creator" content="Dominic F. Q. C.  Yu" /><meta name="dc.Creator" content="Katie L.  Planche" /><meta name="dc.Description" content="The imaging and treatment options for midgut neuroendocrine tumors are discussed, with particular focus on use of imaging to locate the primary tumor and assess surgical resectability." /><meta name="Description" content="The imaging and treatment options for midgut neuroendocrine tumors are discussed, with particular focus on use of imaging to locate the primary tumor and assess surgical resectability." /><meta name="dc.Description" content="Midgut neuroendocrine tumors (MNETs) are rare, and the primary tumor is usually small and difficult to visualize at imaging. Patients often present late with extensive liver and nodal metastases an..." /><meta name="Description" content="Midgut neuroendocrine tumors (MNETs) are rare, and the primary tumor is usually small and difficult to visualize at imaging. Patients often present late with extensive liver and nodal metastases an..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2014-03-01" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="manuscript" content="135504" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.342135504" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.342135504" /><meta name="dc.Language" content="EN" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="2014 by the Radiological Society of North America, Inc." />
        
        

        
