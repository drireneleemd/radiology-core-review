        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Emergency Radiology</span></div><div class="meta-panel__onlineDate">May 21 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">CT of Penetrating Abdominopelvic Trauma</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Muhammad</span> <span property="familyName">Naeem</span>, <span property="honorificSuffix">MBBS</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-8626-0916" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-8626-0916</a> <a href="/cdn-cgi/l/email-protection#afc2c1cecacac2efd8dadcdbc381cacbda" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="ee83808f8b8b83ae999b9d9a82c08b8a9b">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Mark J.</span> <span property="familyName">Hoegger</span>, <span property="honorificSuffix">MD, PhD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-8214-8177" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-8214-8177</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span prop