        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Oct 1 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Mucin-producing Cystic Hepatobiliary Neoplasms: Updated Nomenclature and Clinical, Pathologic, and Imaging Features</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Matthew H.</span> <span property="familyName">Lee</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-8500-0306" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-8500-0306</a> <a href="/cdn-cgi/l/email-protection#a6cbc7d2d2cec3d188cec7d4cac7c8cac3c3e6c1cbc7cfca88c5c9cb" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="422f2336362a27356c2a23302e232c2e272702252f232b2e6c212d2f">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Venkata S.</span> <span property="familyName">Katabathina</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-7800-7312" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-7800-7312</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Meghan G.</span> <span property="familyName">Lubner</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-3788-2871" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-3788-2871</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Hardik U.</span> <span property="familyName">Shah</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Srinivasa R.</span> <span property="familyName">Prasad</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-4594-2117" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-4594-2117</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Kristina A.</span> <span property="familyName">Matkowskyj</span>, <span property="honorificSuffix">MD, PhD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-5223-0834" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-5223-0834</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Perry J.</span> <span property="familyName">Pickhardt</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-5534-8202" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-5534-8202</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">41</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">6</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2021210011" property="sameAs">https://doi.org/10.1148/rg.2021210011</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
