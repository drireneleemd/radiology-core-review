        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Radiologic Assessment for Endoscopic US-guided Biliary                    Drainage" /><meta name="dc.Creator" content="Shunsuke  Sugawara" /><meta name="dc.Creator" content="Miyuki  Sone" /><meta name="dc.Creator" content="Shinichi  Morita" /><meta name="dc.Creator" content="Susumu  Hijioka" /><meta name="dc.Creator" content="Yasunari  Sakamoto" /><meta name="dc.Creator" content="Masahiko  Kusumoto" /><meta name="dc.Creator" content="Yasuaki  Arai" /><meta name="dc.Description" content="Endoscopic US-guided biliary drainage involves placement of a stent to create an extra-anatomic route between the biliary and gastrointestinal tracts and has high technical and clinical success rates." /><meta name="Description" content="Endoscopic US-guided biliary drainage involves placement of a stent to create an extra-anatomic route between the biliary and gastrointestinal tracts and has high technical and clinical success rates." /><meta name="dc.Description" content="Endoscopic US-guided biliary drainage (BD) is performed for various types of biliary obstruction and is mainly indicated for unsuccessful conventional transpapillary endoscopic retrograde cholangio..." /><meta name="Description" content="Endoscopic US-guided biliary drainage (BD) is performed for various types of biliary obstruction and is mainly indicated for unsuccessful conventional transpapillary endoscopic retrograde cholangio..." /><meta name="dc.Publisher" content=" Radiological Society of North America " /><meta name="dc.Date" scheme="WTN8601" content="2020-03-27" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="manuscript" content="190158" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.2020190158" /><meta name="dc.Identifier" scheme="url" content