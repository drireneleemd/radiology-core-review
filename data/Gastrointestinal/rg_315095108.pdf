        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Hepatic Gas: Widening Spectrum of Causes Detected at CT and US in the Interventional Era" /><meta name="dc.Creator" content="Priti A.  Shah" /><meta name="dc.Creator" content="Steven C.  Cunningham" /><meta name="dc.Creator" content="Tara A.  Morgan" /><meta name="dc.Creator" content="Barry D.  Daly" /><meta name="dc.Description" content="The spectrum of iatrogenic and noniatrogenic causes of hepatic gas detected at CT or US is described, with emphasis on the clinical significance of this finding." /><meta name="Description" content="The spectrum of iatrogenic and noniatrogenic causes of hepatic gas detected at CT or US is described, with emphasis on the clinical significance of this finding." /><meta name="dc.Description" content="The spectrum of causes of hepatic gas detected at computed tomography (CT) and ultrasonography (US) is widening. There are many iatrogenic and noniatrogenic causes of hepatic parenchymal, biliary, ..." /><meta name="Description" content="The spectrum of causes of hepatic gas detected at computed tomography (CT) and ultrasonography (US) is widening. There are many iatrogenic and noniatrogenic causes of hepatic parenchymal, biliary, ..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2011-09-06" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="publisher-id" content="095108" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.315095108" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.315095108" /><meta name="dc.Language" content="en" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2011" />
        
        

        
