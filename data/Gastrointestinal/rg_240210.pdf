        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Aug 7 2025</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Noncirrhotic Portal Hypertension: Current Concepts and Overview of Causes, Pathophysiology, and Imaging Findings</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Amir A.</span> <span property="familyName">Borhani</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-8963-2984" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-8963-2984</a> <a href="/cdn-cgi/l/email-protection#bddcd0d4cf93dfd2cfd5dcd3d4fdd3d2cfc9d5cad8cec9d8cfd393d8d9c8" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="93f2fefae1bdf1fce1fbf2fdfad3fdfce1e7fbe4f6e0e7f6e1fdbdf6f7e6">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Sudhakar K.</span> <span property="familyName">Venkatesh</span>, <span property="honorificSuffix">MBBS</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-7514-1030" property="identifier" aria-label="ORCID identifier" target="_blank">h