        <main data-widget-def="ux3-layout-widget" data-widget-id="center" class="content" id="main">
        



        
        <div class="content journal-branding">



        
        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Imaging of Uncommon Primary Intrathoracic Malignancies</span></div><div class="meta-panel__onlineDate">Oct 13 2014</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">New TNM Staging System for Esophageal Cancer: What Chest Radiologists Need to Know</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Su Jin</span> <span property="familyName">Hong</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Tae Jung</span> <span property="familyName">Kim</span>, <span property="honorificSuffix">MD, PhD</span></a> <a href="/cdn-cgi/l/email-protection#dca8bdb9b6a9b2bbf2b7b5b1ed9cbbb1bdb5b0f2bfb3b1" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="c2b6a3a7a8b7aca5eca9abaff382a5afa3abaeeca1adaf">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Kyung Bum</span> <span property="familyName">Nam</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">In Sun</span> <span property="familyName">Lee</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Hee Chul</span> <span property="familyName">Yang</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Sukki</span> <span property="familyName">Cho</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Kwhanmien</span> <span property="familyName">Kim</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Sanghoon</span> <span property="familyName">Jheon</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">Kyung Won</span> <span property="familyName">Lee</span>, <span property="honorificSuffix">MD, PhD</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">34</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">6</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.346130079" property="sameAs">https://doi.org/10.1148/rg.346130079</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
