        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Oct 1 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Gastrointestinal Bleeding at CT Angiography and CT Enterography: Imaging Atlas and Glossary of Terms</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Flavius F.</span> <span property="familyName">Guglielmo</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-7861-3593" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-7861-3593</a> <a href="/cdn-cgi/l/email-protection#cea8a2afb8a7bbbde0a9bba9a2a7aba2a3a18ea4aba8a8abbcbda1a0e0abaabb" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="97f1fbf6e1fee2e4b9f0e2f0fbfef2fbfaf8d7fdf2f1f1f2e5e4f8f9b9f2f3e2">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Michael L.</span> <span property="familyName">Wells</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">David H.</span> <span property="familyName">Bruining</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Lisa L.</span> <span property="familyName">Strate</span>, <span property="honorificSuffix">MD, MPH</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Álvaro</span> <span property="familyName">Huete</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-8746-1111" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-8746-1111</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Avneesh</span> <span property="familyName">Gupta</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-0262-9876" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-0262-9876</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Jorge A.</span> <span property="familyName">Soto</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-2533-3015" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-2533-3015</a></span><span data-displayed-on="all">, <span>… <span data-action="reveal">Show All</span> …</span> </span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Brian C.</span> <span property="familyName">Allen</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-2273-0162" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-2273-0162</a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">Mark A.</span> <span property="familyName">Anderson</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-6144-9093" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-6144-9093</a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con10"><span property="givenName">Olga R.</span> <span property="familyName">Brook</span>, <span property="honorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con11"><span property="givenName">Michael S.</span> <span property="familyName">Gee</span>, <span property="honorificSuffix">MD, PhD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con12"><span property="givenName">David J.</span> <span property="familyName">Grand</span>, <span property="honorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con13"><span property="givenName">Martin L.</span> <span property="familyName">Gunn</span>, <span property="honorificSuffix">MBChB, FRANZCR</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con14"><span property="givenName">Ashish</span> <span property="familyName">Khandelwal</span>, <span property="honorificSuffix">MBBS, MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con15"><span property="givenName">Seong Ho</span> <span property="familyName">Park</span>, <span property="honorificSuffix">MD, PhD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con16"><span property="givenName">Vijay</span> <span property="familyName">Ramalingam</span>, <span property="honorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con17"><span property="givenName">Farnoosh</span> <span property="familyName">Sokhandon</span>, <span property="honorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con18"><span property="givenName">Don C.</span> <span property="familyName">Yoo</span>, <span property="honorificSuffix">MD</span></a></span></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con19"><span property="givenName">Jeff L.</span> <span property="familyName">Fidler</span>, <span property="honorificSuffix">MD</span></a></span><span data-displayed-on="none" data-on-display="all" aria-hidden="true"> <span data-action="hide">Show Fewer</span></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">41</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">6</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2021210043" property="sameAs">https://doi.org/10.1148/rg.2021210043</a></div></div><div class="core-relations my-3"><div class="relation mb-3"><div class="relation--head"><i class="icon-info"></i><a href="/doi/10.1148/rg.2021210182">See related article</a></div></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__me