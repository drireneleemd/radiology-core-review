        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Multisystem Radiology</span></div><div class="meta-panel__onlineDate">May 26 2017</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Beyond the Bowel: Extraintestinal Manifestations of Inflammatory Bowel Disease</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Jeffrey D.</span> <span property="familyName">Olpin</span>, <span property="honorificSuffix">MD</span></a> <a href="/cdn-cgi/l/email-protection#88e2edeeeefaedf1a6e7e4f8e1e6c8e0fbeba6fdfce9e0a6edecfd" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="127877747460776b3c7d7e627b7c527a61713c6766737a3c777667">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Brett P.</span> <span property="familyName">Sjoberg</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Sarah E.</span> <span property="familyName">Stilwill</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Leif E.</span> <span property="familyName">Jensen</span>, <span property="honorificSuffix">MD, MPH</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Maryam</span> <span property="familyName">Rezvani</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Akram M.</span> <span property="familyName">Shaaban</span>, <span property="honorificSuffix">MBBCh</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">37</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">4</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2017160121" property="sameAs">https://doi.org/10.1148/rg.2017160121</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
