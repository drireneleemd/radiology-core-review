        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Multisystem Radiology</span></div><div class="meta-panel__onlineDate">Mar 3 2020</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Imaging and Treatment of Complications of Abdominal and Pelvic Mesh Repair</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Alexander</span> <span property="familyName">Gavlin</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-3641-9420" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-3641-9420</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Andrea S.</span> <span property="familyName">Kierans</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-9672-1803" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-9672-1803</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Johnson</span> <span property="familyName">Chen</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-7794-9992" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-7794-9992</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Christopher</span> <span property="familyName">Song</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Preethi</span> <span property="familyName">Guniganti</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-4366-0450" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-4366-0450</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Fernanda S.</span> <span property="familyName">Mazzariol</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-6253-2956" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-6253-2956</a> <a href="/cdn-cgi/l/email-protection#4224272f7b727073022f27266c212d302c272e2e6c272637" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="ea8c8f87d3dad8dbaa878f8ec4898598848f8686c48f8e9f">[email&#160;protected]</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">40</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">2</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2020190106" property="sameAs">https://doi.org/10.1148/rg.2020190106</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
