        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Peritoneal and Retroperitoneal Anatomy and Its Relevance for                     Cross-Sectional Imaging" /><meta name="dc.Creator" content="Temel  Tirkes" /><meta name="dc.Creator" content="Kumaresan  Sandrasegaran" /><meta name="dc.Creator" content="Aashish A.  Patel" /><meta name="dc.Creator" content="Margaret A.  Hollar" /><meta name="dc.Creator" content="Juan G.  Tejada" /><meta name="dc.Creator" content="Mark  Tann" /><meta name="dc.Creator" content="Fatih M.  Akisik" /><meta name="dc.Creator" content="John C.  Lappas" /><meta name="dc.Description" content="Knowledge of peritoneal anatomy is essential for radiologists to accurately identify the spread of tumors and fluid collections across the peritoneal spaces at cross-sectional imaging." /><meta name="Description" content="Knowledge of peritoneal anatomy is essential for radiologists to accurately identify the spread of tumors and fluid collections across the peritoneal spaces at cross-sectional imaging." /><meta name="dc.Description" content="It is difficult to identify normal peritoneal folds and ligaments at imaging. However, infectious, inflammatory, neoplastic, and traumatic processes frequently involve the peritoneal cavity and its..." /><meta name="Description" content="It is difficult to identify normal peritoneal folds and ligaments at imaging. However, infectious, inflammatory, neoplastic, and traumatic processes frequently involve the peritoneal cavity and its..." /><meta name="dc.Publisher" content=" Radiological Society of North America " /><meta name="dc.Date" scheme="WTN8601" content="2012-03-05" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="publisher-id" content="115032" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.322115032" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.322115032" /><meta name="dc.Language" content="en" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2012" />
        
        

        
