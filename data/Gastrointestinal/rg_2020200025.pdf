property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Abhijit</span> <span property="familyName">Sunnapwar</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Sainath</span> <span property="familyName">Kondapaneni</span>, <span property="honorificSuffix">BSA</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Anil</span> <span property="familyName">Dasyam</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Varaha S.</span> <span property="familyName">Tammisetti</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-2682-621X" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-2682-621X</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Umber</span> <span property="familyName">Salman</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Alia</span> <span property="familyName">Nazarullah</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-7954-6740" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-7954-6740</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">Venkata S.</span> <span property="familyName">Katabathina</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-7800-7312" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-7800-7312</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">40</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">5</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2020200025" property="sameAs">https://doi.org/10.1148/rg.2020200025</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
