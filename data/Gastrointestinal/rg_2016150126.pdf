        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Jan 12 2016</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Esophagectomy and Gastric Pull-through Procedures: Surgical Techniques, Imaging Features, and Potential Complications</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Jennifer C.</span> <span property="familyName">Flanagan</span>, <span property="honorificSuffix">MSRS, RRA</span></a> <a href="/cdn-cgi/l/email-protection#105a757e7e797675623e567c717e7177717e504544437f6564786775636475627e3e757465" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="5d17383333343b382f731b313c333c3a3c331d08090e322829352a382e29382f3373383928">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Richard</span> <span property="familyName">Batz</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Sachin S.</span> <span property="familyName">Saboo</span>, <span property="honorificSuffix">MD, FRCR</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Shaun M.</span> <span property="familyName">Nordeck</span>, <span property="honorificSuffix">MSRS, RRA</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Suhny</span> <span property="familyName">Abbara</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Kemp</span> <span property="familyName">Kernstine</span>, <span property="honorificSuffix">MD, PhD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Vasantha</span> <span property="familyName">Vasan</span>, <span property="honorificSuffix">MD</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">36</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">1</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2016150126" property="sameAs">https://doi.org/10.1148/rg.2016150126</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
