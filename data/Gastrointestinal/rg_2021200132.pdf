        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Feb 12 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">CT Esophagography for Evaluation of Esophageal Perforation</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Ashley A.</span> <span property="familyName">Norton-Gregory</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-6503-6974" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-6503-6974</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Naveen M.</span> <span property="familyName">Kulkarni</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-2644-7367" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-2644-7367</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Stacy D.</span> <span property="familyName">O’Connor</span>, <span property="honorificSuffix">MD, MPH, MMSc</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-0813-1414" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-0813-1414</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Joseph J.</span> <span property="familyName">Budovec</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-5216-382X" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-5216-382X</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Adam P.</span> <span property="familyName">Zorn</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Stephane L.</span> <span property="familyName">Desouches</span>, <span property="honorificSuffix">DO</span></a> <a href="/cdn-cgi/l/email-protection#cfbcabaabca0baaca7aabc8fa2acb8e1aaabba" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="dfacbbbaacb0aabcb7baac9fb2bca8f1babbaa">[email&#160;protected]</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">41</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">2</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2021200132" property="sameAs">https://doi.org/10.1148/rg.2021200132</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
