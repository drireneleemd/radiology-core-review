        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Beyond the GIST: Mesenchymal Tumors of the Stomach" /><meta name="dc.Creator" content="Hyunseon C.  Kang" /><meta name="dc.Creator" content="Christine O.  Menias" /><meta name="dc.Creator" content="Ayman H.  Gaballah" /><meta name="dc.Creator" content="Stuti  Shroff" /><meta name="dc.Creator" content="Melissa W.  Taggart" /><meta name="dc.Creator" content="Naveen  Garg" /><meta name="dc.Creator" content="Khaled M.  Elsayes" /><meta name="dc.Description" content="Radiologic features of GISTs and non-GIST intramural gastric tumors are described, with emphasis on histopathologic correlation." /><meta name="Description" content="Radiologic features of GISTs and non-GIST intramural gastric tumors are described, with emphasis on histopathologic correlation." /><meta name="dc.Description" content="Intramural gastric masses arise in the wall of the stomach (generally within the submucosa or muscularis propria), often with intact overlying mucosa. These tumors are typically mesenchymal in orig..." /><meta name="Description" content="Intramural gastric masses arise in the wall of the stomach (generally within the submucosa or muscularis propria), often with intact overlying mucosa. These tumors are typically mesenchymal in orig..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2013-10-01" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="publisher-id" content="135507" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.336135507" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.336135507" /><meta name="dc.Language" content="EN" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2013" />
        
        

        
