g.315105735&amp;id=fig18b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig19" class="graphic"><img src="/cms/10.1148/rg.315105735/asset/images/105735fig19.jpeg" height="1013" width="1280" aria-labelledby="fig19" loading="lazy" /><figcaption><span class="heading">Figure 19</span> Renal involvement and abdominal lymphadenopathy in a 46-year-old man. Contrast-enhanced CT image shows periportal lymphadenopathy (arrowheads). Bilateral hypoattenuating lesions also are seen in the kidneys (arrows), a finding indicative of renal involvement with autoimmune pancreatitis.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.315105735&amp;id=fig19">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig20a" class="graphic"><img src="/cms/10.1148/rg.315105735/asset/images/105735fig20a.jpeg" height="988" width="1280" loading="lazy" /><figcaption><span class="heading">Figure 20a</span> <!-- There is no content. --><div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.315105735&amp;id=fig20a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig20b" class="graphic"><img src="/cms/10.1148/rg.315105735/asset/images/105735fig20b.jpeg" height="1000" width="1280" loading="lazy" /><figcaption><span class="heading">Figure 20b</span> <!-- There is no content. --><div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.315105735&amp;id=fig20b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig20c" class="graphic"><img src="/cms/10.1148/rg.315105735/asset/images/105735fig20c.jpeg" height="1068" width="1280" loading="lazy" /><figcaption><span 