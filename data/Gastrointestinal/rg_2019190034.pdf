        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Oct 18 2019</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Liver MR Elastography Technique and Image Interpretation: Pearls and Pitfalls</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Flavius F.</span> <span property="familyName">Guglielmo</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-7861-3593" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-7861-3593</a> <a href="/cdn-cgi/l/email-protection#13557f72657a66603d5466747f7a767f7e7c53797675757661607c7d3d767766" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="c086aca1b6a9b5b3ee87b5a7aca9a5acadaf80aaa5a6a6a5b2b3afaeeea5a4b5">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Sudhakar K.</span> <span property="familyName">Venkatesh</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-7514-1030" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-7514-1030</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Donald G.</span> <span property="familyName">Mitchell</span>, <span property="honorificSuffix">MD</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">39</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">7</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2019190034" property="sameAs">https://doi.org/10.1148/rg.2019190034</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
