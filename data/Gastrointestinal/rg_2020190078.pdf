        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="CT Colonography: Improving Interpretive Skill by Avoiding                     Pitfalls" /><meta name="dc.Creator" content="Zina                         J.  Ricci" /><meta name="dc.Creator" content="Fernanda                             S.  Mazzariol" /><meta name="dc.Creator" content="Mariya  Kobi" /><meta name="dc.Creator" content="Milana  Flusberg" /><meta name="dc.Creator" content="Melanie  Moses" /><meta name="dc.Creator" content="Judy  Yee" /><meta name="dc.Description" content="Artifacts and pseudolesions encountered at CT colonography pose a real challenge to interpretation, and it is important for radiologists to understand their imaging characteristics and how implemen..." /><meta name="Description" content="Artifacts and pseudolesions encountered at CT colonography pose a real challenge to interpretation, and it is important for radiologists to understand their imaging characteristics and how implemen..." /><meta name="dc.Description" content="CT colonography image interpretation requires simultaneous detection of colonic pathologic disease and recognition of pitfalls that can simulate or obscure real findings. Artifacts and pseudolesion..." /><meta name="Description" content="CT colonography image interpretation requires simultaneous detection of colonic pathologic disease and recognition of pitfalls that can simulate or obscure real findings. Artifacts and pseudolesion..." /><meta name="dc.Publisher" content=" Radiological Society of North America " /><meta name="dc.Date" scheme="WTN8601" content="2019-12-06" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="manuscript" content="190078" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.2020190078" /><meta name="dc.Identifier" scheme="url" content="ht