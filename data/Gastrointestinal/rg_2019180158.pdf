        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">May 6 2019</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Role of US LI-RADS in the LI-RADS Algorithm</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Shuchi K.</span> <span property="familyName">Rodgers</span>, <span property="honorificSuffix">MD</span></a> <a href="/cdn-cgi/l/email-protection#e79588838082959494a7828e899493828e89c9828392" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="11637e7576746362625174787f626574787f3f747564">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">David T.</span> <span property="familyName">Fetzer</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Helena</span> <span property="familyName">Gabriel</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">James H.</span> <span property="familyName">Seow</span>, <span property="honorificSuffix">MBBS</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Hailey H.</span> <span property="familyName">Choi</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Katherine E.</span> <span property="familyName">Maturen</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Ashish P.</span> <span property="familyName">Wasnik</span>, <span property="honorificSuffix">MD</span></a></span><span data-displayed-on="all">, <span>… <span data-action="reveal">Show All</span> …</span> </span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Tara A.</span> <span property="familyName">Morgan</span>, <span property="honorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">Nirvikar</span> <span property="familyName">Dahiya</span>, <span property="honorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con10"><span property="givenName">Mary K.</span> <span property="familyName">O’Boyle</span>, <span property="honorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con11"><span property="givenName">Yuko</span> <span property="familyName">Kono</span>, <span property="honorificSuffix">MD, PhD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con12"><span property="givenName">Claude B.</span> <span property="familyName">Sirlin</span>, <span property="honorificSuffix">MD</span></a></span></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con13"><span property="givenName">Aya</span> <span property="familyName">Kamaya</span>, <span property="honorificSuffix">MD</span></a></span><span data-displayed-on="none" data-on-display="all" aria-hidden="true"> <span data-action="hide">Show Fewer</span></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">39</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">3</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2019180158" property="sameAs">https://doi.org/10.1148/rg.2019180158</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
