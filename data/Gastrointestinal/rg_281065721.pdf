        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>RSNA Education Exhibits</span></div><div class="meta-panel__onlineDate">Jan 1 2008</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Multimodality Imaging Following <sup>90</sup>Y Radioembolization: A Comprehensive Review and Pictorial Essay1</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Bassel</span> <span property="familyName">Atassi</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Affaan K.</span> <span property="familyName">Bangash</span>, <span property="honorificSuffix">DO</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Ammar</span> <span property="familyName">Bahrani</span>, <span property="honorificSuffix">BS</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Giuseppi</span> <span property="familyName">Pizzi</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Robert J.</span> <span property="familyName">Lewandowski</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Robert K.</span> <span property="familyName">Ryu</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Kent T.</span> <span property="familyName">Sato</span>, <span property="honorificSuffix">MD</span></a></span><span data-displayed-on="all">, <span>… <span data-action="reveal">Show All</span> …</span> </span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Vanessa L.</span> <span property="familyName">Gates</span>, <span property="honorificSuffix">MS</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">Mary F.</span> <span property="familyName">Mulcahy</span>, <span property="honorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con10"><span property="givenName">Laura</span> <span property="familyName">Kulik</span>, <span property="honorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con11"><span property="givenName">Frank</span> <span property="familyName">Miller</span>, <span property="honorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con12"><span property="givenName">Vahid</span> <span property="familyName">Yaghmai</span>, <span property="honorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con13"><span property="givenName">Ravi</span> <span property="familyName">Murthy</span>, <span property="honorificSuffix">MD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con14"><span property="givenName">Andrew</span> <span property="familyName">Larson</span>, <span property="honorificSuffix">PhD</span></a></span></span><span data-hidden-on="all">, <span property="author" typeof="Person" role="listitem"><a href="#con15"><span property="givenName">Reed A.</span> <span property="familyName">Omary</span>, <span property="honorificSuffix">MD, MS</span></a></span></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con16"><span property="givenName">Riad</span> <span property="familyName">Salem</span>, <span property="honorificSuffix">MD, MBA</span></a></span><span data-displayed-on="none" data-on-display="all" aria-hidden="true"> <span data-action="hide">Show Fewer</span></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">28</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">1</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.281065721" property="sameAs">https://doi.org/10.1148/rg.281065721</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
