        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="CT Colonography with Computer-aided Detection: Recognizing the Causes of False-Positive Reader Results" /><meta name="dc.Creator" content="Igor  Trilisky" /><meta name="dc.Creator" content="Abraham H.  Dachman" /><meta name="dc.Creator" content="Kristen  Wroblewski" /><meta name="dc.Creator" content="Michael W.  Vannier" /><meta name="dc.Creator" content="John M.  Horne" /><meta name="dc.Description" content="Improved CT colonography interpretation can be achieved with computer-aided detection subject to avoidable false-positive interpretations, which are described and illustrated." /><meta name="Description" content="Improved CT colonography interpretation can be achieved with computer-aided detection subject to avoidable false-positive interpretations, which are described and illustrated." /><meta name="dc.Description" content="Computed tomography (CT) colonography is a screening modality used to detect colonic polyps before they progress to colorectal cancer. Computer-aided detection (CAD) is designed to decrease errors ..." /><meta name="Description" content="Computed tomography (CT) colonography is a screening modality used to detect colonic polyps before they progress to colorectal cancer. Computer-aided detection (CAD) is designed to decrease errors ..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2014-11-10" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="manuscript" content="130053" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.347130053" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.347130053" /><meta name="dc.Language" content="EN" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="2014 by the Radiological Society of North America, Inc." />
        
        

        
