        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Oct 5 2018</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">LI-RADS Version 2018 Ancillary Features at MRI</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Milena</span> <span property="familyName">Cerny</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-5033-7507" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-5033-7507</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Victoria</span> <span property="familyName">Chernyak</span>, <span property="honorificSuffix">MD, MS</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Damien</span> <span property="familyName">Olivié</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Jean-Sébastien</span> <span property="familyName">Billiard</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Jessica</span> <span property="familyName">Murphy-Lavallée</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Ania Z.</span> <span property="familyName">Kielar</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Khaled M.</span> <span property="familyName">Elsayes</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Laurence</span> <span property="familyName">Bourque</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">Jonathan C.</span> <span property="familyName">Hooker</span>, <span property="honorificSuffix">BS</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con10"><span property="givenName">Claude B.</span> <span property="familyName">Sirlin</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con11"><span property="givenName">An</span> <span property="familyName">Tang</span>, <span property="honorificSuffix">MD, MSc</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-8967-5503" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-8967-5503</a> <a href="/cdn-cgi/l/email-protection#a3c2cd8dd7c2cdc4e3d6cecccdd7d1c6c2cf8dc0c2" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="25444b0b51444b426550484a4b51574044490b4644">[email&#160;protected]</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">38</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">7</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2018180052" property="sameAs">https://doi.org/10.1148/rg.2018180052</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
