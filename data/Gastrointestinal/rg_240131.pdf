        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">May 29 2025</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Mucinous Appendiceal Neoplasms and Pseudomyxoma Peritonei: Imaging Features and Current Therapies</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Laura C.</span> <span property="familyName">Jorgenson</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0009-0002-1281-1081" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0009-0002-1281-1081</a> <a href="/cdn-cgi/l/email-protection#fcb6938e9b99928f9392d2909d898e9dcebc919d8593d2999889" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="aae0c5d8cdcfc4d9c5c484c6cbdfd8cb98eac7cbd3c584cfcedf">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Sherry S.</span> <span property="familyName">Wang</span>, <span property="honorificSuffix">MBBS</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-6445-1025" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-6445-1025</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Travis E.</span> <span property="familyName">Grotz</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Rondell P.</span> <span property="familyName">Graham</span>, <span property="honorificSuffix">MBBS</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Patrick J.</span> <span property="familyName">Navin</span>, <span property="honorificSuffix">BCh, BAO</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-8095-9283" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-8095-9283</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Christopher</span> <span property="familyName">Favazza</span>, <span property="honorificSuffix">PhD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Sudhakar K</span> <span property="familyName">Venkatesh</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-7514-1030" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-7514-1030</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Jeff L.</span> <span property="familyName">Fidler</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-8275-126X" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-8275-126X</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">Joel G.</span> <span property="familyName">Fletcher</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-8941-5434" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-8941-5434</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con10"><span property="givenName">Eric C.</span> <span property="familyName">Ehman</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con11"><span property="givenName">Shannon P.</span> <span property="familyName">Sheedy</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-7712-8278" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-7712-8278</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">45</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">6</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.240131" property="sameAs">https://doi.org/10.1148/rg.240131</a></div></div><div class="core-relations my-3"><div class="relation mb-3"><div class="relation--head"><i class="icon-info"></i><a href="/doi/10.1148/rg.259008">See erratum</a></div></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__cme info-panel__item"><a href="/servlet/linkout?doi=10.1148%2Frg.240131&suffix=s0&url=https://api3.rsna.org/lms/v1/sendToJournalCMETest?doi=10.1148%2Frg.240131" class="btn btn--cme"