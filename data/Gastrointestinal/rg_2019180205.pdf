        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Jul 26 2019</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Contrast-enhanced US in Local Ablative Therapy and Secondary Surveillance for Hepatocellular Carcinoma</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Sanjay</span> <span property="familyName">Bansal</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Jonathan</span> <span property="familyName">Gui</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Christina</span> <span property="familyName">Merrill</span>, <span property="honorificSuffix">BSc</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Jason K.</span> <span property="familyName">Wong</span>, <span property="honorificSuffix">MD, FRCPC</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Kelly W.</span> <span property="familyName">Burak</span>, <span property="honorificSuffix">MD, FRCPC</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Stephanie R.</span> <span property="familyName">Wilson</span>, <span property="honorificSuffix">MD, FRCPC</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-6396-7612" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-6396-7612</a> <a href="/cdn-cgi/l/email-protection#d88bacbda8b0b9b6b1bdf68fb1b4abb7b698b9b0abf6bbb9" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="712205140119101f18145f26181d021e1f311019025f1210">[email&#160;protected]</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">39</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">5</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2019180205" property="sameAs">https://doi.org/10.1148/rg.2019180205</a></div></div><div class="core-relations my-3"><div class="relation mb-3"><div class="relation--head"><i class="icon-info"></i><a href="/doi/10.1148/rg.2019190049">See related article</a></div></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
