<div tabindex="-1" id="modal--changePassword"
     aria-labelledby="modalChangePasswordLabel"
     class="modal fade change-password-drawer" aria-modal="true" role="dialog">
    <div role="document" class="modal-dialog modal-fullscreen-sm-down">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="modalChangePasswordLabel" class="modal-title h5">Change Password </h2>
                <button type="button" data-dismiss="modal" aria-label="close" class="close">
                    <span aria-hidden="true">x</span><span class="sr-only">Close</span>
                </button>
            </div>
            







<form action="/action/changePassword" class="raa-form change-password-form" method="post"><div class="alert alert-danger d-none"></div>
    <input type="hidden" name="submit" value="submit" />
    <div class="form-row">
        <div class="col">
            <div class="form-group">
                <label for="5aa3ed89-eced-4d4d-b752-312a8cf5cebf-old">Old Password</label>
                <input id="5aa3ed89-eced-4d4d-b752-312a8cf5cebf-old" class="form-control" type="password" name="old" value="" autocomplete="off" />
                <span class="icon-eye d-none"></span>
            </div>
        </div>
    </div>
    <div class="form-row">
