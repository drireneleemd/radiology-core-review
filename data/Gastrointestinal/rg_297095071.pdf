        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Kidney in Danger: CT Findings of Blunt and Penetrating Renal Trauma1" /><meta name="dc.Creator" content="Raquel Cano  Alonso" /><meta name="dc.Creator" content="Susana Borruel  Nacenta" /><meta name="dc.Creator" content="Patricia Diez  Martinez" /><meta name="dc.Creator" content="Angel Sanchez  Guerrero" /><meta name="dc.Creator" content="Carlos Garcia  Fuentes" /><meta name="dc.Description" content="Abdominopelvic multidetector CT plays a major role in identifying and classifying injuries in blunt and penetrating renal trauma, thereby aiding in the selection of an appropriate treatment option." /><meta name="Description" content="Abdominopelvic multidetector CT plays a major role in identifying and classifying injuries in blunt and penetrating renal trauma, thereby aiding in the selection of an appropriate treatment option." /><meta name="dc.Description" content="Approximately 10% of all significant blunt abdominal traumatic injuries manifest with renal injury, although it is usually minor. However, renal imaging is indicated in cases of gross hematuria, pe..." /><meta name="Description" content="Approximately 10% of all significant blunt abdominal traumatic injuries manifest with renal injury, although it is usually minor. However, renal imaging is indicated in cases of gross hematuria, pe..." /><meta name="dc.Publisher" content=" Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2009-11-01" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.297095071" /><meta name="dc.Identifier" scheme="publisher-id" content="0292033" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.297095071" /><meta name="dc.Language" content="en" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2009" />
        
        

        
