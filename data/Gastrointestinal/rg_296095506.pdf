        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="MR Imaging of Cystic Lesions of the Pancreas1" /><meta name="dc.Creator" content="Bobby  Kalb" /><meta name="dc.Creator" content="Juan M.  Sarmiento" /><meta name="dc.Creator" content="David A  Kooby" /><meta name="dc.Creator" content="N. Volkan  Adsay" /><meta name="dc.Creator" content="Diego R.  Martin" /><meta name="dc.Description" content="Knowledge of the MR imaging features of cystic lesions of the pancreas, which may represent both neoplastic and nonneoplastic processes, is necessary for accurate diagnostic evaluation." /><meta name="Description" content="Knowledge of the MR imaging features of cystic lesions of the pancreas, which may represent both neoplastic and nonneoplastic processes, is necessary for accurate diagnostic evaluation." /><meta name="dc.Description" content="Pancreatic cystic lesions are relatively common imaging findings and may be secondary to both benign and malignant disease processes. Accurate characterization of the internal features of a cyst—in..." /><meta name="Description" content="Pancreatic cystic lesions are relatively common imaging findings and may be secondary to both benign and malignant disease processes. Accurate characterization of the internal features of a cyst—in..." /><meta name="dc.Publisher" content=" Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2009-10-01" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.296095506" /><meta name="dc.Identifier" scheme="publisher-id" content="0291749" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.296095506" /><meta name="dc.Language" content="en" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2009" />
        
        

        
