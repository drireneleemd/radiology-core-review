        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Dec 13 2019</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Hyperintense Liver Masses at Hepatobiliary Phase Gadoxetic Acid–enhanced MRI: Imaging Appearances and Clinical Importance</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Nobuhiro</span> <span property="familyName">Fujita</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-9708-050X" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-9708-050X</a> <a href="/cdn-cgi/l/email-protection#157b3873607f7c6174556774717c7a793b7870713b7e6c60667d6038603b74763b7f65" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="ec82c18a998685988dac9e8d88858380c2818988c28795999f8499c199c28d8fc2869c">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Akihiro</span> <span property="familyName">Nishie</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-7103-7757" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-7103-7757</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Yoshiki</span> <span property="familyName">Asayama</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-6495-4821" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-6495-4821</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Kousei</span> <span property="familyName">Ishigami</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Yasuhiro</span> <span property="familyName">Ushijima</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Daisuke</span> <span property="familyName">Kakihara</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Tomohiro</span> <span property="familyName">Nakayama</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Koichiro</span> <span property="familyName">Morita</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">Keisuke</span> <span property="familyName">Ishimatsu</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con10"><span property="givenName">Hiroshi</span> <span property="familyName">Honda</span>, <span property="honorificSuffix">MD</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">40</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">1</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2020190037" property="sameAs">https://doi.org/10.1148/rg.2020190037</a></div></div><div class="core-relations my-3"><div class="relation mb-3"><div class="relation--head"><i class="icon-info"></i><a href="/doi/10.1148/rg.2020190200">See related article</a></div></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
