        <div class="content journal-branding">



        
        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Informatics</span></div><div class="meta-panel__onlineDate">Nov 13 2018</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Deep Learning Electronic Cleansing for Single- and Dual-Energy CT Colonography</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Rie</span> <span property="familyName">Tachibana</span>, <span property="honorificSuffix">PhD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Janne J.</span> <span property="familyName">Näppi</span>, <span property="honorificSuffix">PhD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Junko</span> <span property="familyName">Ota</span>, <span property="honorificSuffix">PhD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Nadja</span> <span property="familyName">Kohlhase</span>, <span property="honorificSuffix">MS</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Toru</span> <span property="familyName">Hironaka</span>, <span property="honorificSuffix">MS</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Se Hyung</span> <span property="familyName">Kim</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-8664-0356" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-8664-0356</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Daniele</span> <span property="familyName">Regge</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Hiroyuki</span> <span property="familyName">Yoshida</span>, <span property="honorificSuffix">PhD</span></a> <a href="/cdn-cgi/l/email-protection#84fdebf7ecede0e5aaecedf6ebc4e9e3ecaaece5f6f2e5f6e0aae1e0f1" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="9be2f4e8f3f2fffab5f3f2e9f4dbf6fcf3b5f3fae9edfae9ffb5feffee">[email&#160;protected]</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">38</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">7</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2018170173" property="sameAs">https://doi.org/10.1148/rg.2018170173</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
