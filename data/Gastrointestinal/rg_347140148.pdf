            <div class="modal-body">
                <form action="/action/verifyPhoneNumber" method="post"><input type="hidden" name="submit" value="submit" />
                    <div class="alert alert-danger d-none"></div>
                    <div class="form-row">
                        <div class="col">
                            <div class="form-group">
                                <label for="3d660699-8f14-43b5-a63f-f581c3711956-code">Enter the verification code</label>
                                <input id="3d660699-8f14-43b5-a63f-f581c3711956-code" class="form-control" type="text" name="verificationCode" value="" size="15"pattern="^[0-9]{6}$"required="required" />
                            </div>
                        </div>
                    </div>
                    <div class="form-row">
