        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Abdominal and Pelvic Aneurysms and Pseudoaneurysms: Imaging Review with Clinical, Radiologic, and Treatment Correlation" /><meta name="dc.Creator" content="Robert A.  Jesinger" /><meta name="dc.Creator" content="Andrew A.  Thoreson" /><meta name="dc.Creator" content="Ramit  Lamba" /><meta name="dc.Description" content="It is important to recognize abdominopelvic visceral artery aneurysms and pseudoaneurysms at imaging because early treatment can improve quality of life and prevent life-threatening complications." /><meta name="Description" content="It is important to recognize abdominopelvic visceral artery aneurysms and pseudoaneurysms at imaging because early treatment can improve quality of life and prevent life-threatening complications." /><meta name="dc.Description" content="Abnormally enlarged visceral arteries in the abdomen and pelvis must be recognized radiologically because early treatment can improve the quality of life and prevent life-threatening complications...." /><meta name="Description" content="Abnormally enlarged visceral arteries in the abdomen and pelvis must be recognized radiologically because early treatment can improve the quality of life and prevent life-threatening complications...." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2013-05-03" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="publisher-id" content="115036" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.333115036" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.333115036" /><meta name="dc.Language" content="EN" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2013" />
        
        

        
