        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Multidetector CT of the Postoperative Colon: Review of Normal Appearances and Common Complications" /><meta name="dc.Creator" content="Stefanie  Weinstein" /><meta name="dc.Creator" content="Samuel  Osei-Bonsu" /><meta name="dc.Creator" content="Rizwan  Aslam" /><meta name="dc.Creator" content="Judy  Yee" /><meta name="dc.Description" content="Accurate characterization of the postoperative colon with multidetector CT will facilitate the diagnosis of potentially life-threatening complications and aid the surgeon with clinical management." /><meta name="Description" content="Accurate characterization of the postoperative colon with multidetector CT will facilitate the diagnosis of potentially life-threatening complications and aid the surgeon with clinical management." /><meta name="dc.Description" content="If not properly recognized, the normal postoperative appearance of the pelvis following colorectal surgery can be misinterpreted as disease, including infection or recurrent tumor. However, multide..." /><meta name="Description" content="If not properly recognized, the normal postoperative appearance of the pelvis following colorectal surgery can be misinterpreted as disease, including infection or recurrent tumor. However, multide..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2013-03-04" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="publisher-id" content="125723" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.332125723" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.332125723" /><meta name="dc.Language" content="EN" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2013" /