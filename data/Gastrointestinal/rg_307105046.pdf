gure></div><div class="figure-wrap"><figure id="fig12b" class="graphic"><img src="/cms/10.1148/rg.307105046/asset/images/105046fig12b.jpeg" height="1800" width="1800" loading="lazy" /><figcaption><span class="heading">Figure 12b</span> <!-- There is no content. --><div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.307105046&amp;id=fig12b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig12c" class="graphic"><img src="/cms/10.1148/rg.307105046/asset/images/105046fig12c.jpeg" height="1278" width="1278" loading="lazy" /><figcaption><span class="heading">Figure 12c</span> <!-- There is no content. --><div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.307105046&amp;id=fig12c">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig13a" class="graphic"><img src="/cms/10.1148/rg.307105046/asset/images/105046fig13a.jpeg" height="1800" width="1729" loading="lazy" /><figcaption><span class="heading">Figure 13a</span> <!-- There is no content. --><div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.307105046&amp;id=fig13a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig13b" class="graphic"><img src="/cms/10.1148/rg.307105046/asset/images/105046fig13b.jpeg" height="1453" width="1800" loading="lazy" /><figcaption><span class="heading">Figure 13b</span> <!-- There is no content. --><div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.307105046&amp;id=fig13b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig13c" class="graphic"><img src="/cms/1