        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Apr 24 2015</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Cystic Fibrosis below the Diaphragm: Abdominal Findings in Adult Patients</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Lisa P.</span> <span property="familyName">Lavelle</span>, <span property="honorificSuffix">MBBCh, FFRRCSI</span></a> <a href="/cdn-cgi/l/email-protection#cfa3e1a3aeb9aaa3a3aa8fbcbbe2b9a6a1acaaa1bbbce1a6aa" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="39551755584f5c55555c794a4d144f50575a5c574d4a17505c">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Sinead H.</span> <span property="familyName">McEvoy</span>, <span property="honorificSuffix">MBBCh, FFRRCSI</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Elaine</span> <span property="familyName">Ni Mhurchu</span>, <span property="honorificSuffix">MBBCh, FFRRCSI</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Robert G.</span> <span property="familyName">Gibney</span>, <span property="honorificSuffix">MBBCh, FFRRCSI</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Colm J.</span> <span property="familyName">McMahon</span>, <span property="honorificSuffix">MBBCh, FFRRCSI</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Eric J.</span> <span property="familyName">Heffernan</span>, <span property="honorificSuffix">MBBCh, FFRRCSI</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Dermot E.</span> <span property="familyName">Malone</span>, <span property="honorificSuffix">MD, FRCPI, FFRRCSI, FRCR, FRCPC</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">35</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">3</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2015140110" property="sameAs">https://doi.org/10.1148/rg.2015140110</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
