        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Trauma/Emergency Radiology</span></div><div class="meta-panel__onlineDate">Nov 27 2020</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Pancreatic Trauma: Imaging Review and Management Update</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Andres R.</span> <span property="familyName">Ayoob</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-3514-9185" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-3514-9185</a> <a href="/cdn-cgi/l/email-protection#dabbb4bea8bfa9f4bba3b5b5b89aafb1a3f4bfbeaf" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="f998979d8b9c8ad7988096969bb98c9280d79c9d8c">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">James T.</span> <span property="familyName">Lee</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-5324-7467" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-5324-7467</a></span>, <span property="author" typeof="Person" role="listit