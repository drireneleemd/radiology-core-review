        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Jul 23 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">How to Use LI-RADS to Report Liver CT and MRI Observations</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Guilherme </span> <span property="familyName">M. Cunha</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-6403-5155" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-6403-5155</a> <a href="/cdn-cgi/l/email-protection#0b6c687e65636a4b7e7c256e6f7e" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="83e4e0f6edebe2c3f6f4ade6e7f6">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Kathryn J.</span> <span property="familyName">Fowler</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-9188-1701" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-9188-1701</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Alexandra</span> <span property="familyName">Roudenko</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-8917-7616" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-8917-7616</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Bachir</span> <span property="familyName">Taouli</span>, <span property="honorificSuffix">MD, MHA</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-6409-1333" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-6409-1333</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Alice W.</span> <span property="familyName">Fung</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-8939-6125" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-8939-6125</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Khaled M.</span> <span property="familyName">Elsayes</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-0184-0717" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-0184-0717</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Robert M.</span> <span property="familyName">Marks</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-1463-718X" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-1463-718X</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Irene</span> <span property="familyName">Cruite</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">Natally</span> <span property="familyName">Horvat</span>, <span property="honorificSuffix">MD, PhD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con10"><span property="givenName">Victoria</span> <span property="familyName">Chernyak</span>, <span property="honorificSuffix">MD, MS</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-5715-1403" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-5715-1403</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con11"><span property="givenName">Claude B.</span> <span property="familyName">Sirlin</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-6639-9072" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-6639-9072</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con12"><span property="givenName">An</span> <span property="familyName">Tang</span>, <span property="honorificSuffix">MD, MSc</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-8967-5503" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-8967-5503</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">41</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="Publi