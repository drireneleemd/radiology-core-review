-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.316115519&amp;id=fig08">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig09a" class="graphic"><img src="/cms/10.1148/rg.316115519/asset/images/115519fig09a.jpeg" height="1005" width="1280" loading="lazy" /><figcaption><span class="heading">Figure 9a</span> <!-- There is no content. --><div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.316115519&amp;id=fig09a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig09b" class="graphic"><img src="/cms/10.1148/rg.316115519/asset/images/115519fig09b.jpeg" height="1064" width="1280" loading="lazy" /><figcaption><span class="heading">Figure 9b</span> <!-- There is no content. --><div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.316115519&amp;id=fig09b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig09c" class="graphic"><img src="/cms/10.1148/rg.316115519/asset/images/115519fig09c.jpeg" height="988" width="1280" loading="lazy" /><figcaption><span class="heading">Figure 9c</span> <!-- There is no content. --><div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.316115519&amp;id=fig09c">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig10a" class="graphic"><img src="/cms/10.1148/rg.316115519/asset/images/115519fig10a.jpeg" height="914" width="1280" loading="lazy" /><figcaption><span class="heading">Figure 10a</span> <!-- There is no content. --><div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.316115519&amp;id=fig10a">Download 