        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Abdominopelvic Emergency Imaging</span></div><div class="meta-panel__onlineDate">Sep 25 2025</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Acute Mesenteric Ischemia: Pathophysiology-based Approach to Imaging Findings and Diagnosis</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Matthew H.</span> <span property="familyName">Lee</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-8500-0306" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-8500-0306</a> <a href="/cdn-cgi/l/email-protection#ddb0b1b8b8e89da8aab5b8bcb1a9b5f3b2afba" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="99f4f5fcfcacd9eceef1fcf8f5edf1b7f6ebfe">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Perry J.</span> <span property="familyName">Pickhardt</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-5534-8202" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-5534-8202</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Anna M.</span> <span property="familyName">Sorensen</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-2327-4886" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-2327-4886</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Giuseppe V.</span> <span property="familyName">Toia</span>, <span property="honorificSuffix">MD, MS</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-5794-2822" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-5794-2822</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Meghan G.</span> <span property="familyName">Lubner</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-3788-2871" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-3788-2871</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Ryan</span> <span property="familyName">Sappenfield</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">David H.</span> <span property="familyName">Kim</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-4215-174X" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-4215-174X</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">45</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">10</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.250012" property="sameAs">https://doi.org/10.1148/rg.250012</a></div></div><div class="core-relations my-3"><div class="relation mb-3"><div class="relation--head"><i class="icon-info"></i><a href="/doi/10.1148/rg.250171">See the invited commentary by Huete in this issue.</a></div></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__cme info-panel__item"><a href="/servlet/linkout?doi=10.1148%2Frg.250012&suffix=s0&url=https://api3.rsna.org/lms/v1/sendToJournalCMETest?doi=10.1148%2Frg.250012" class="btn btn--cme" data-toggle="tooltip"><i aria-hidden="true" class="icon-checkmark2"></i><span class="link-text">CME</span></a></div><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
