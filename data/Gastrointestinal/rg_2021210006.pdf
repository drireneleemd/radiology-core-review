        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Multisystem Radiology</span></div><div class="meta-panel__label"><span>Radiology-Pathology Collection</span></div><div class="meta-panel__onlineDate">Aug 6 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Amyloidosis: Multisystem Spectrum of Disease with Pathologic Correlation</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Mark D.</span> <span property="familyName">Sugi</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-2154-3990" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-2154-3990</a> <a href="/cdn-cgi/l/email-protection#a5c8c4d7ce8bd6d0c2cce5d0c6d6c38bc0c1d0" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="87eae6f5eca9f4f2e0eec7f2e4f4e1a9e2e3f2">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Akira</span> <span property="familyName">Kawashima</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-4686-8369" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-4686-8369</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Marcela A.</span> <span property="familyName">Salomao</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Sanjeev</span> <span property="familyName">Bhalla</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-1262-8925" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-1262-8925</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Sudhakar K.</span> <span property="familyName">Venkatesh</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-7514-1030" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-7514-1030</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Perry J.</span> <span property="familyName">Pickhardt</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-5534-8202" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-5534-8202</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">41</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">5</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2021210006" property="sameAs">https://doi.org/10.1148/rg.2021210006</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
