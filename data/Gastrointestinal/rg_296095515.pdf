        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Hepatobiliary-specific MR Contrast Agents: Role in Imaging the Liver and Biliary Tree1" /><meta name="dc.Creator" content="Melanie K.  Seale" /><meta name="dc.Creator" content="Onofrio A.  Catalano" /><meta name="dc.Creator" content="Sanjay  Saini" /><meta name="dc.Creator" content="Peter F.  Hahn" /><meta name="dc.Creator" content="Dushyant V.  Sahani" /><meta name="dc.Description" content="The hepatobiliary-specific class of MR contrast agents is introduced, and their pharmacology, benefits and pitfalls, and current and emerging applications are discussed." /><meta name="Description" content="The hepatobiliary-specific class of MR contrast agents is introduced, and their pharmacology, benefits and pitfalls, and current and emerging applications are discussed." /><meta name="dc.Description" content="Hepatobiliary-specific contrast agents are one of several classes of contrast agents available for magnetic resonance (MR) imaging of the liver. These agents are taken up by functioning hepatocytes..." /><meta name="Description" content="Hepatobiliary-specific contrast agents are one of several classes of contrast agents available for magnetic resonance (MR) imaging of the liver. These agents are taken up by functioning hepatocytes..." /><meta name="dc.Publisher" content=" Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2009-10-01" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.296095515" /><meta name="dc.Identifier" scheme="publisher-id" content="0291725" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.296095515" /><meta name="dc.Language" content="en" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2009" />
        
        

        
