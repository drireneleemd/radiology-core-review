</div><div class="publication__menu__toggler"><button type="button" data-toggle="collapse" data-target="#publication__menu__content" aria-controls="#publication__menu__content" aria-expanded="false" aria-label="Open Publication Menu" class="d-xl-none align-items-center navbar-toggler animation-icon-shift text-regular font-weight-bold text-white p-0"><span class="publication__menu__toggler__title"></span><span class="icon-component "><svg aria-hidden="true" style=""><use xlink:href="/specs/products/rsna/releasedAssets/icons/icons-db0642a32256a04b1fd820d93ecb34dc.spritemap.svg#arrows-right"></use></svg></span></button><button type="button" data-toggle="collapse" data-target="#publication__menu__content" aria-controls="#publication__menu__content" aria-expanded="false" aria-label="Close Publication Menu" class="d-xl-none align-items-center navbar-toggler animation-icon-shift text-regular font-weight-bold text-white p-0 hidden"><span class="mr-8">Close</span><span class="icon-component "><svg aria-hidden="true" style=""><use xlink:href="/specs/products/rsna/releasedAssets/icons/icons-db0642a32256a04b1fd820d93ecb34dc.spritemap.svg#close"></use></svg></span></button></div></div><div id="publication__menu__content" class="publication__menu__content collapse navbar-collapse sidebar collapse-lock-screen align-items-center px-16 pb-40 px-xl-0 py-xl-0"><div class="publication__menu__list flex-grow-1 d-xl-flex justify-content-xl-end"><p class="publication__menu__title publication__menu__list__heading d-xl-none text-small-bold text-deep-gray mb-0 p-16"></p><ul aria-label="publication menu list" class="navbar-nav"><li class="nav-item pr-xl-24"><a id="publication-menu-item-0" href="/toc/radiographics/current" tabindex="" class="nav-link text-small-bold">Latest Articles</a></li><li class="nav-item pr-xl-24"><a id="publication-menu-item-1" href="/toc/radiographics/46/5" tabindex="" class="nav-link text-small-bold">Current Issue</a></li><li class="nav-item pr-xl-24"><a id="publication-menu-item-2" href="/loi/radiographics" tabindex="" class="nav-link text-small-bold">All Issues</a></li><li class="nav-item pr-xl-24"><div class="dropdown"><a id="publication-menu-item-3" href="#" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" class="nav-link dropdown-toggle text-small-bold">Collections</a><div aria-labelledby="publication-menu-item-3" class="dropdown-menu"><a href="/page/radiographics/specialissues" class="dropdown-item">Monograph</a><a href="/topic/article-types/arttype-cookyjar?sortBy=Earliest" class="dropdown-item">Cases from the Cooky Jar</a><a href="/page/radiographics/visual-abstract" class="dropdown-item">Visual Abstracts</a><a href="/page/podcasts#radiographics" class="dropdown-item">Podcasts</a></div></div></li><li class="nav-item pr-xl-24"><div class="dropdown"><a id="publication-menu-item-4" href="#" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" class="nav-link dropdown-toggle text-small-bold">Authors/Reviewers</a><div aria-labelledby="publication-menu-item-4" class="dropdown-menu"><a href="/page/radiographics/rgauthor_instructions" class="dropdown-item">Instructions for Authors </a><a href="https://mc.manuscriptcentral.com/rg" class="dropdown-item">Submit a Manuscript </a><a href="/page/authorservices" class="dropdown-item">Author Services</a><a href="/page/radiographics/peer-review" class="dropdown-item">For Reviewers</a></div></div></li><li class="nav-item pr-xl-24"><div class="dropdown"><a id="publication-menu-item-5" href="#" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" class="nav-link dropdown-toggle text-small-bold">Core Learning</a><div aria-labelledby="publication-menu-item-5" class="dropdown-menu"><a href="/page/radiographics/rgteam/top10Home" class="dropdown-item">Top 10 Reading List</a><a href="/page/radiographics/abr-core-exam-study-guide" class="dropdown-item">ABR Core Exam Blueprints Article Index</a><a href="/page/radiographics/aapm-physics" class="dropdown-item">AAPM Physics Curriculum Article Index</a><a href="/page/radiographics/rgteam/top30_physics" class="dropdown-item">Top 30 Physics Articles</a><a href="/page/radiographics/nis" class="dropdown-item">Noninterpretive Skills Index</a><a href="/topic/presentations/fundamentals?sortBy=Earliest" class="dropdown-item">RadioGraphics Fundamentals</a><a href="/topic/presentations/RGTutorials?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">RadioGraphics Tutorials</a><a href="/page/radiographics/on-call" class="dropdown-item">On-Call Preparation Article Index</a><a href="/action/doSearch?target=digital-object-search&amp;DOResourceTypeId=exams&amp;sortBy=PubDateField_desc " class="dropdown-item">Test Your Knowledge Quizzes</a></div></div></li><li class="nav-item pr-xl-24"><div class="dropdown"><a id="publication-menu-item-6" href="#" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" class="nav-link dropdown-toggle text-small-bold">Browse by</a><div aria-labelledby="publication-menu-item-6" class="dropdown-menu"><a href="https://chatbot-beta.rsna.org" class="dropdown-item">RadioGraphics AI Research Assistant</a><a href="/topic/subspecialty/ai?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">AI</a><a href="/topic/subspecialty/bq?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">Biomarkers/Quantitative Imaging</a><a href="/topic/subspecialty/br?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">Breast Imaging</a><a href="/topic/subspecialty/ca?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">Cardiac Radiology</a><a href="/topic/subspecialty/ch?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">Chest Radiology</a><a href="/topic/subspecialty/ct?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">Computed Tomography</a><a href="/topic/subspecialty/ed?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">Education</a><a href="/topic/subspecialty/er?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">Emergency Radiology</a><a href="/topic/subspecialty/gi?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">Gastrointestinal Radiology</a><a href="/topic/subspecialty/gn?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">General/Multisystem Radiology</a><a href="/topic/subspecialty/gu?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">Genitourinary Radiology</a><a href="/topic/subspecialty/hn?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">Head and Neck</a><a href="/topic/subspecialty/hp?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">Health Policy</a><a href="/topic/subspecialty/in?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">Informatics</a><a href="/topic/subspecialty/ir?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">Interventional Radiology</a><a href="/topic/subspecialty/lm?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">Leadership &amp; Management</a><a href="/topic/subspecialty/mr?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">Magnetic Resonance Imaging</a><a href="/topic/subspecialty/mi?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">Molecular Imaging</a><a href="/topic/subspecialty/mk?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">Musculoskeletal Radiology</a><a href="/topic/subspecialty/nr?sortBy=Earliest&amp;startPage=&amp;SeriesKey=radiographics" class="dropdown-item">Neuroradiology</a><a href="/topic/subspecialty/nm?sortBy=Earlie