        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Gastrointestinal Imaging</span></div><div class="meta-panel__onlineDate">Mar 1 2014</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Abdominal Complications Following Hematopoietic Stem Cell Transplantation</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Lourdes del</span> <span property="familyName">Campo</span>, <span property="honorificSuffix">MD, PhD</span></a> <a href="/cdn-cgi/l/email-protection#82e6e7eee1e3eff2edaceeedf7f0e6e7f1c2e5efe3ebeeace1edef" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="b9dddcd5dad8d4c9d697d5d6cccbdddccaf9ded4d8d0d597dad6d4">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Nieves Gómez</span> <span property="familyName">León</span>, <span property="honorificSuffix">MD, PhD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Diana Castaño</span> <span property="familyName">Palacios</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Claudio</span> <span property="familyName">Lagana</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">David</span> <span property="familyName">Tagarro</span>, <span property="honorificSuffix">MD</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">34</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">2</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.342135046" property="sameAs">https://doi.org/10.1148/rg.342135046</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
