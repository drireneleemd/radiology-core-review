        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="US of Gastrointestinal Tract Disease" /><meta name="dc.Creator" content="Derek  Muradali" /><meta name="dc.Creator" content="Deborah R.  Goldberg" /><meta name="dc.Description" content="The US appearances of normal and abnormal bowel are discussed, with emphasis on a variety of benign and malignant pathologic conditions and potential errors at imaging interpretation." /><meta name="Description" content="The US appearances of normal and abnormal bowel are discussed, with emphasis on a variety of benign and malignant pathologic conditions and potential errors at imaging interpretation." /><meta name="dc.Description" content="The potential use of ultrasonography (US) in evaluating gut disease has been underappreciated in most diagnostic imaging departments in North America. The impression that US has a questionable role..." /><meta name="Description" content="The potential use of ultrasonography (US) in evaluating gut disease has been underappreciated in most diagnostic imaging departments in North America. The impression that US has a questionable role..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2015-01-15" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="manuscript" content="140003" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.351140003" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.351140003" /><meta name="dc.Language" content="EN" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="2015 by the Radiological Society of North America, Inc." />
        
        

        
