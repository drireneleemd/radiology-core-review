        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Trauma/Emergency Radiology</span></div><div class="meta-panel__onlineDate">Sep 1 2020</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Imaging Spectrum of Duodenal Emergencies</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Babina</span> <span property="familyName">Gosangi</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-4855-4232" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-4855-4232</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Tatiana C.</span> <span property="familyName">Rocha</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-5726-1461" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-5726-1461</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Alejandra</span> <span property="familyName">Duran-Mendicuti</span>, <span property="honorificSuffix">MD</span></a> <a href="/cdn-cgi/l/email-protection#b5d8d1c0c7d4dbd8d0dbd1dcd6c0c1dcf5d7c2dd9bddd4c7c3d4c7d19bd0d1c0" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="5538312027343b38303b313c3620213c1537223d7b3d3427233427317b303120">[email&#160;protected]</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">40</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">5</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2020200045" property="sameAs">https://doi.org/10.1148/rg.2020200045</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
