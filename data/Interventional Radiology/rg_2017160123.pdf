        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Vascular/Interventional Radiology</span></div><div class="meta-panel__onlineDate">Mar 18 2017</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Contrast-enhanced US–guided Interventions: Improving Success Rate and Avoiding Complications Using US Contrast Agents</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Dean Y.</span> <span property="familyName">Huang</span>, <span property="honorificSuffix">FRCR, EBIR</span></a> <a href="/cdn-cgi/l/email-protection#7c18191d125214091d121b3c12140f52121908" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="1672737778387e6377787156787e6538787362">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Gibran T.</span> <span property="familyName">Yusuf</span>, <span property="honorificSuffix">FRCR</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Mohammad</span> <span property="familyName">Daneshi</span>, <span property="honorificSuffix">FRCR</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Mohammad Ali</span> <span property="familyName">Husainy</span>, <span property="honorificSuffix">MD, FRCR</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Raymond</span> <span property="familyName">Ramnarine</span>, <span property="honorificSuffix">FRCR</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-2866-3749" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-2866-3749</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Maria E. K.</span> <span property="familyName">Sellars</span>, <span property="honorificSuffix">FRCR</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Paul S.</span> <span property="familyName">Sidhu</span>, <span property="honorificSuffix">MRCP, FRCR</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">37</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">2</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2017160123" property="sameAs">https://doi.org/10.1148/rg.2017160123</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
