        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Breast Imaging</span></div><div class="meta-panel__onlineDate">Aug 6 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Upright Tomosynthesis-guided Breast Biopsy: Tips, Tricks, and Troubleshooting</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Charmi A.</span> <span property="familyName">Vijapura</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-2563-0378" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-2563-0378</a> <a href="/cdn-cgi/l/email-protection#d6b5beb7a4bbbfa096b1bbb7bfbaf8b5b9bb" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="f1929990839c9887b1969c90989ddf929e9c">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Rifat A.</span> <span property="familyName">Wahab</span>, <span property="honorificSuffix">DO</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-9177-6098" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-9177-6098</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Atharva G.</span> <span property="familyName">Thakore</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Mary C.</span> <span property="familyName">Mahoney</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-6139-9201" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-6139-9201</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">41</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">5</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2021210017" property="sameAs">https://doi.org/10.1148/rg.2021210017</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
