        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Breast Imaging</span></div><div class="meta-panel__onlineDate">Mar 19 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Breast MRI: False-Negative Results and Missed Opportunities</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Katrina E.</span> <span property="familyName">Korhonen</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-0365-2640" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-0365-2640</a> <a href="/cdn-cgi/l/email-protection#701b110402191e115e1b1f02181f1e151e30021114001102041e1502035e131f1d" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="abc0cadfd9c2c5ca85c0c4d9c3c4c5cec5ebd9cacfdbcad9dfc5ced9d885c8c4c6">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Samantha P.</span> <span property="familyName">Zuckerman</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-8872-2846" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-8872-2846</a></span>,