        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Breast Imaging</span></div><div class="meta-panel__label"><span><i>RadioGraphics</i> Fundamentals</span></div><div class="meta-panel__onlineDate">Dec 4 2025</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Managing Bleeding Risks and Complications of Imaging-guided Breast Biopsy: A Primer for Radiologists</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Thomas P.</span> <span property="familyName">LoDuca</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Clara</span> <span property="familyName">Nemr</span>, <span property="honorificSuffix">BS</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Alison R.</span> <span property="familyName">Gegios</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Ryan W.</span> <span property="familyName">Woods</span>, <span property="honorificSuffix">MD, MPH</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-0185-8458" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-0185-8458</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Amy M.</span> <span property="familyName">Fowler</span>, <span property="honorificSuffix">MD, PhD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-1172-1618" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-1172-1618</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Anand K.</span> <span property="familyName">Narayan</span>, <span property="honorificSuffix">MD, PhD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Elizabeth S.</span> <span property="familyName">Burnside</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-6600-435X" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-6600-435X</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Lonie R.</span> <span property="familyName">Salkowski</span>, <span property="honorificSuffix">MD, PhD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-0384-0297" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-0384-0297</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">Roberta M.</span> <span property="familyName">Strigel</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0009-0009-3321-5984" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0009-0009-3321-5984</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con10"><span property="givenName">Mai A.</span> <span property="familyName">Elezaby</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-8865-6375" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-8865-6375</a> <a href="/cdn-cgi/l/email-protection#6d00080108170c0f142d181a05080c01190543021f0a" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="f69b939a938c97948fb683819e93979a829ed8998491">[email&#160;protected]</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">46</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">1</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.250117" property="sameAs">https://doi.org/10.1148/rg.250117</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
