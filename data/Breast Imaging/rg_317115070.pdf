0" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.317115070" /><meta name="dc.Language" content="en" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2011" />
        
        

        
