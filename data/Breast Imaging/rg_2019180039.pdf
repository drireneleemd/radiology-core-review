<div class="modal fade" role="dialog" tabindex="-1" id="modal--requestUsername">
    <div class="modal-dialog modal-fullscreen-sm-down" role="document">
        <div class="modal-content content">
            <div class="modal-header">
                <h2 class="modal-title h5">Request Username</h2>
                <button type="button" data-dismiss="modal" aria-label="close" class="close">
                    <span aria-hidden="true">x</span>
                    <span class="sr-only">Close</span>
                </button>
            </div>
            <div class="modal-body">
                <form action="/action/requestUsername" class="raa-form" method="post"><input type="hidden" name="requestUsername" value="requestUsername" />
                    <p>Can't sign in? Forgot your username? <br />
                        Enter your email address below and we will send you your username</p>
                    <div class="alert alert-danger d-none"></div>

                    <div class="form-row">
                        <div class="col">
                            <div class="form-group">
                                <label for="6f290ab1-b423-4811-ab9d-690639447459.email">Email</label>
                                <input id="6f290ab1-b423-4811-ab9d-690639447459.email" class="form-control" type="text" name="email" value="" size="15" />
                            </div>
                        </div>
                    </div>
                    
                        <div class="form-row">
                            <div class="col">
                                <div class="form-group">
                                    <div class="username-recaptcha-ajax"></div>
                                </div>
                            </div>
                        </div>
                    

                    <div class="form-row">
                        <div class="col text-right">
                            <button type="submit" data-dismiss="modal" class="btn btn-submit">
                                <span>Submit</span>
                                <span aria-hidden="true" class="icon-arrow-right ml-3"></span>
                            </button>
                        </div>
                    </div></form>

                <div class="alert alert-success d-none">
                    <p>If the address matches an existing account you will receive an email with instructions to retrieve your username</p>
                </div>

            </div>
        </div>
    </div>
</div>




        
        





