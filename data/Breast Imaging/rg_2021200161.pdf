        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Breast Imaging</span></div><div class="meta-panel__label"><span>Radiology-Pathology Collection</span></div><div class="meta-panel__onlineDate">May 14 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Palpable Lumps after Mastectomy: Radiologic-Pathologic Review of Benign and Malignant Masses</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Rend</span> <span property="familyName">Al-Khalili</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-4673-5219" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-4673-5219</a> <a href="/cdn-cgi/l/email-protection#1e6c7b707a307f723375767f727772775e796b707b6a30797b716c797b6a716970307b7a6b" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="493b2c272d6728256422212825202520092e3c272c3d672e2c263b2e2c3d263e27672c2d3c">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Ali</span> <span property="familyName">Alzeer</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Giang-Kimthi</span> <span property="familyName">Nguyen</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Erin P.</span> <span property="familyName">Crane</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Judy H.</span> <span property="familyName">Song</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Janice L.</span> <span property="familyName">Jeon</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Michael</span> <span property="familyName">Nellamattathil</span>, <span property="honorificSuffix">DO</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-3579-2311" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-3579-2311</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Erini V.</span> <span property="familyName">Makariou</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">Victoria L.</span> <span property="familyName">Mango</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-1844-7965" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-1844-7965</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" ty