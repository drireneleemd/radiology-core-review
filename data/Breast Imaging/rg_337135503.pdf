        <div class="content journal-branding">



        
        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Breast Imaging</span></div><div class="meta-panel__onlineDate">Nov 1 2013</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">What Radiologists Need to Know about Diagnosis and Treatment of Inflammatory Breast Cancer: A Multidisciplinary Approach</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Eren D.</span> <span property="familyName">Yeh</span>, <span property="honorificSuffix">MD</span></a> <a href="/cdn-cgi/l/email-protection#e4819d818ca4948596908a819697ca8b9683" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="47223e222f07372635332922353469283520">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Heather A.</span> <span property="familyName">Jacene</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Jennifer R.</span> <span property="familyName">Bellon</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Faina</span> <span property="familyName">Nakhlis</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Robyn L.</span> <span property="familyName">Birdwell</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Dianne</span> <span property="familyName">Georgian-Smith</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Catherine S.</span> <span property="familyName">Giess</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Judi</span> <span property="familyName">Hirshfield-Bartek</span>, <span property="honorificSuffix">RN</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">Beth</span> <span property="familyName">Overmoyer</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con10"><span property="givenName">Annick D.</span> <span property="familyName">Van den Abbeele</span>, <span property="honorificSuffix">MD</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">33</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">7</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.337135503" property="sameAs">https://doi.org/10.1148/rg.337135503</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
