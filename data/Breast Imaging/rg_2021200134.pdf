        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Breast Imaging</span></div><div class="meta-panel__onlineDate">May 3 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Breast MRI for Evaluation of Response to Neoadjuvant Therapy</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Beatriu</span> <span property="familyName">Reig</span>, <span property="honorificSuffix">MD, MPH</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-6577-8601" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-6577-8601</a> <a href="/cdn-cgi/l/email-protection#4e2c2b2f3a3c273b603c2b27290e20373b222f202921202b60213c29" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="fa989f9b8e88938fd4889f939dba94838f969b949d95949fd495889d">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Alana A.</span> <span property="familyName">Lewin</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-7990-4701" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-7990-4701</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Linda</span> <span property="familyName">Du</span>, <span property="honorificSuffix">DO, MPH</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Laura</span> <span property="familyName">Heacock</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-0900-0459" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-0900-0459</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Hildegard K.</span> <span property="familyName">Toth</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Samantha L.</span> <span property="familyName">Heller</span>, <span property="honorificSuffix">PhD, MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-5995-2642" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-5995-2642</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Yiming</span> <span property="familyName">Gao</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-0238-7398" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-0238-7398</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Linda</span> <span property="familyName">Moy</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-9564-9360" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-9564-9360</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">41</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">3</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2021200134" property="sameAs">https://doi.org/10.1148/rg.2021200134</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
