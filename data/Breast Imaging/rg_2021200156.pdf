        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Breast Imaging</span></div><div class="meta-panel__onlineDate">Jul 1 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Image-guided Microinvasive Percutaneous Treatment of Breast Lesions: Where Do We Stand?</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Shima</span> <span property="familyName">Roknsharifi</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-6456-1753" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-6456-1753</a> <a href="/cdn-cgi/l/email-protection#63310c080d100b02110a050a4d100b23040e020a0f4d000c0e" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="cb99a4a0a5b8a3aab9a2ada2e5b8a38baca6aaa2a7e5a8a4a6">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Kapil</span> <span property="familyName">Wattamwar</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-4003-4937" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-4003-4937</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Michael D. C.</span> <span property="familyName">Fishman</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-9995-2738" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-9995-2738</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Robert C.</span> <span property="familyName">Ward</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Kelly</span> <span property="familyName">Ford</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-3093-910X" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-3093-910X</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Salomao</span> <span property="familyName">Faintuch</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Surekha</span> <span property="familyName">Joshi</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Vandana</span> <span property="familyName">Dialani</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-5728-8103" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-5728-8103</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">41</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">4</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2021200156" property="sameAs">https://doi.org/10.1148/rg.2021200156</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
