        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Interpreting One-View Mammographic Findings: Minimizing Callbacks While Maximizing Cancer Detection" /><meta name="dc.Creator" content="Catherine S.  Giess" /><meta name="dc.Creator" content="Elisabeth P.  Frost" /><meta name="dc.Creator" content="Robyn L.  Birdwell" /><meta name="dc.Description" content="Understanding the causes of spurious one-view mammographic findings and the reasons why a breast cancer may manifest as a one-view finding can assist radiologists in improving their interpretive ac..." /><meta name="Description" content="Understanding the causes of spurious one-view mammographic findings and the reasons why a breast cancer may manifest as a one-view finding can assist radiologists in improving their interpretive ac..." /><meta name="dc.Description" content="Overlap of breast tissue is a frequent consequence of the necessary positioning and compression of the three-dimensional breast to obtain two-dimensional mammograms. The mammary glands contain fewe..." /><meta name="Description" content="Overlap of breast tissue is a frequent consequence of the necessary positioning and compression of the three-dimensional breast to obtain two-dimensional mammograms. The mammary glands contain fewe..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2014-07-14" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="manuscript" content="130066" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.344130066" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.344130066" /><meta name="dc.Language" content="EN" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="2014 by the Radiological Society of North America, Inc." />
        
        

        
