        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Breast Imaging</span></div><div class="meta-panel__onlineDate">Feb 5 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Digital Breast Tomosynthesis: Update on Technology, Evidence, and Clinical Practice</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Yiming</span> <span property="familyName">Gao</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-2311-7442" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-2311-7442</a> <a href="/cdn-cgi/l/email-protection#88f1e1e5e1e6efa6efe9e7c8e6f1fde4e9e6efe7e6eda6e7faef" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="7009191d191e175e17111f301e09051c111e171f1e155e1f0217">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Linda</span> <span property="familyName">Moy</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-9564-9360" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-9564-9360</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Samantha L.</span> <span property="familyName">Heller</span>, <span property="honorificSuffix">PhD, MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-7167-2950" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-7167-2950</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">41</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">2</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2021200101" property="sameAs">https://doi.org/10.1148/rg.2021200101</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
