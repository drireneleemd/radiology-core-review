        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Breast Imaging</span></div><div class="meta-panel__onlineDate">Nov 7 2019</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Contrast-enhanced Mammography: Current Applications and Future Directions</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Kimeya F.</span> <span property="familyName">Ghaderi</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-3193-5688" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-3193-5688</a> <a href="/cdn-cgi/l/email-protection#7c171b141d18190e153c1e1518111f52141d0e0a1d0e1852191809" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="5338343b323736213a13313a373e307d3b3221253221377d363726">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Jordana</span> <span property="familyName">Phillips</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Hannah</span> <span property="familyName">Perry</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Parisa</span> <span property="familyName">Lotfi</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Tejas S.</span> <span property="familyName">Mehta</span>, <span property="honorificSuffix">MD, MPH</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-9464-8104" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-9464-8104</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">39</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">7</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2019190079" property="sameAs">https://doi.org/10.1148/rg.2019190079</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
