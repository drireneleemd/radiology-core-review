        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Breast Imaging</span></div><div class="meta-panel__onlineDate">Apr 6 2018</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Automated Three-dimensional Breast US for Screening: Technique, Artifacts, and Lesion Characterization</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Jan C. M.</span> <span property="familyName">van Zelst</span>, <span property="honorificSuffix">MD, MSc</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-0810-8246" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-0810-8246</a> <a href="/cdn-cgi/l/email-protection#305a515e1e46515e4a555c434470425154525f4554455d531e5e5c" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="afc5cec181d9cec1d5cac3dcdbefddcecbcdc0dacbdac2cc81c1c3">[email&#160;protected]</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Ritse M.</span> <span property="familyName">Mann</span>, <span property="honorificSuffix">MD, PhD</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">38</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">3</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2018170162" property="sameAs">https://doi.org/10.1148/rg.2018170162</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
