        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Breast Imaging</span></div><div class="meta-panel__onlineDate">Jun 12 2020</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Missed Breast Cancer: Effects of Subconscious Bias and Lesion Characteristics</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Leslie R.</span> <span property="familyName">Lamb</span>, <span property="honorificSuffix">MD, MSc</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-4024-7302" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-4024-7302</a> <a href="/cdn-cgi/l/email-protection#4e223c222f232c0e23292660262f3c382f3c2a602b2a3b" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="016d736d606c63416c66692f696073776073652f646574">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Marina</span> <span property="familyName">Mohallem Fonseca</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Raman</span> <span property="familyName">Verma</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-1800-7115" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-1800-7115</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Jean M.</span> <span property="familyName">Seely</span>, <span property="honorificSuffix">MDCM</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">40</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">4</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2020190090" property="sameAs">https://doi.org/10.1148/rg.2020190090</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
