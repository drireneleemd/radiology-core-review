        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Breast Imaging</span></div><div class="meta-panel__label"><span>Radiology-Pathology Collection</span></div><div class="meta-panel__onlineDate">Jul 17 2025</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Papillary Neoplasms of the Breast: WHO Classification, Multimodality Imaging, and Radiologic-Pathologic Correlation</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Janice N.</span> <span property="familyName">Thai</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-6828-4036" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-6828-4036</a> <a href="/cdn-cgi/l/email-protection#9af0eef2fbf3afdaf7fdf2b4f2fbe8ecfbe8feb4fffeef" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="92f8e6faf3fba7d2fff5fabcfaf3e0e4f3e0f6bcf7f6e7">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Jasmine</span> <span property="familyName">Vickery</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0009-0008-6946-8847" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0009-0008-6946-8847</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Baris</span> <span property="familyName">Boyraz</span>, <span property="honorificSuffix">MD, PhD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Claire</span> <span property="familyName">Crowley</span>, <span property="honorificSuffix">MB, BCh, BAO</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-8416-1861" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-8416-1861</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Mansi A.</span> <span property="familyName">Saksena</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Xuefei</span> <span property="familyName">Hong</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Vladislav V.</span> <span property="familyName">Makarenko</span>, <span property="honorificSuffix">MD, PhD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Mark A.</span> <span property="familyName">Tulecke</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">Patrick J.</span> <span property="familyName">McIntire</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con10"><span property="givenName">Veerle</span> <span property="familyName">Bossuyt</span>, <span property="honorificSuffix">MD</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">45</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">8</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.240091" property="sameAs">https://doi.org/10.1148/rg.240091</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__cme info-panel__item"><a href="/servlet/linkout?doi=10.1148%2Frg.240091&suffix=s0&url=https://api3.rsna.org/lms/v1/sendToJournalCMETest?doi=10.1148%2Frg.240091" class="btn btn--cme" data-toggle="tooltip"><i aria-hidden="true" class="icon-checkmark2"></i><span class="link-text">CME</span></a></div><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
