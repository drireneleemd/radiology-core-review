        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Breast Imaging</span></div><div class="meta-panel__onlineDate">May 29 2020</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Genetic Testing and Screening Recommendations for Patients with Hereditary Breast Cancer</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Puja P.</span> <span property="familyName">Bharucha</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Kellie E.</span> <span property="familyName">Chiu</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-5891-4209" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-5891-4209</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Fabienne M.</span> <span property="familyName">François</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Jessica L.</span> <span property="familyName">Scott</span>, <span property="honorificSuffix">MGC, CGC</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-6007-558X" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-6007-558X</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Gauri R.</span> <span property="familyName">Khorjekar</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Nikki P.</span> <span property="familyName">Tirada</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-5997-7292" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-5997-7292</a> <a href="/cdn-cgi/l/email-protection#e6968b83928383958792a6818b878f8ac885898b" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="d4a4b9b1a0b1b1a7b5a094b3b9b5bdb8fab7bbb9">[email&#160;protected]</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">40</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">4</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2020190181" property="sameAs">https://doi.org/10.1148/rg.2020190181</a></div></div><div class="core-relations my-3"><div class="relation mb-3"><div class="relation--head"><i class="icon-info"></i><a href="/doi/10.1148/rg.2020190218">See related article</a></div></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
