        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Breast Imaging</span></div><div class="meta-panel__onlineDate">Apr 17 2020</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Breast Implant–associated Anaplastic Large Cell Lymphoma: Review and Multiparametric Imaging Paradigms</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Bhupinder</span> <span property="familyName">Sharma</span>, <span property="honorificSuffix">BSc (Hons), BM, FRCR</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-1125-4076" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-1125-4076</a> <a href="/cdn-cgi/l/email-protection#b7f5dfc2c7ded9d3d2c599c4dfd6c5dad6f7c5dadf99d9dfc499c2dc" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="1052786560797e7475623e637871627d7150627d783e7e78633e657b">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Amanda</span> <span property="familyName">Jurgensen-Rauch</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-6805-2892" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-6805-2892</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Erika</span> <span property="familyName">Pace</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Ayoma D.</span> <span property="familyName">Attygalle</span>, <span property="honorificSuffix">PhD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-5034-8150" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-5034-8150</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Rajaei</span> <span property="familyName">Sharma</span>, <span property="honorificSuffix">BSc (Hons), PGCert</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-9909-9404" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-9909-9404</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Côme</span> <span property="familyName">Bommier</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-5695-911X" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-5695-911X</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Andrew C.</span> <span property="familyName">Wotherspoon</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Sarkhara</span> <span property="familyName">Sharma</span>, <span property="honorificSuffix">BSc (Hons)</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con9"><span property="givenName">Sunil</span> <span property="familyName">Iyengar</span>, <span property="honorificSuffix">PhD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con10"><span property="givenName">Dima</span> <span property="familyName">El-Sharkawi</span>, <span property="honorificSuffix">PhD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-2752-5814" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-2752-5814</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">40</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">3</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2020190198" property="sameAs">https://doi.org/10.1148/rg.2020190198</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
