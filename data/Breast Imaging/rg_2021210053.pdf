        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Breast Imaging</span></div><div class="meta-panel__onlineDate">Sep 1 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Imaging Updates to Breast Cancer Lymph Node Management</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Hannah L.</span> <span property="familyName">Chung</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-0135-8402" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-0135-8402</a> <a href="/cdn-cgi/l/email-protection#e4aca8a78c918a83a48980858a808196978b8aca8b9683" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="83cbcfc0ebf6ede4c3eee7e2ede7e6f1f0ecedadecf1e4">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Huong T.</span> <span property="familyName">Le-Petross</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-0356-498X" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-0356-498X</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Jessica W. T.</span> <span property="familyName">Leung</span>, <span property="honorificSuffix">MD</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">41</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">5</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2021210053" property="sameAs">https://doi.org/10.1148/rg.2021210053</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
