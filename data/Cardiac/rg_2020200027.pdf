        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Cardiac Imaging</span></div><div class="meta-panel__onlineDate">Oct 1 2020</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">CT for Pre- and Postprocedural Evaluation of Transcatheter Mitral Valve Replacement</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Praveen</span> <span property="familyName">Ranganath</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-9360-1806" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-9360-1806</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Alastair</span> <span property="familyName">Moore</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Mayra</span> <span property="familyName">Guerrero</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Jeremy</span> <span property="familyName">Collins</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://o