<div tabindex="-1" id="modal--verifyPhone"
     aria-labelledby="modalverifyPhoneLabel"
     class="modal fade" aria-modal="true" role="dialog">
    <div role="document" class="modal-dialog modal-fullscreen-sm-down">
        <div class="modal-content">
            <div class="modal-header">
