        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Role of Multidetector CT in Assessment of Repaired Tetralogy of Fallot" /><meta name="dc.Creator" content="Sameer  Ahmed" /><meta name="dc.Creator" content="Pamela Tecce  Johnson" /><meta name="dc.Creator" content="Elliot K.  Fishman" /><meta name="dc.Creator" content="Stefan Loy  Zimmerman" /><meta name="dc.Description" content="The pathophysiology, surgical treatment, and postrepair complications of tetralogy of Fallot are discussed, with emphasis on the growing role of multidetector CT in the care of affected patients." /><meta name="Description" content="The pathophysiology, surgical treatment, and postrepair complications of tetralogy of Fallot are discussed, with emphasis on the growing role of multidetector CT in the care of affected patients." /><meta name="dc.Description" content="The population of adults with repaired tetralogy of Fallot (TOF) is growing, thanks to improvements in the surgical and medical management of this condition. Accordingly, late postrepair complicati..." /><meta name="Description" content="The population of adults with repaired tetralogy of Fallot (TOF) is growing, thanks to improvements in the surgical and medical management of this condition. Accordingly, late postrepair complicati..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2013-06-29" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="publisher-id" content="125114" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.334125114" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.334125114" /><meta name="dc.Language" content="EN" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2013" />
        
        

        
