        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Chest Imaging</span></div><div class="meta-panel__onlineDate">Mar 1 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Chest CT Angiography for Acute Aortic Pathologic Conditions: Pearls and Pitfalls</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Jane P.</span> <span property="familyName">Ko</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-9355-7200" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-9355-7200</a> <a href="/cdn-cgi/l/email-protection#8bc1eae5eea5e0e4cbe5f2fee7eae5ece4e5eea5e4f9ec" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="c48ea5aaa1eaafab84aabdb1a8a5aaa3abaaa1eaabb6a3">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Jonathan M.</span> <span property="familyName">Goldstein</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-5568-5532" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-5568-5532</a></span>, <span property="author" typeo