        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="The Fontan Procedure: Anatomy, Complications, and Manifestations of Failure" /><meta name="dc.Creator" content="Tyler B.  Fredenburg" /><meta name="dc.Creator" content="Tiffanie R.  Johnson" /><meta name="dc.Creator" content="Mervyn D.  Cohen" /><meta name="dc.Description" content="Normal appearances of Fontan circulation, as established with older and with more recent techniques, are described, as well as complications and signs of failure." /><meta name="Description" content="Normal appearances of Fontan circulation, as established with older and with more recent techniques, are described, as well as complications and signs of failure." /><meta name="dc.Description" content="The Fontan procedure refers to any operation that results in the flow of systemic venous blood to the lungs without passing through a ventricle. It is performed to treat several complex congenital ..." /><meta name="Description" content="The Fontan procedure refers to any operation that results in the flow of systemic venous blood to the lungs without passing through a ventricle. It is performed to treat several complex congenital ..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2011-03-07" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="publisher-id" content="105027" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.312105027" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.312105027" /><meta name="dc.Language" content="en" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2011" />
        
        

        
