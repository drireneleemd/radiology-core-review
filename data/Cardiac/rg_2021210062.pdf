ed.ncbi.nlm.nih.gov/25984453/">PubMed</a></div><div class="core-xlink-google-scholar"><a href="https://scholar.google.com/scholar_lookup?title=Spontaneous+coronary+artery+dissection%3A+novel+insights+on+diagnosis+and+management&amp;author=F+Alfonso&amp;author=T+Bastante&amp;author=J+Cuesta&amp;author=D+Rodr%C3%ADguez&amp;author=A+Benedicto&amp;author=F+Rivero&amp;publication_year=2015&amp;journal=Cardiovasc+Diagn+Ther&amp;pages=133-140&amp;pmid=25984453">Google Scholar</a></div></div></div></div></div><div role="listitem" data-has="label"><div class="label">9.</div><div id="r9" class="citations"><div class="citation"><div class="citation-content">Tweet MS, Gulati R, Williamson EE, Vrtiska TJ, Hayes SN. Multimodality imaging for spontaneous coronary artery dissection in women. <em>JACC Cardiovasc Imaging</em> 2016;9(4):436–450.</div><div class="external-links"><div class="core-xlink-crossref"><a href="https://doi.org/10.1016/j.jcmg.2016.01.009">Crossref</a></div><div class="core-xlink-pubmed"><a href="https://pubmed.ncbi.nlm.nih.gov/27056163/">PubMed</a></div><div class="core-xlink-google-scholar"><a href="https://scholar.google.com/scholar_lookup?title=Multimodality+imaging+for+spontaneous+coronary+artery+dissection+in+women&amp;author=MS+Tweet&amp;author=R+Gulati&amp;author=EE+Williamson&amp;author=TJ+Vrtiska&amp;author=SN+Hayes&amp;publication_year=2016&amp;journal=JACC+Cardiovasc+Imaging&amp;pages=436-450&amp;doi=10.1016%2Fj.jcmg.2016.01.009&amp;pmid=27056163">Google Scholar</a></div></div></div></div></div><div role="listitem" data-has="label"><div class="label">10.</div><div id="r10" class="citations"><div class="citation"><div class="citation-content">Garcia-Guimarães M, Bastante T, Antuña P, et al. Spontaneous coronary artery dissection: mechanisms, diagnosis and management. <em>Eur Cardiol</em> 2020;15:1–8.</div><div class="external-links"><div class="core-xlink-crossref"><a href="https://doi.org/10.15420/ecr.2019.01">Crossref</a></div><div class="core-xlink