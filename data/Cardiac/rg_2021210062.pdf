        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Cardiac Imaging</span></div><div class="meta-panel__onlineDate">Oct 15 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Spontaneous Coronary Artery Dissection: An Underdiagnosed Clinical Entity—A Primer for Cardiac Imagers</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Anum</span> <span property="familyName">Aslam</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-6243-5286" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-6243-5286</a> <a href="/cdn-cgi/l/email-protection#7f1e1e110a123f121a1b510a12161c17511a1b0a" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="e180808f948ca18c8485cf948c888289cf848594">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Jadranka</span> <span property="familyName">Stojanovska</span>, <span property="honorificSuffix">MD, MS</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-2742-6274" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-2742-6274</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Usman S.</span> <span property="familyName">Khokhar</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Richard L.</span> <span property="familyName">Weinberg</span>, <span property="honorificSuffix">MD, PhD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Santhi K.</span> <span property="familyName">Ganesh</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-3663-5249" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-3663-5249</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Troy</span> <span property="familyName">Labounty</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Nadia R.</span> <span property="familyName">Sutton</span>, <span property="honorificSuffix">MD, MPH</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-0968-3085" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-0968-3085</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Smita</span> <span property="familyName">Patel</span>, <span property="honorificSuffix">MD</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" t