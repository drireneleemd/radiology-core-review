" /><meta name="dc.Identifier" scheme="manuscript" content="125076" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.346125076" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.346125076" /><meta name="dc.Language" content="EN" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="2014 by the Radiological Society of North America, Inc." />
        
        

        
