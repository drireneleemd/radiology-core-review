        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="From the Radiologic Pathology Archives: Cardiac Lymphoma: Radiologic-Pathologic Correlation" /><meta name="dc.Creator" content="Jean  Jeudy" /><meta name="dc.Creator" content="Jacobo  Kirsch" /><meta name="dc.Creator" content="Fabio  Tavora" /><meta name="dc.Creator" content="Allen P.  Burke" /><meta name="dc.Creator" content="Teri J.  Franks" /><meta name="dc.Creator" content="Tan-Lucien  Mohammed" /><meta name="dc.Creator" content="Aletta Ann  Frazier" /><meta name="dc.Creator" content="Jeffrey R.  Galvin" /><meta name="dc.Description" content="Clinical manifestations, imaging findings, pathologic features, differential diagnosis, and treatment and prognosis of cardiac lymphoma are reviewed, with emphasis on radiologic-pathologic correlation." /><meta name="Description" content="Clinical manifestations, imaging findings, pathologic features, differential diagnosis, and treatment and prognosis of cardiac lymphoma are reviewed, with emphasis on radiologic-pathologic correlation." /><meta name="dc.Description" content="Lymphoma of the heart and pericardium is usually present as one aspect of disseminated disease and rarely occurs as a primary malignancy. It accounts for 1.3% of primary cardiac tumors and 0.5% of ..." /><meta name="Description" content="Lymphoma of the heart and pericardium is usually present as one aspect of disseminated disease and rarely occurs as a primary malignancy. It accounts for 1.3% of primary cardiac tumors and 0.5% of ..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2012-08-31" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="publisher-id" content="115126" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.325115126" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.325115126" /><meta name="dc.Language" content="en" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2012" />
        
        

        
