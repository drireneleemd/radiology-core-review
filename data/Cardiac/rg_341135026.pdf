8389/">PubMed</a></div><div class="core-xlink-google-scholar"><a href="https://scholar.google.com/scholar_lookup?title=Cardiac+neural+crest+is+necessary+for+normal+addition+of+the+myocardium+to+the+arterial+pole+from+the+secondary+heart+field&amp;author=KL+Waldo&amp;author=MR+Hutson&amp;author=HA+Stadt&amp;author=M+Zdanowicz&amp;author=J+Zdanowicz&amp;author=ML+Kirby&amp;publication_year=2005&amp;journal=Dev+Biol&amp;pages=66-77&amp;doi=10.1016%2Fj.ydbio.2005.02.011&amp;pmid=15848389">Google Scholar</a></div></div></div></div></div><div role="listitem" data-has="label"><div class="label">5.</div><div id="bib5" class="citations"><div class="citation"><div class="citation-content">Restivo A, Piacentini G, Placidi S, Saffirio C, Marino B. Cardiac outflow tract: a review of some embryogenetic aspects of the conotruncal region of the heart. <em>Anat Rec A Discov Mol Cell Evol Biol</em> 2006;288(9):936–943.</div><div class="external-links"><div class="core-xlink-crossref"><a href="https://doi.org/10.1002/ar.a.20367">Crossref</a></div><div class="core-xlink-pubmed"><a href="https://pubmed.ncbi.nlm.nih.gov/16892424/">PubMed</a></div><div class="core-xlink-google-scholar"><a href="https://scholar.google.com/scholar_lookup?title=Cardiac+outflow+tract%3A+a+review+of+some+embryogenetic+aspects+of+the+conotruncal+region+of+the+heart&amp;author=A+Restivo&amp;author=G+Piacentini&amp;author=S+Placidi&amp;author=C+Saffirio&amp;author=B+Marino&amp;publication_year=2006&amp;journal=Anat+Rec+A+Discov+Mol+Cell+Evol+Biol&amp;pages=936-943&amp;doi=10.1002%2Far.a.20367&amp;pmid=16892424">Google Scholar</a></div></div></div></div></div><div role="listitem" data-has="label"><div class="label">6.</div><div id="bib6" class="citations"><div class="citation"><div class="citation-content">Hokken RB, Bartelings MM, Bogers AJJC, Gittenberger–de Groot AC. Morphology of the pulmonary and aortic roots with regard to the pulmonary autograft procedure. <em>J Thorac Cardiovasc Surg</em> 1997; 113:453–461.</div><div class="external-links"><div class="core-xlink-crossref"><a href="https://doi.org/10.1016/S0022-5223(97)70357-X">Crossref</a></div><div class="core-xlink-pubmed"><a href="https://pubmed.ncbi.nlm.nih.gov/9081089/">PubMed</a></div><div class="core-xlink-google-scholar"><a href="https://scholar.google.com/scholar_lookup?title=Morphology+of+the+pulmonary+and+aortic+roots+with+regard+to+the+pulmonary+autograft+procedure&amp;author=RB+Hokken&amp;author=MM+Bartelings&amp;author=AJJC+Bogers&amp;author=AC+Gittenberger%E2%80%93de+Groot&amp;publication_year=1997&amp;journal=J+Thorac+Cardiovasc+Surg&amp;pages=453-461&amp;doi=10.1016%2FS0022-5223%2897%2970357-X&amp;pmid=9081089">Google Scholar</a></div></div></div></div></div><div role="listitem" data-has="label"><div class="label">7.</div><div id="bib7" class="citations"><div class="citation"><div class="citation-content">Stamm C, Anderson RH, Ho SY. Clinical anatomy of the normal pulmonary root compared with that in isolated pulmonary valvular stenosis. <em>J Am Coll Cardiol</em> 1998;31(6):1420–1425.</div><div class="external-links"><div class="core-xlink-crossref"><a href="https://doi.org/10.1016/S0735-1097(98)00089-8">Crossref</a></div><div class="core-xlink-pubmed"><a href="https://pubmed.ncbi.nlm.nih.gov/9581744/">PubMed</a></div><div class="core-xlink-google-scholar"><a href="https://scholar.google.com/scholar_lookup?title=Clinical+anatomy+of+the+normal+pulmonary+root+compared+with+that+in+isolated+pulmonary+valvular+stenosis&amp;author=C+Stamm&amp;author=RH+Anderson&amp;author=SY+Ho&amp;publication_year=1998&amp;journal=J+Am+Coll+Cardiol&amp;pages=1420-1425&amp;doi=10.1016%2FS0735-1097%2898%2900089-8&amp;pmid=9581744">Google Scholar</a></div></div></div></div></div><div role="listitem" data-has="label"><div class="label">8.</div><div id="bib8" class="citations"><div class="citation"><div class="citation-content">Anderson RH, Razavi R, Taylor AM. Cardiac anatomy revisited. <em>J Anat</em> 2004;205(3):159–177.<