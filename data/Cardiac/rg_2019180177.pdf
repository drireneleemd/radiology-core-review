        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Cardiac Imaging</span></div><div class="meta-panel__onlineDate">May 31 2019</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Multimodality Imaging of Complications of Cardiac Valve Surgeries</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Prabhakar</span> <span property="familyName">Rajiah</span>, <span property="honorificSuffix">MD, FRCR</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-7538-385X" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-7538-385X</a> <a href="/cdn-cgi/l/email-protection#6b190a0f1b195c582b0c060a020745080406" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="6b190a0f1b195c582b0c060a020745080406">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Alastair</span> <span property="familyName">Moore</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Sachin</span> <span property="familyName">Saboo</span>, <span property="honorificSuffix">MD, FRCR</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-3270-5876" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-3270-5876</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Harold</span> <span property="familyName">Goerne</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Praveen</span> <span property="familyName">Ranganath</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">James</span> <span property="familyName">MacNamara</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Parag</span> <span property="familyName">Joshi</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Suhny</span> <span property="familyName">Abbara</span>, <span property="honorificSuffix">MD</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">39</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">4</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2019180177" property="sameAs">https://doi.org/10.1148/rg.2019180177</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
