        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Cardiovascular MR Imaging of Conotruncal Anomalies1" /><meta name="dc.Creator" content="Luba  Frank" /><meta name="dc.Creator" content="Jonathan R.  Dillman" /><meta name="dc.Creator" content="Victoria  Parish" /><meta name="dc.Creator" content="Gisela C.  Mueller" /><meta name="dc.Creator" content="Ella A.  Kazerooni" /><meta name="dc.Creator" content="Aaron  Bell" /><meta name="dc.Creator" content="Anil K.  Attili" /><meta name="dc.Description" content="The clinical features and MR imaging appearances of major conotruncal anomalies before and after surgery are described and illustrated." /><meta name="Description" content="The clinical features and MR imaging appearances of major conotruncal anomalies before and after surgery are described and illustrated." /><meta name="dc.Description" content="Conotruncal anomalies are congenital heart defects that result from abnormal formation and septation of the outflow tracts of the heart and great vessels. The major conotruncal anomalies include te..." /><meta name="Description" content="Conotruncal anomalies are congenital heart defects that result from abnormal formation and septation of the outflow tracts of the heart and great vessels. The major conotruncal anomalies include te..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2010-07-04" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.304095158" /><meta name="dc.Identifier" scheme="publisher-id" content="095158" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.304095158" /><meta name="dc.Language" content="en" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2010" />
        
        

        
