        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Chest Imaging</span></div><div class="meta-panel__onlineDate">Mar 1 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Aortic Dissection and Other Acute Aortic Syndromes: Diagnostic Imaging Findings from Acute to Chronic Longitudinal Progression</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Horacio</span> <span property="familyName">Murillo</span>, <span property="honorificSuffix">MD, PhD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-9448-205X" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-9448-205X</a> <a href="/cdn-cgi/l/email-protection#365e5b43445f5a5a5976454257585059445218535243" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="fa92978f8893969695ba898e9b949c95889ed49f9e8f">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Lior</span> <span property="familyName">Molvin</span>, <span property="honorificSuffix">MBA</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-9989-3587" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-9989-3587</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Anne S.</span> <span property="familyName">Chin</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Dominik</span> <span property="familyName">Fleischmann</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-0715-0952" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-0715-0952</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">41</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">2</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2021200138" property="sameAs">https://doi.org/10.1148/rg.2021200138</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
