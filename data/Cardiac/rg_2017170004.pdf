        <div class="content journal-branding">



        
        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Cardiac Imaging</span></div><div class="meta-panel__onlineDate">Aug 18 2017</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Fibrous Skeleton of the Heart: Anatomic Overview and Evaluation of Pathologic Conditions with CT and MR Imaging</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Farhood</span> <span property="familyName">Saremi</span>, <span property="honorificSuffix">MD</span></a> <a href="/cdn-cgi/l/email-protection#c3a5b0a2b1a6aeaa83b6b0a0eda6a7b6" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="9ff9ecfeedfaf2f6dfeaecfcb1fafbea">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Damián</span> <span property="familyName">Sánchez-Quintana</span>, <span property="honorificSuffix">MD, PhD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Shumpei</span> <span property="familyName">Mori</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Horia</span> <span property="familyName">Muresian</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Diane E.</span> <span property="familyName">Spicer</span>, <span property="honorificSuffix">BSc, PA(ASCP)</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Cameron</span> <span property="familyName">Hassani</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Robert H.</span> <span property="familyName">Anderson</span>, <span property="honorificSuffix">MD, FRCPath</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">37</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">5</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2017170004" property="sameAs">https://doi.org/10.1148/rg.2017170004</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
        <div class="article-tools"><a href="/personalize/addFavoritePublication?doi=10.1148%2Frg.2017170004" target="_blank" class="article-tools__favorite btn btn--slim btn--inverse" data-toggle="tooltip" data-trigger="hover" data-original-title="Add to favorites"><i aria-hidden="true" class="icon-add-favorite"></i><span class="sr-only">Add to favorites</span></a><a href="/action/addCitationAlert?doi=10.1148%2Frg.2017170004" target="_blank" class="article-tools__citation btn btn--slim btn--inverse" data-toggle="tooltip" data-trigger="hover" data-original-title="Track Citations"><i aria-hidden="true" class="icon-alert-bell"></i><span class="sr-only">Track Citations</span></a></div>
</div><div class="info-panel__citations info-panel__item"><a href="#tab-citations" class="btn btn--inverse btn--slim" data-toggle="tooltip" data-original-title="View Citations" aria-label="View Citations"><i aria-hidden="true" class="icon-format_quote"></i></a></div><div class="info-panel__formats info-panel__item"><a href="#core-collateral-purchase-access" class="btn btn--access" data-toggle="tooltip" data-original-title="Go to purchase options" aria-label="Go to purchase options"><i aria-hidden="true" class="icon-lock-open"></i><span class="link-text">Get Access</span></a></div></div></div></div></header><div data-core-nav="header" data-extent="frontmatter"><div class="core-nav-wrapper core-container" aria-label="Article navigation"><div><button aria-controls="article_sections_menu" aria-expanded="false" aria-label="Toggle section navigation menu"><i class="icon-list" aria-hidden="true"></i><span>Contents</span></button><nav id="article_sections_menu" aria-label="Contents" data-core-nav="article"><ul><li><a href="#abstract">Abstract</a></li><li><a href="#core-sec-figures">Figures</a></li><li><a href="#bibliography">References</a></li></ul></nav></div><nav id="article_collateral_menu"><ul class="collateral-pill" data-core-nav="collateral"><li><a href="#core-collateral-info" aria-controls="core-collateral-info" aria-disabled="true" disabled="true" data-toggle="tooltip" data-placement="left" data-original-title="Information & Authors" title="Information & Authors" aria-expanded="false"><i aria-hidden="true" class="icon-info"></i><span class="sr-only">Information & Authors</span></a></li><li><a href="#core-collateral-metrics" aria-controls="core-collateral-metrics" aria-disabled="true" disabled="true" data-toggle="tooltip" data-placement="left" data-original-title="Metrics & Citations" title="Metrics & Citations" aria-expanded="false"><i aria-hidden="true" class="icon-metrics"></i><span class="sr-only">Metrics & Citations</span></a></li><li><a href="#core-collateral-purchase-access" aria-controls="core-collateral-purchase-access" aria-disabled="true" disabled="true" data-toggle="tooltip" data-placement="left" data-original-title="Get Access" title="Get Access" aria-expanded="false"><i aria-hidden="true" class="icon-lock-open"></i><span class="sr-only">Get Access</span></a></li><li><a href="#core-collateral-references" aria-controls="core-collateral-references" aria-disabled="true" disabled="true" data-toggle="tooltip" data-placement="left" data-original-title="References" title="References" aria-expanded="false"><i aria-hidden="true" class="icon-references"></i><span class="sr-only">References</span></a></li><li><a href="#core-collateral-figures" aria-controls="core-collateral-figures" aria-disabled="true" disabled="true" data-toggle="tooltip" data-placement="left" data-original-title="Figures" title="Figures" aria-expanded="false"><i aria-hidden="true" class="icon-photo"></i><span class="sr-only">Figures</span></a></li><li><a href="#core-collateral-tables" aria-controls="core-collateral-tables" aria-disabled="true" disabled="true" data-toggle="tooltip" data-placement="left" data-original-title="Tables" title="Tables" aria-expanded="false"><i aria-hidden="true" class="icon-table"></i><span class="sr-only">Tables</span></a></li><li><a href="#core-collateral-media" aria-controls="core-collateral-media" aria-disabled="true" disabled="true" data-toggle="tooltip" data-placement="left" data-original-title="Media" title="Media" aria-expanded="false"><i aria-hidden="true" class="icon-play-circle-filled"></i><span class="sr-only">Media</span></a></li><li><a href="#core-collateral-share" aria-controls="core-collateral-share" aria-disabled="true" disabled="true" data-toggle="tooltip" data-placement="left" data-original-title="Share" title="Share" aria-expanded="false"><i aria-hidden="true" class="icon-share"></i><span class="sr-only">Share</span></a></li></ul></nav></div></div><div data-core-wrapper="content"><div id="abstracts" data-extent="frontmatter"><div class="core-container"><section id="abstract" property="abstract" typeof="Text" role="doc-abstract"><h2 property="name">Abstract</h2><div role="paragraph">The fibrous skeleton is concentrated at the base of the ventricular mass. It provides electrical insulation at the atrioventricular level and fibrous continuity for the leaflets of the mitral, aortic, and tricuspid valves. Its components include the fibrous trigones, the fibrous area of aortic-mitral continuity, the subvalvar collar of the mitral valve, the membranous septum, the interleaflet triangles, the tendon of Todaro, and likely the conus ligament. The majority of the mitral annulus is fibrous, but the only true fibrous part of the tricuspid annulus is where the valvar leaflets are attached to the central fibrous body. At the aortic annulus, the fibrous elements support only the noncoronary aortic sinus and parts of the right and left coronary sinuses. The ring-shaped annulus of the arterioventricular valves as localized with imaging techniques (imaging annulus) differs from the crown-shaped hemodynamic annulus of the arterial valves. The imaging annulus corresponds to the plane passing through the nadirs of the hinge-lines of the leaflets. The hinges of the pulmonary valve are not part of the fibrous skeleton. Computed tomography (CT) and magnetic resonance (MR) imaging are excellent modalities for evaluation of the anatomy, physiologic variations, and pathologic conditions of the fibrous skeleton. The submillimeter isotropic three-dimensional datasets obtained with CT and the high contrast resolution of MR imaging are the main advantages of these modalities in assessing anatomy. The function of the valves and associated annuli can best be studied with MR imaging. Pathologic conditions involving the area, including paravalvar leaks, abscesses, perforation, and pseudoaneurysms, usually occur as a complication of infective endocarditis or extensive calcifications after valvar surgery. MR imaging and CT can demonstrate these lesions equally well. CT is the preferred technique for showing the extent of calcifications in the fibrous skeleton. Large calcifications involving the central fibrous body can cause heart block by interfering with the normal function of the His bundle and its branches.</div><div role="paragraph"><sup>©</sup>RSNA, 2017</div></section></div></div><section id="bodymatter" data-extent="bodymatter" property="articleBody" typeof="Text"><div class="core-container"><section aria-labelledby="denial-block-title" class="denial-block "><h2 id="denial-block-title" class="denial-block__title">Get full access to this article</h2><p class="denial-block__text">View all available purchase options and get full access to this article.</p><div class="denial-block__cta"><a href="#core-collateral-purchase-access" class="btn btn--access"><i aria-hidden="true" class="icon-lock-open"></i><span>Get Access</span></a></div><footer class="denial-block__footer"><span>Already a Subscriber? </span><span>Sign in as an </span><a href="/action/showLogin?redirectUri=/doi/10.1148/rg.2017170004">individual</a><span> or via your </span><a href="/action/ssostart?uri=/doi/10.1148/rg.2017170004">institution</a></footer></section></div></section><section id="backmatter" data-extent="backmatter"><div class="core-container"><section id="core-sec-figures" data-type="figures"><h2>Figures</h2><div class="figure-wrap"><figure id="fig1" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig1.jpeg" height="2487" width="3000" aria-labelledby="fig1" loading="lazy" /><figcaption><span class="heading">Figure 1</span>. Diagrams show the fate and transformation of proepicardium-derived cells. During development of the heart tube, two extracardiac sources migrate and deliver cells into and onto the heart tube. Migrating cells originating from the cardiac neural crest (blue ★) contribute to formation of the aortopulmonary septum, the outflow tract endocardial cushions, and the base of the atrial septum. The second group of extracardiac cells (red ★) are derived from the proepicardial organ, a cauliflower-like protrusion at the venous pole of the heart. These epithelial cells migrate to epicardium and following mesenchymal transformation form the subepicardium. The subepicardial mesenchymal cells then migrate further and contribute to development of the myocardial interstitial fibroblasts (extracellular matrix [ECM]), the fibrous annulus of the <abbr title="atrioventricular">AV</abbr> valves, and the coronary arterial smooth muscle cells. The cardiac jelly is also invaded by mesenchymal cells derived from the endocardium to form the subendocardial layer; these cells contribute to development of the endocardial cushions at the future <abbr title="atrioventricular">AV</abbr> junction and in the outflow tract. Valve leaflets will develop from the endocardial cushions.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig1">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig2" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig2.jpeg" height="1761" width="1800" aria-labelledby="fig2" loading="lazy" /><figcaption><span class="heading">Figure 2</span>. Epicardium and structures containing fibrous elements (green areas). The epicardial and subepicardial cells derived from embryonic proepicardium contribute to development of the cardiac interstitial fibroblasts and the annuli of the <abbr title="atrioventricular">AV</abbr> valves. However, the valve leaflets develop from the endocardial cushions. The epicardium is contiguous with the insulating fibrous tissue of the fibrous annuli, which help separate the atrial myocardium from the ventricular myocardium. The majority of the fibrous tissue is concentrated at the <abbr title="atrioventricular">AV</abbr> septal junction, where parts of the leaflets of the mitral valve <i>(MV)</i>, aortic valve, and tricuspid valve <i>(TV)</i> meet at the central fibrous body <i>(CFB)</i>, with the membranous septum and the tendon of Todaro being part of it. <i>AVN</i> = <abbr title="atrioventricular">AV</abbr> node, <i>IVC</i> = inferior vena cava, <i>SAN</i> = sinuatrial node.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig2">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig3a" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig3a.jpeg" height="1332" width="1610" aria-labelledby="fig3a" loading="lazy" /><figcaption><span class="heading">Figure 3a</span>. Endomysial collagen network surrounding myocytes. Aside from the gross fibrous skeleton, the cardiac myocytes are surrounded by a cardiac collagen network known as the cardiac extracellular matrix (ECM) produced by cardiac fibroblasts. The ECM that surrounds individual myocytes and blood vessels is essential for normal cardiac function. <b>(a)</b> Photomicrograph of the left ventricular (<abbr title="left ventricle">LV</abbr>) myocardium shows the honeycomb pattern of the ECM network around yellow myocytes. (Silver methenamine Jones stain.) <b>(b, c)</b> Electron micrographs at different magnifications and after digestion of myocytes show the ECM (arrows) surrounding the myocytes <b>(b)</b> and an individual capillary vessel <b>(c)</b>.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig3a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig3b" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig3b.jpeg" height="1308" width="1600" aria-labelledby="fig3b" loading="lazy" /><figcaption><span class="heading">Figure 3b</span>. Endomysial collagen network surrounding myocytes. Aside from the gross fibrous skeleton, the cardiac myocytes are surrounded by a cardiac collagen network known as the cardiac extracellular matrix (ECM) produced by cardiac fibroblasts. The ECM that surrounds individual myocytes and blood vessels is essential for normal cardiac function. <b>(a)</b> Photomicrograph of the left ventricular (<abbr title="left ventricle">LV</abbr>) myocardium shows the honeycomb pattern of the ECM network around yellow myocytes. (Silver methenamine Jones stain.) <b>(b, c)</b> Electron micrographs at different magnifications and after digestion of myocytes show the ECM (arrows) surrounding the myocytes <b>(b)</b> and an individual capillary vessel <b>(c)</b>.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig3b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig3c" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig3c.jpeg" height="1309" width="1353" aria-labelledby="fig3c" loading="lazy" /><figcaption><span class="heading">Figure 3c</span>. Endomysial collagen network surrounding myocytes. Aside from the gross fibrous skeleton, the cardiac myocytes are surrounded by a cardiac collagen network known as the cardiac extracellular matrix (ECM) produced by cardiac fibroblasts. The ECM that surrounds individual myocytes and blood vessels is essential for normal cardiac function. <b>(a)</b> Photomicrograph of the left ventricular (<abbr title="left ventricle">LV</abbr>) myocardium shows the honeycomb pattern of the ECM network around yellow myocytes. (Silver methenamine Jones stain.) <b>(b, c)</b> Electron micrographs at different magnifications and after digestion of myocytes show the ECM (arrows) surrounding the myocytes <b>(b)</b> and an individual capillary vessel <b>(c)</b>.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig3c">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig4" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig4.jpeg" height="2025" width="1595" aria-labelledby="fig4" loading="lazy" /><figcaption><span class="heading">Figure 4</span>. Historic representation of the fibrous skeleton. The majority of the fibrous tissue is concentrated at the fibrous trigones and adjacent connecting structures. There is fibrous tissue in the mitral valvar annulus, but this is hardly ever a continuous ring. The mural tricuspid valvar annulus is exclusively composed of fibroadipose tissue. The hinges of the pulmonary valve are not part of the fibrous skeleton. The conus ligament is an inconsistent structure and is seen in only a small fraction of hearts. <i>N</i> = noncoronary sinus.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig4">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig5" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig5.jpeg" height="3456" width="3200" aria-labelledby="fig5" loading="lazy" /><figcaption><span class="heading">Figure 5</span>. Essential components of the fibrous skeleton. Color-coded computed tomographic (CT) images show basal views of the heart after removal of the atria (superior ventricular views) and removal of the ventricles (inferior atrial view). Essential components of the fibrous skeleton include the fibrous aortic-mitral continuity, right and left fibrous trigones, membranous septum, interleaflet triangles, parts of the mitral and tricuspid annuli, tendon of Todaro, and conus ligament. <i>L</i> = left coronary sinus, <i>N</i> = noncoronary sinus, <i>R</i> = right coronary sinus.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig5">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig6a" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig6a.jpeg" height="1815" width="1417" aria-labelledby="fig6a" loading="lazy" /><figcaption><span class="heading">Figure 6a</span>. Aortoventricular membrane. Color-coded volume-rendered CT image (right posterior oblique view) <b>(a)</b> and virtual endoscopy view of the ostium of the <abbr title="left ventricle">LV</abbr> and the <abbr title="left ventricle">LV</abbr> outflow tract (<abbr title="LV outflow tract">LVOT</abbr>) <b>(b)</b> show the components of the aortoventricular membrane. The aortoventricular membrane (green area in <b>a</b>, area bordered by thin white line in <b>b</b>) is described as a tough fibrous structure that covers the ostium of the <abbr title="left ventricle">LV</abbr> connecting to the aortic sinuses superiorly and the mitral valve posteriorly. Components of the aortoventricular membrane include the subvalvular membrane (subvalvar collar) (yellow double-headed arrows in <b>b</b>), right fibrous trigone <i>(RFT)</i>, left fibrous trigone <i>(LFT)</i>, aortic-mitral valvar continuity (curved double-headed arrow), membranous septum (<i>ms</i> in <b>b</b>), and left coronary <i>(L)</i>–noncoronary <i>(N)</i> interleaflet triangle (*). In contrast to the other structures, the subvalvar collar of the mitral valve rarely exists as a complete circumferential band as shown here. In most hearts, it is segmental and limited to parts of the mural mitral annulus. The subvalvar collar is a good anatomic area for placement of sutures during mitral valve surgery, a common location for annulus calcification, and a potential site of perforation during catheter ablation. Some idiopathic ventricular arrhythmias arise from the <abbr title="left ventricle">LV</abbr> ostium close to the subvalvar collar. The aortic-mitral valvar continuity is approximately 3 cm in length extending between the fibrous triangles. <i>LIPV</i> in <b>b</b> = left inferior pulmonary vein, <i>RIPV</i> in <b>b</b> = right inferior pulmonary vein.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig6a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig6b" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig6b.jpeg" height="1816" width="1735" aria-labelledby="fig6b" loading="lazy" /><figcaption><span class="heading">Figure 6b</span>. Aortoventricular membrane. Color-coded volume-rendered CT image (right posterior oblique view) <b>(a)</b> and virtual endoscopy view of the ostium of the <abbr title="left ventricle">LV</abbr> and the <abbr title="left ventricle">LV</abbr> outflow tract (<abbr title="LV outflow tract">LVOT</abbr>) <b>(b)</b> show the components of the aortoventricular membrane. The aortoventricular membrane (green area in <b>a</b>, area bordered by thin white line in <b>b</b>) is described as a tough fibrous structure that covers the ostium of the <abbr title="left ventricle">LV</abbr> connecting to the aortic sinuses superiorly and the mitral valve posteriorly. Components of the aortoventricular membrane include the subvalvular membrane (subvalvar collar) (yellow double-headed arrows in <b>b</b>), right fibrous trigone <i>(RFT)</i>, left fibrous trigone <i>(LFT)</i>, aortic-mitral valvar continuity (curved double-headed arrow), membranous septum (<i>ms</i> in <b>b</b>), and left coronary <i>(L)</i>–noncoronary <i>(N)</i> interleaflet triangle (*). In contrast to the other structures, the subvalvar collar of the mitral valve rarely exists as a complete circumferential band as shown here. In most hearts, it is segmental and limited to parts of the mural mitral annulus. The subvalvar collar is a good anatomic area for placement of sutures during mitral valve surgery, a common location for annulus calcification, and a potential site of perforation during catheter ablation. Some idiopathic ventricular arrhythmias arise from the <abbr title="left ventricle">LV</abbr> ostium close to the subvalvar collar. The aortic-mitral valvar continuity is approximately 3 cm in length extending between the fibrous triangles. <i>LIPV</i> in <b>b</b> = left inferior pulmonary vein, <i>RIPV</i> in <b>b</b> = right inferior pulmonary vein.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig6b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig7" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig7.jpeg" height="3426" width="3200" aria-labelledby="fig7" loading="lazy" /><figcaption><span class="heading">Figure 7</span>. Variation in extent and width of the subvalvar collar of the mitral annulus. CT images (longitudinal two-chamber <abbr title="left ventricle">LV</abbr> views) and corresponding histologic sections from two patients show a well-developed subvalvar collar (red double-headed arrows) at the superior margin of the mitral annulus (left) and along the circumference of the mitral annulus (right). There is no subvalvar collar at the inferior margin of the annulus in the left images. Instead, a tubular annulus connects the mitral valve <i>(MV)</i> leaflet directly to the <abbr title="left ventricle">LV</abbr>.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig7">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig8" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig8.jpeg" height="826" width="2443" aria-labelledby="fig8" loading="lazy" /><figcaption><span class="heading">Figure 8</span>. Mitral annulus morphology. Drawings show variability in the extent of fibrous components (green) of the mitral annulus (<a href="#r14" role="doc-biblioref" data-xml-rid="r14">14</a>).<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig8">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig9a" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig9a.jpeg" height="1502" width="1400" aria-labelledby="fig9a" loading="lazy" /><figcaption><span class="heading">Figure 9a</span>. Mitral annulus pseudoaneurysm in a 59-year-old woman after mitral valve replacement for stenosis. Short-axis <b>(a)</b>, coronal <b>(b)</b>, and coronal volume-rendered <b>(c)</b> CT angiograms show the replaced mitral valve (red arrows). A pseudoaneurysm (green arrows) is seen at the inferomedial margin of the mitral annulus. At the midpoint of the posterior leaflet of the mitral valve, the subvalvar segment of the aortoventricular membrane narrows and in some cases is not visible. In this region where suturing does not have strong fibrotic tissue support, dehiscence or perforation may develop. <i>Ao</i> = aorta, <i>LA</i> = left atrium.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig9a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig9b" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig9b.jpeg" height="1179" width="1666" aria-labelledby="fig9b" loading="lazy" /><figcaption><span class="heading">Figure 9b</span>. Mitral annulus pseudoaneurysm in a 59-year-old woman after mitral valve replacement for stenosis. Short-axis <b>(a)</b>, coronal <b>(b)</b>, and coronal volume-rendered <b>(c)</b> CT angiograms show the replaced mitral valve (red arrows). A pseudoaneurysm (green arrows) is seen at the inferomedial margin of the mitral annulus. At the midpoint of the posterior leaflet of the mitral valve, the subvalvar segment of the aortoventricular membrane narrows and in some cases is not visible. In this region where suturing does not have strong fibrotic tissue support, dehiscence or perforation may develop. <i>Ao</i> = aorta, <i>LA</i> = left atrium.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig9b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig9c" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig9c.jpeg" height="1179" width="1283" aria-labelledby="fig9c" loading="lazy" /><figcaption><span class="heading">Figure 9c</span>. Mitral annulus pseudoaneurysm in a 59-year-old woman after mitral valve replacement for stenosis. Short-axis <b>(a)</b>, coronal <b>(b)</b>, and coronal volume-rendered <b>(c)</b> CT angiograms show the replaced mitral valve (red arrows). A pseudoaneurysm (green arrows) is seen at the inferomedial margin of the mitral annulus. At the midpoint of the posterior leaflet of the mitral valve, the subvalvar segment of the aortoventricular membrane narrows and in some cases is not visible. In this region where suturing does not have strong fibrotic tissue support, dehiscence or perforation may develop. <i>Ao</i> = aorta, <i>LA</i> = left atrium.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig9c">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig10a" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig10a.jpeg" height="890" width="2492" aria-labelledby="fig10a" loading="lazy" /><figcaption><span class="heading">Figure 10a</span>. Mitral annulus morphology and function. <b>(a)</b> Diagrams in three projections show nonplanar saddle-shaped morphology of the mitral annulus (<a href="#r17" role="doc-biblioref" data-xml-rid="r17">17</a>). <b>(b)</b> Short-axis CT angiograms show variation of the annulus area with the cardiac cycle. During the cardiac cycle, no change occurs at the fibrous aortic-mitral continuity (blue margin in <b>a</b>). Annular contraction occurs in early systole and a deeper saddle-shaped morphology occurs, followed by gradual annular area increase until end systole. The difference is minimal during late systole and diastole. This normal dynamic change in morphology is altered in myxomatous valve disease and acute posterior wall ischemia. Flattening and dilatation of the annulus in these conditions lead to lack of leaflet coaptation followed by mitral insufficiency.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig10a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig10b" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig10b.jpeg" height="808" width="2500" aria-labelledby="fig10b" loading="lazy" /><figcaption><span class="heading">Figure 10b</span>. Mitral annulus morphology and function. <b>(a)</b> Diagrams in three projections show nonplanar saddle-shaped morphology of the mitral annulus (<a href="#r17" role="doc-biblioref" data-xml-rid="r17">17</a>). <b>(b)</b> Short-axis CT angiograms show variation of the annulus area with the cardiac cycle. During the cardiac cycle, no change occurs at the fibrous aortic-mitral continuity (blue margin in <b>a</b>). Annular contraction occurs in early systole and a deeper saddle-shaped morphology occurs, followed by gradual annular area increase until end systole. The difference is minimal during late systole and diastole. This normal dynamic change in morphology is altered in myxomatous valve disease and acute posterior wall ischemia. Flattening and dilatation of the annulus in these conditions lead to lack of leaflet coaptation followed by mitral insufficiency.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig10b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig11a" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig11a.jpeg" height="1252" width="1404" aria-labelledby="fig11a" loading="lazy" /><figcaption><span class="heading">Figure 11a</span>. Abscess of the fibrous aortic-mitral continuity with secondary pseudoaneurysm in a 21-year-old man with a bicuspid aortic valve (right coronary sinus–noncoronary sinus fusion) and fever. Short-axis <b>(a)</b> and three-chamber <b>(b)</b> CT angiograms show an abscess cavity (pseudoaneurysm) (green arrow) that originated between the left <i>(L)</i> and noncoronary <i>(N)</i> aortic sinuses extending into the fibrous aortic-mitral continuity (red arrow) and transverse sinus. The three-chamber view <b>(b)</b> also shows normal attachment of the anterior wall of the left atrium <i>(LA)</i> to the intervalvar fibrosa. Destruction of the intervalvar fibrosa in infective endocarditis is caused by enzymatic degradation and is most common when prosthetic valves in both the mitral and aortic positions are infected. Surgery includes valve replacement and reconstruction of the intervalvar fibrosa. <i>Ao</i> = aorta, <i>MV</i> = mitral valve, <i>R</i> = right coronary sinus.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig11a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig11b" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig11b.jpeg" height="1252" width="1250" aria-labelledby="fig11b" loading="lazy" /><figcaption><span class="heading">Figure 11b</span>. Abscess of the fibrous aortic-mitral continuity with secondary pseudoaneurysm in a 21-year-old man with a bicuspid aortic valve (right coronary sinus–noncoronary sinus fusion) and fever. Short-axis <b>(a)</b> and three-chamber <b>(b)</b> CT angiograms show an abscess cavity (pseudoaneurysm) (green arrow) that originated between the left <i>(L)</i> and noncoronary <i>(N)</i> aortic sinuses extending into the fibrous aortic-mitral continuity (red arrow) and transverse sinus. The three-chamber view <b>(b)</b> also shows normal attachment of the anterior wall of the left atrium <i>(LA)</i> to the intervalvar fibrosa. Destruction of the intervalvar fibrosa in infective endocarditis is caused by enzymatic degradation and is most common when prosthetic valves in both the mitral and aortic positions are infected. Surgery includes valve replacement and reconstruction of the intervalvar fibrosa. <i>Ao</i> = aorta, <i>MV</i> = mitral valve, <i>R</i> = right coronary sinus.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig11b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig12a" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig12a.jpeg" height="1120" width="1800" aria-labelledby="fig12a" loading="lazy" /><figcaption><span class="heading">Figure 12a</span>. Fibrous trigones and membranous septum. <i>RCA</i> = right coronary artery. <b>(a)</b> Aortic sinuses. Longitudinal open-book dissection shows the three aortic sinuses. The fibrous continuity between the aortic leaflet of the mitral valve and the left coronary <i>(L)</i> and noncoronary <i>(N)</i> sinuses is shown, with the junction demarcated by a dotted green line. Two of the three interleaflet fibrous triangles (red △) are shown. The right fibrous trigone <i>(RFT)</i> lies inferior and posterior to the membranous septum, which lies just beneath the right coronary sinus <i>(R)</i>–noncoronary sinus triangle. The two fibrous structures together form the central fibrous body <i>(CFB)</i>. The <abbr title="atrioventricular">AV</abbr> conduction axis penetrates through this fibrous area. In mitral surgery, dividing the intervalvular fibrosa and opening the dome of the left atrium maximize exposure of the mitral annulus. <i>LFT</i> = left fibrous trigone. <b>(b, c)</b> Membranous septum. Coronal CT image <b>(b)</b> and composite color-coded volume-rendered image (right anterior oblique view) <b>(c)</b> show the relationship of the membranous septum <i>(MS)</i> to the tricuspid and aortic annuli. The commissure between the septal and anterior leaflets is usually located over the membranous septum and divides it into two components: the <abbr title="atrioventricular">AV</abbr> membranous component and interventricular membranous component <i>(IV-MS)</i>. <i>AA</i> = ascending aorta, <i>IVS</i> = muscular interventricular septum, <i>N</i> = noncoronary sinus, <i>R</i> = right coronary sinus, <i>RA</i> = right atrium, <i>TV</i> = tricuspid valve.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig12a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig12b" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig12b.jpeg" height="1287" width="1559" aria-labelledby="fig12b" loading="lazy" /><figcaption><span class="heading">Figure 12b</span>. Fibrous trigones and membranous septum. <i>RCA</i> = right coronary artery. <b>(a)</b> Aortic sinuses. Longitudinal open-book dissection shows the three aortic sinuses. The fibrous continuity between the aortic leaflet of the mitral valve and the left coronary <i>(L)</i> and noncoronary <i>(N)</i> sinuses is shown, with the junction demarcated by a dotted green line. Two of the three interleaflet fibrous triangles (red △) are shown. The right fibrous trigone <i>(RFT)</i> lies inferior and posterior to the membranous septum, which lies just beneath the right coronary sinus <i>(R)</i>–noncoronary sinus triangle. The two fibrous structures together form the central fibrous body <i>(CFB)</i>. The <abbr title="atrioventricular">AV</abbr> conduction axis penetrates through this fibrous area. In mitral surgery, dividing the intervalvular fibrosa and opening the dome of the left atrium maximize exposure of the mitral annulus. <i>LFT</i> = left fibrous trigone. <b>(b, c)</b> Membranous septum. Coronal CT image <b>(b)</b> and composite color-coded volume-rendered image (right anterior oblique view) <b>(c)</b> show the relationship of the membranous septum <i>(MS)</i> to the tricuspid and aortic annuli. The commissure between the septal and anterior leaflets is usually located over the membranous septum and divides it into two components: the <abbr title="atrioventricular">AV</abbr> membranous component and interventricular membranous component <i>(IV-MS)</i>. <i>AA</i> = ascending aorta, <i>IVS</i> = muscular interventricular septum, <i>N</i> = noncoronary sinus, <i>R</i> = right coronary sinus, <i>RA</i> = right atrium, <i>TV</i> = tricuspid valve.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig12b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig12c" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig12c.jpeg" height="1287" width="1590" aria-labelledby="fig12c" loading="lazy" /><figcaption><span class="heading">Figure 12c</span>. Fibrous trigones and membranous septum. <i>RCA</i> = right coronary artery. <b>(a)</b> Aortic sinuses. Longitudinal open-book dissection shows the three aortic sinuses. The fibrous continuity between the aortic leaflet of the mitral valve and the left coronary <i>(L)</i> and noncoronary <i>(N)</i> sinuses is shown, with the junction demarcated by a dotted green line. Two of the three interleaflet fibrous triangles (red △) are shown. The right fibrous trigone <i>(RFT)</i> lies inferior and posterior to the membranous septum, which lies just beneath the right coronary sinus <i>(R)</i>–noncoronary sinus triangle. The two fibrous structures together form the central fibrous body <i>(CFB)</i>. The <abbr title="atrioventricular">AV</abbr> conduction axis penetrates through this fibrous area. In mitral surgery, dividing the intervalvular fibrosa and opening the dome of the left atrium maximize exposure of the mitral annulus. <i>LFT</i> = left fibrous trigone. <b>(b, c)</b> Membranous septum. Coronal CT image <b>(b)</b> and composite color-coded volume-rendered image (right anterior oblique view) <b>(c)</b> show the relationship of the membranous septum <i>(MS)</i> to the tricuspid and aortic annuli. The commissure between the septal and anterior leaflets is usually located over the membranous septum and divides it into two components: the <abbr title="atrioventricular">AV</abbr> membranous component and interventricular membranous component <i>(IV-MS)</i>. <i>AA</i> = ascending aorta, <i>IVS</i> = muscular interventricular septum, <i>N</i> = noncoronary sinus, <i>R</i> = right coronary sinus, <i>RA</i> = right atrium, <i>TV</i> = tricuspid valve.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig12c">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig13" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig13.jpeg" height="2144" width="3400" aria-labelledby="fig13" loading="lazy" /><figcaption><span class="heading">Figure 13</span>. Fibrous components of the <abbr title="LV outflow tract">LVOT</abbr>. Short-axis CT images of the <abbr title="LV outflow tract">LVOT</abbr> (middle and right), displayed from superior to inferior, were reconstructed using a three-chamber reference image (left). In short-axis cross section, the posterior wall of the <abbr title="LV outflow tract">LVOT</abbr> is formed by the fibrous interleaflet triangle between the noncoronary <i>(N)</i> and left coronary <i>(L)</i> aortic sinuses, which is in fibrous continuity with the anterior (aortic) leaflet of the mitral valve. As shown, this fibrous aortic-mitral valvar curtain is thicker on the sides and forms the right fibrous trigone <i>(RFT)</i> and left fibrous trigone <i>(LFT)</i> at the nadirs of the noncoronary and left coronary sinuses, respectively. The anterior and anterolateral walls of the <abbr title="LV outflow tract">LVOT</abbr> are primarily formed by the muscle. The anteromedial wall of the <abbr title="LV outflow tract">LVOT</abbr> is formed by the membranous septum <i>(ms)</i>. <i>LA</i> = left atrium, <i>R</i> = right coronary sinus, <i>RV</i> = right ventricle, <i>RVOT</i> = right ventricular outflow tract.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig13">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig14" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig14.jpeg" height="3549" width="2700" aria-labelledby="fig14" loading="lazy" /><figcaption><span class="heading">Figure 14</span>. Anatomic components of the aortic sinuses. Using a short-axis reference CT image through the aortic valve, three volume-rendered images of the left heart were obtained along the anterolateral (red), anteromedial (green), and posterior (yellow) sides of the aortic root and <abbr title="LV outflow tract">LVOT</abbr>. The muscular part of the <abbr title="LV outflow tract">LVOT</abbr> is demarcated by a dashed white line. The numbers 1–3 denote three points of reference to make the orientation of the volume-rendered images easier to follow. The <abbr title="left ventricle">LV</abbr> muscle is shown as reddish brown on the color-coded images. The nadirs of both the right <i>(R)</i> and left <i>(L)</i> coronary sinuses are in contact with the <abbr title="left ventricle">LV</abbr> ostium muscle. The posterior portion of the left coronary sinus is not in direct contact with the <abbr title="left ventricle">LV</abbr> myocardium; instead, it is attached to the left fibrous trigone <i>(LFT)</i> and faces the left atrium <i>(LA)</i>. There are three fibrous interleaflet triangles that reach to the level of the sinutubular junction (STJ) of the aorta. The imaging annulus corresponds to the plane passing through the nadirs of the leaflet hinge-lines. <i>LM</i> = left main coronary artery, <i>ms</i> = membranous septum, <i>N</i> = noncoronary sinus, <i>RA</i> = right atrium, <i>RCA</i> = right coronary artery, <i>RFT</i> = right fibrous trigone, <i>TV</i> = tricuspid valve.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig14">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig15a" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig15a.jpeg" height="1210" width="1438" aria-labelledby="fig15a" loading="lazy" /><figcaption><span class="heading">Figure 15a</span>. Calcifications. <b>(a)</b> CT image (four-chamber view) in a 68-year-old woman shows calcification (arrow) limited to the subvalvar collar of the posterior mitral annulus. Early calcification of the mitral annulus usually involves the mural annulus (77% of cases) and appears to be more common in women. <b>(b)</b> Sagittal CT image in a 64-year-old woman shows extensive calcification of the inferior mitral annulus with progression into the septum involving the right septomarginal trabeculation. Large calcifications can interfere with normal valve function. <b>(c)</b> Short-axis CT image in a 69-year-old woman shows a large calcified lesion of the membranous septum (black arrow). Rarely, calcifications involve the His bundle and bundle branches, causing heart block that requires a permanent pacemaker (white arrow). <b>(d)</b> Short-axis CT image in a 60-year-old man shows a 2-cm oval structure with eggshell rim calcification and homogeneous central calcification (arrow) in the anterolateral aspect of the mitral annulus approaching the left fibrous triangle, consistent with caseous calcification of the mitral annulus.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig15a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig15b" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig15b.jpeg" height="1210" width="1208" aria-labelledby="fig15b" loading="lazy" /><figcaption><span class="heading">Figure 15b</span>. Calcifications. <b>(a)</b> CT image (four-chamber view) in a 68-year-old woman shows calcification (arrow) limited to the subvalvar collar of the posterior mitral annulus. Early calcification of the mitral annulus usually involves the mural annulus (77% of cases) and appears to be more common in women. <b>(b)</b> Sagittal CT image in a 64-year-old woman shows extensive calcification of the inferior mitral annulus with progression into the septum involving the right septomarginal trabeculation. Large calcifications can interfere with normal valve function. <b>(c)</b> Short-axis CT image in a 69-year-old woman shows a large calcified lesion of the membranous septum (black arrow). Rarely, calcifications involve the His bundle and bundle branches, causing heart block that requires a permanent pacemaker (white arrow). <b>(d)</b> Short-axis CT image in a 60-year-old man shows a 2-cm oval structure with eggshell rim calcification and homogeneous central calcification (arrow) in the anterolateral aspect of the mitral annulus approaching the left fibrous triangle, consistent with caseous calcification of the mitral annulus.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig15b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig15c" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig15c.jpeg" height="1173" width="1379" aria-labelledby="fig15c" loading="lazy" /><figcaption><span class="heading">Figure 15c</span>. Calcifications. <b>(a)</b> CT image (four-chamber view) in a 68-year-old woman shows calcification (arrow) limited to the subvalvar collar of the posterior mitral annulus. Early calcification of the mitral annulus usually involves the mural annulus (77% of cases) and appears to be more common in women. <b>(b)</b> Sagittal CT image in a 64-year-old woman shows extensive calcification of the inferior mitral annulus with progression into the septum involving the right septomarginal trabeculation. Large calcifications can interfere with normal valve function. <b>(c)</b> Short-axis CT image in a 69-year-old woman shows a large calcified lesion of the membranous septum (black arrow). Rarely, calcifications involve the His bundle and bundle branches, causing heart block that requires a permanent pacemaker (white arrow). <b>(d)</b> Short-axis CT image in a 60-year-old man shows a 2-cm oval structure with eggshell rim calcification and homogeneous central calcification (arrow) in the anterolateral aspect of the mitral annulus approaching the left fibrous triangle, consistent with caseous calcification of the mitral annulus.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig15c">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig15d" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig15d.jpeg" height="1172" width="1273" aria-labelledby="fig15d" loading="lazy" /><figcaption><span class="heading">Figure 15d</span>. Calcifications. <b>(a)</b> CT image (four-chamber view) in a 68-year-old woman shows calcification (arrow) limited to the subvalvar collar of the posterior mitral annulus. Early calcification of the mitral annulus usually involves the mural annulus (77% of cases) and appears to be more common in women. <b>(b)</b> Sagittal CT image in a 64-year-old woman shows extensive calcification of the inferior mitral annulus with progression into the septum involving the right septomarginal trabeculation. Large calcifications can interfere with normal valve function. <b>(c)</b> Short-axis CT image in a 69-year-old woman shows a large calcified lesion of the membranous septum (black arrow). Rarely, calcifications involve the His bundle and bundle branches, causing heart block that requires a permanent pacemaker (white arrow). <b>(d)</b> Short-axis CT image in a 60-year-old man shows a 2-cm oval structure with eggshell rim calcification and homogeneous central calcification (arrow) in the anterolateral aspect of the mitral annulus approaching the left fibrous triangle, consistent with caseous calcification of the mitral annulus.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig15d">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig16" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig16.jpeg" height="3804" width="3000" aria-labelledby="fig16" loading="lazy" /><figcaption><span class="heading">Figure 16</span>. Central fibrous body contents and calcification of the right fibrous trigone in a 64-year-old man. Four-chamber histologic sections (left), contrast-enhanced CT images (middle), and nonenhanced CT images (right) are shown from inferior (top) to superior (bottom) at the level of the central fibrous body. On the histologic sections, fibrous tissue is in blue and the muscles and conduction system are in brownish red. On the CT images, calcified parts of the fibrous skeleton (purple arrows) including the right fibrous trigone <i>(RFT)</i> and mitral annulus correspond to the areas outlined by dashed black lines on the histologic sections. Note extension of the calcification into the fibrous tissue surrounding the penetrating His bundle <i>(His)</i> and bundle branches. <i>AVN</i> = <abbr title="atrioventricular">AV</abbr> node, <i>AVNA</i> = <abbr title="atrioventricular">AV</abbr> nodal artery, <i>IVS</i> = interventricular septum, <i>LA</i> = left atrium, <i>LBB</i> = left bundle branch, <i>MS</i> = membranous septum, <i>MV</i> = mitral valve leaflet, <i>RA</i> = right atrium, <i>RBB</i> = right bundle branch, <i>TV</i> = septal tricuspid valve leaflet.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig16">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig17a" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig17a.jpeg" height="1356" width="1376" aria-labelledby="fig17a" loading="lazy" /><figcaption><span class="heading">Figure 17a</span>. Tricuspid valve annulus. <b>(a)</b> Short-axis CT image at the level of the tricuspid annulus shows division of the membranous septum (double-headed yellow arrow) into two compartments by the tricuspid leaflets at the zone of attachment (commissure) between the septal and anterosuperior leaflets. <b>(b)</b> Color-coded tricuspid annulus projected on a volume-rendered CT image shows the normal nonplanar annulus (green), with the posteroseptal portion being the lowest (displaced toward the <abbr title="right ventricle">RV</abbr> apex) and the anteroseptal portion being the highest. In severe functional tricuspid regurgitation (FTR), the annulus becomes planar and flat. <b>(c, d)</b> Short-axis CT images show the shape of the tricuspid annulus in a normal 34-year-old man <b>(c)</b> and a 32-year-old woman with FTR and right heart enlargement <b>(d)</b>. In its normal condition, the annulus appears oval with a diameter ratio of 1.3. In FTR, dilatation occurs along the free wall (mural annulus). The septal wall attached to the central fibrous body and membranous septum (double-headed yellow arrow) remains stable and does not dilate.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig17a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig17b" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig17b.jpeg" height="1352" width="1277" aria-labelledby="fig17b" loading="lazy" /><figcaption><span class="heading">Figure 17b</span>. Tricuspid valve annulus. <b>(a)</b> Short-axis CT image at the level of the tricuspid annulus shows division of the membranous septum (double-headed yellow arrow) into two compartments by the tricuspid leaflets at the zone of attachment (commissure) between the septal and anterosuperior leaflets. <b>(b)</b> Color-coded tricuspid annulus projected on a volume-rendered CT image shows the normal nonplanar annulus (green), with the posteroseptal portion being the lowest (displaced toward the <abbr title="right ventricle">RV</abbr> apex) and the anteroseptal portion being the highest. In severe functional tricuspid regurgitation (FTR), the annulus becomes planar and flat. <b>(c, d)</b> Short-axis CT images show the shape of the tricuspid annulus in a normal 34-year-old man <b>(c)</b> and a 32-year-old woman with FTR and right heart enlargement <b>(d)</b>. In its normal condition, the annulus appears oval with a diameter ratio of 1.3. In FTR, dilatation occurs along the free wall (mural annulus). The septal wall attached to the central fibrous body and membranous septum (double-headed yellow arrow) remains stable and does not dilate.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig17b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig17c" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig17c.jpeg" height="1252" width="1374" aria-labelledby="fig17c" loading="lazy" /><figcaption><span class="heading">Figure 17c</span>. Tricuspid valve annulus. <b>(a)</b> Short-axis CT image at the level of the tricuspid annulus shows division of the membranous septum (double-headed yellow arrow) into two compartments by the tricuspid leaflets at the zone of attachment (commissure) between the septal and anterosuperior leaflets. <b>(b)</b> Color-coded tricuspid annulus projected on a volume-rendered CT image shows the normal nonplanar annulus (green), with the posteroseptal portion being the lowest (displaced toward the <abbr title="right ventricle">RV</abbr> apex) and the anteroseptal portion being the highest. In severe functional tricuspid regurgitation (FTR), the annulus becomes planar and flat. <b>(c, d)</b> Short-axis CT images show the shape of the tricuspid annulus in a normal 34-year-old man <b>(c)</b> and a 32-year-old woman with FTR and right heart enlargement <b>(d)</b>. In its normal condition, the annulus appears oval with a diameter ratio of 1.3. In FTR, dilatation occurs along the free wall (mural annulus). The septal wall attached to the central fibrous body and membranous septum (double-headed yellow arrow) remains stable and does not dilate.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig17c">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig17d" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig17d.jpeg" height="1252" width="1282" aria-labelledby="fig17d" loading="lazy" /><figcaption><span class="heading">Figure 17d</span>. Tricuspid valve annulus. <b>(a)</b> Short-axis CT image at the level of the tricuspid annulus shows division of the membranous septum (double-headed yellow arrow) into two compartments by the tricuspid leaflets at the zone of attachment (commissure) between the septal and anterosuperior leaflets. <b>(b)</b> Color-coded tricuspid annulus projected on a volume-rendered CT image shows the normal nonplanar annulus (green), with the posteroseptal portion being the lowest (displaced toward the <abbr title="right ventricle">RV</abbr> apex) and the anteroseptal portion being the highest. In severe functional tricuspid regurgitation (FTR), the annulus becomes planar and flat. <b>(c, d)</b> Short-axis CT images show the shape of the tricuspid annulus in a normal 34-year-old man <b>(c)</b> and a 32-year-old woman with FTR and right heart enlargement <b>(d)</b>. In its normal condition, the annulus appears oval with a diameter ratio of 1.3. In FTR, dilatation occurs along the free wall (mural annulus). The septal wall attached to the central fibrous body and membranous septum (double-headed yellow arrow) remains stable and does not dilate.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig17d">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig18a" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig18a.jpeg" height="1043" width="1589" aria-labelledby="fig18a" loading="lazy" /><figcaption><span class="heading">Figure 18a</span>. Ebstein anomaly and accessory pathways. <i>RA</i> = right atrium, <i>RCA</i> = right coronary artery. <b>(a)</b> Longitudinal section through the <abbr title="atrioventricular">AV</abbr> junction at the level of the septal tricuspid leaflet shows a normal tricuspid valve. A fibrous annulus is seen only in the septal region, and the septal leaflet is directly attached to the annulus. <b>(b)</b> Corresponding longitudinal section in a patient with Ebstein anomaly. The septal leaflet is hypoplastic, thickened, and in part adherent to the <abbr title="right ventricle">RV</abbr>. The apical displacement of the septal leaflet is commonly associated with discontinuity of the central fibrous body and septal <abbr title="atrioventricular">AV</abbr> annulus, a substrate for cardiac arrhythmias. <b>(c)</b> Four-chamber color-coded CT image in a 45-year-old woman with Ebstein anomaly shows the apically displaced septal tricuspid leaflet. <i>MV</i> = mitral valve. <b>(d)</b> Corresponding longitudinal section shows Ebstein anomaly with abnormal <abbr title="atrioventricular">AV</abbr> muscle bridges. In 25% of cases of Ebstein anomaly, some myocardium passes directly through the <abbr title="atrioventricular">AV</abbr> annulus, forming a potential substrate for accessory <abbr title="atrioventricular">AV</abbr> connections and ventricular pre-excitation (Wolff-Parkinson-White syndrome). Large bridges may be seen with high-resolution CT.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig18a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig18b" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig18b.jpeg" height="1033" width="1955" aria-labelledby="fig18b" loading="lazy" /><figcaption><span class="heading">Figure 18b</span>. Ebstein anomaly and accessory pathways. <i>RA</i> = right atrium, <i>RCA</i> = right coronary artery. <b>(a)</b> Longitudinal section through the <abbr title="atrioventricular">AV</abbr> junction at the level of the septal tricuspid leaflet shows a normal tricuspid valve. A fibrous annulus is seen only in the septal region, and the septal leaflet is directly attached to the annulus. <b>(b)</b> Corresponding longitudinal section in a patient with Ebstein anomaly. The septal leaflet is hypoplastic, thickened, and in part adherent to the <abbr title="right ventricle">RV</abbr>. The apical displacement of the septal leaflet is commonly associated with discontinuity of the central fibrous body and septal <abbr title="atrioventricular">AV</abbr> annulus, a substrate for cardiac arrhythmias. <b>(c)</b> Four-chamber color-coded CT image in a 45-year-old woman with Ebstein anomaly shows the apically displaced septal tricuspid leaflet. <i>MV</i> = mitral valve. <b>(d)</b> Corresponding longitudinal section shows Ebstein anomaly with abnormal <abbr title="atrioventricular">AV</abbr> muscle bridges. In 25% of cases of Ebstein anomaly, some myocardium passes directly through the <abbr title="atrioventricular">AV</abbr> annulus, forming a potential substrate for accessory <abbr title="atrioventricular">AV</abbr> connections and ventricular pre-excitation (Wolff-Parkinson-White syndrome). Large bridges may be seen with high-resolution CT.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig18b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig18c" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig18c.jpeg" height="1330" width="1561" aria-labelledby="fig18c" loading="lazy" /><figcaption><span class="heading">Figure 18c</span>. Ebstein anomaly and accessory pathways. <i>RA</i> = right atrium, <i>RCA</i> = right coronary artery. <b>(a)</b> Longitudinal section through the <abbr title="atrioventricular">AV</abbr> junction at the level of the septal tricuspid leaflet shows a normal tricuspid valve. A fibrous annulus is seen only in the septal region, and the septal leaflet is directly attached to the annulus. <b>(b)</b> Corresponding longitudinal section in a patient with Ebstein anomaly. The septal leaflet is hypoplastic, thickened, and in part adherent to the <abbr title="right ventricle">RV</abbr>. The apical displacement of the septal leaflet is commonly associated with discontinuity of the central fibrous body and septal <abbr title="atrioventricular">AV</abbr> annulus, a substrate for cardiac arrhythmias. <b>(c)</b> Four-chamber color-coded CT image in a 45-year-old woman with Ebstein anomaly shows the apically displaced septal tricuspid leaflet. <i>MV</i> = mitral valve. <b>(d)</b> Corresponding longitudinal section shows Ebstein anomaly with abnormal <abbr title="atrioventricular">AV</abbr> muscle bridges. In 25% of cases of Ebstein anomaly, some myocardium passes directly through the <abbr title="atrioventricular">AV</abbr> annulus, forming a potential substrate for accessory <abbr title="atrioventricular">AV</abbr> connections and ventricular pre-excitation (Wolff-Parkinson-White syndrome). Large bridges may be seen with high-resolution CT.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig18c">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig18d" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig18d.jpeg" height="1317" width="1592" aria-labelledby="fig18d" loading="lazy" /><figcaption><span class="heading">Figure 18d</span>. Ebstein anomaly and accessory pathways. <i>RA</i> = right atrium, <i>RCA</i> = right coronary artery. <b>(a)</b> Longitudinal section through the <abbr title="atrioventricular">AV</abbr> junction at the level of the septal tricuspid leaflet shows a normal tricuspid valve. A fibrous annulus is seen only in the septal region, and the septal leaflet is directly attached to the annulus. <b>(b)</b> Corresponding longitudinal section in a patient with Ebstein anomaly. The septal leaflet is hypoplastic, thickened, and in part adherent to the <abbr title="right ventricle">RV</abbr>. The apical displacement of the septal leaflet is commonly associated with discontinuity of the central fibrous body and septal <abbr title="atrioventricular">AV</abbr> annulus, a substrate for cardiac arrhythmias. <b>(c)</b> Four-chamber color-coded CT image in a 45-year-old woman with Ebstein anomaly shows the apically displaced septal tricuspid leaflet. <i>MV</i> = mitral valve. <b>(d)</b> Corresponding longitudinal section shows Ebstein anomaly with abnormal <abbr title="atrioventricular">AV</abbr> muscle bridges. In 25% of cases of Ebstein anomaly, some myocardium passes directly through the <abbr title="atrioventricular">AV</abbr> annulus, forming a potential substrate for accessory <abbr title="atrioventricular">AV</abbr> connections and ventricular pre-excitation (Wolff-Parkinson-White syndrome). Large bridges may be seen with high-resolution CT.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig18d">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig19a" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig19a.jpeg" height="1239" width="1399" aria-labelledby="fig19a" loading="lazy" /><figcaption><span class="heading">Figure 19a</span>. Pulmonary annulus. <i>A</i> = anterior pulmonary leaflet, <i>L</i> = left coronary sinus, <i>Lp</i> = left posterior pulmonary leaflet, <i>N</i> = noncoronary sinus, <i>R</i> = right coronary sinus. <b>(a, b)</b> Short-axis cross section <b>(a)</b> and CT images <b>(b)</b> of the heart at the aortic root show the muscular subpulmonary infundibulum of the <abbr title="RV outflow tract">RVOT</abbr> in its long axis approaching the pulmonary valve. While all of the leaflets of the pulmonary valve are supported by infundibular musculature, only two of the leaflets of the aortic valve have muscular support. <i>CS</i> = coronary sinus, <i>LA</i> = left atrium, <i>ms</i> = membranous septum, <i>MV-AL</i> = mitral valve–aortic leaflet, <i>RA</i> = right atrium. <b>(c, d)</b> Opened pulmonary root with endocardial dissection <b>(c)</b> and sagittal CT images of the <abbr title="RV outflow tract">RVOT</abbr> <b>(d)</b> show the leaflets of the pulmonary valve supported by infundibular musculature. The muscle covers the outer surface of the sinus bases <b>(d)</b>, and its distal edge demarcates the anatomic ventriculoarterial junction <i>(A-VAJ)</i> (dashed blue lines). The red lines demarcate the hemodynamic VAJ <i>(H-VAJ)</i>, which follows the semilunar attachments of the three arterial valvar leaflets and crosses the A-VAJ at six points. ★ = interleaflet <i>(IL)</i> triangles. The imaging annulus is the line connecting the inferior margin of the hinges of the leaflets (green lines). The distance between the A-VAJ and the imaging annulus roughly corresponds to the anatomic annulus (arrows in <b>d</b> [inset cadaveric view]). Therefore, while the imaging annulus looks like a ring, the anatomic annulus exists as a band of variable width.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig19a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig19b" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig19b.jpeg" height="868" width="1742" aria-labelledby="fig19b" loading="lazy" /><figcaption><span class="heading">Figure 19b</span>. Pulmonary annulus. <i>A</i> = anterior pulmonary leaflet, <i>L</i> = left coronary sinus, <i>Lp</i> = left posterior pulmonary leaflet, <i>N</i> = noncoronary sinus, <i>R</i> = right coronary sinus. <b>(a, b)</b> Short-axis cross section <b>(a)</b> and CT images <b>(b)</b> of the heart at the aortic root show the muscular subpulmonary infundibulum of the <abbr title="RV outflow tract">RVOT</abbr> in its long axis approaching the pulmonary valve. While all of the leaflets of the pulmonary valve are supported by infundibular musculature, only two of the leaflets of the aortic valve have muscular support. <i>CS</i> = coronary sinus, <i>LA</i> = left atrium, <i>ms</i> = membranous septum, <i>MV-AL</i> = mitral valve–aortic leaflet, <i>RA</i> = right atrium. <b>(c, d)</b> Opened pulmonary root with endocardial dissection <b>(c)</b> and sagittal CT images of the <abbr title="RV outflow tract">RVOT</abbr> <b>(d)</b> show the leaflets of the pulmonary valve supported by infundibular musculature. The muscle covers the outer surface of the sinus bases <b>(d)</b>, and its distal edge demarcates the anatomic ventriculoarterial junction <i>(A-VAJ)</i> (dashed blue lines). The red lines demarcate the hemodynamic VAJ <i>(H-VAJ)</i>, which follows the semilunar attachments of the three arterial valvar leaflets and crosses the A-VAJ at six points. ★ = interleaflet <i>(IL)</i> triangles. The imaging annulus is the line connecting the inferior margin of the hinges of the leaflets (green lines). The distance between the A-VAJ and the imaging annulus roughly corresponds to the anatomic annulus (arrows in <b>d</b> [inset cadaveric view]). Therefore, while the imaging annulus looks like a ring, the anatomic annulus exists as a band of variable width.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig19b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig19c" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig19c.jpeg" height="1241" width="1546" aria-labelledby="fig19c" loading="lazy" /><figcaption><span class="heading">Figure 19c</span>. Pulmonary annulus. <i>A</i> = anterior pulmonary leaflet, <i>L</i> = left coronary sinus, <i>Lp</i> = left posterior pulmonary leaflet, <i>N</i> = noncoronary sinus, <i>R</i> = right coronary sinus. <b>(a, b)</b> Short-axis cross section <b>(a)</b> and CT images <b>(b)</b> of the heart at the aortic root show the muscular subpulmonary infundibulum of the <abbr title="RV outflow tract">RVOT</abbr> in its long axis approaching the pulmonary valve. While all of the leaflets of the pulmonary valve are supported by infundibular musculature, only two of the leaflets of the aortic valve have muscular support. <i>CS</i> = coronary sinus, <i>LA</i> = left atrium, <i>ms</i> = membranous septum, <i>MV-AL</i> = mitral valve–aortic leaflet, <i>RA</i> = right atrium. <b>(c, d)</b> Opened pulmonary root with endocardial dissection <b>(c)</b> and sagittal CT images of the <abbr title="RV outflow tract">RVOT</abbr> <b>(d)</b> show the leaflets of the pulmonary valve supported by infundibular musculature. The muscle covers the outer surface of the sinus bases <b>(d)</b>, and its distal edge demarcates the anatomic ventriculoarterial junction <i>(A-VAJ)</i> (dashed blue lines). The red lines demarcate the hemodynamic VAJ <i>(H-VAJ)</i>, which follows the semilunar attachments of the three arterial valvar leaflets and crosses the A-VAJ at six points. ★ = interleaflet <i>(IL)</i> triangles. The imaging annulus is the line connecting the inferior margin of the hinges of the leaflets (green lines). The distance between the A-VAJ and the imaging annulus roughly corresponds to the anatomic annulus (arrows in <b>d</b> [inset cadaveric view]). Therefore, while the imaging annulus looks like a ring, the anatomic annulus exists as a band of variable width.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig19c">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig19d" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig19d.jpeg" height="868" width="2004" aria-labelledby="fig19d" loading="lazy" /><figcaption><span class="heading">Figure 19d</span>. Pulmonary annulus. <i>A</i> = anterior pulmonary leaflet, <i>L</i> = left coronary sinus, <i>Lp</i> = left posterior pulmonary leaflet, <i>N</i> = noncoronary sinus, <i>R</i> = right coronary sinus. <b>(a, b)</b> Short-axis cross section <b>(a)</b> and CT images <b>(b)</b> of the heart at the aortic root show the muscular subpulmonary infundibulum of the <abbr title="RV outflow tract">RVOT</abbr> in its long axis approaching the pulmonary valve. While all of the leaflets of the pulmonary valve are supported by infundibular musculature, only two of the leaflets of the aortic valve have muscular support. <i>CS</i> = coronary sinus, <i>LA</i> = left atrium, <i>ms</i> = membranous septum, <i>MV-AL</i> = mitral valve–aortic leaflet, <i>RA</i> = right atrium. <b>(c, d)</b> Opened pulmonary root with endocardial dissection <b>(c)</b> and sagittal CT images of the <abbr title="RV outflow tract">RVOT</abbr> <b>(d)</b> show the leaflets of the pulmonary valve supported by infundibular musculature. The muscle covers the outer surface of the sinus bases <b>(d)</b>, and its distal edge demarcates the anatomic ventriculoarterial junction <i>(A-VAJ)</i> (dashed blue lines). The red lines demarcate the hemodynamic VAJ <i>(H-VAJ)</i>, which follows the semilunar attachments of the three arterial valvar leaflets and crosses the A-VAJ at six points. ★ = interleaflet <i>(IL)</i> triangles. The imaging annulus is the line connecting the inferior margin of the hinges of the leaflets (green lines). The distance between the A-VAJ and the imaging annulus roughly corresponds to the anatomic annulus (arrows in <b>d</b> [inset cadaveric view]). Therefore, while the imaging annulus looks like a ring, the anatomic annulus exists as a band of variable width.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig19d">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig20a" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig20a.jpeg" height="1425" width="1300" aria-labelledby="fig20a" loading="lazy" /><figcaption><span class="heading">Figure 20a</span>. Tendon of Todaro. CT endoscopic <b>(a)</b> and cadaveric <b>(b)</b> views of the medial wall of the right atrium and <b>(c)</b> longitudinal section of the <abbr title="atrioventricular">AV</abbr> junction at the level of the central fibrous body <i>(CFB)</i>. The tendon of Todaro <i>(TT)</i> delimits the posterior (atrial) margin of the Koch triangle (green triangle). It is a rounded tendon running deep in the atrial musculature extending from the eustachian valve/ridge <i>(EV/ER)</i> to the central fibrous body. It is not visible in the internal view of the right atrium unless the endocardium is dissected <b>(b)</b>. <i>AA</i> = ascending aorta, <i>CSO</i> = coronary sinus orifice, <i>IVC</i> = inferior vena cava, <i>ms</i> = membranous septum, <i>MV</i> = mitral valve, <i>OF</i> = oval fossa, <i>R</i> = right coronary sinus, <i>RCA</i> = right coronary artery, <i>SVC</i> = superior vena cava, <i>STA</i> = septal tricuspid valve annulus, <i>TV</i> = tricuspid valve.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig20a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig20b" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig20b.jpeg" height="1408" width="1488" aria-labelledby="fig20b" loading="lazy" /><figcaption><span class="heading">Figure 20b</span>. Tendon of Todaro. CT endoscopic <b>(a)</b> and cadaveric <b>(b)</b> views of the medial wall of the right atrium and <b>(c)</b> longitudinal section of the <abbr title="atrioventricular">AV</abbr> junction at the level of the central fibrous body <i>(CFB)</i>. The tendon of Todaro <i>(TT)</i> delimits the posterior (atrial) margin of the Koch triangle (green triangle). It is a rounded tendon running deep in the atrial musculature extending from the eustachian valve/ridge <i>(EV/ER)</i> to the central fibrous body. It is not visible in the internal view of the right atrium unless the endocardium is dissected <b>(b)</b>. <i>AA</i> = ascending aorta, <i>CSO</i> = coronary sinus orifice, <i>IVC</i> = inferior vena cava, <i>ms</i> = membranous septum, <i>MV</i> = mitral valve, <i>OF</i> = oval fossa, <i>R</i> = right coronary sinus, <i>RCA</i> = right coronary artery, <i>SVC</i> = superior vena cava, <i>STA</i> = septal tricuspid valve annulus, <i>TV</i> = tricuspid valve.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig20b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig20c" class="graphic"><img src="/cms/10.1148/rg.2017170004/asset/images/large/rg.2017170004.fig20c.jpeg" height="1405" width="1658" aria-labelledby="fig20c" loading="lazy" /><figcaption><span class="heading">Figure 20c</span>. Tendon of Todaro. CT endoscopic <b>(a)</b> and cadaveric <b>(b)</b> views of the medial wall of the right atrium and <b>(c)</b> longitudinal section of the <abbr title="atrioventricular">AV</abbr> junction at the level of the central fibrous body <i>(CFB)</i>. The tendon of Todaro <i>(TT)</i> delimits the posterior (atrial) margin of the Koch triangle (green triangle). It is a rounded tendon running deep in the atrial musculature extending from the eustachian valve/ridge <i>(EV/ER)</i> to the central fibrous body. It is not visible in the internal view of the right atrium unless the endocardium is dissected <b>(b)</b>. <i>AA</i> = ascending aorta, <i>CSO</i> = coronary sinus orifice, <i>IVC</i> = inferior vena cava, <i>ms</i> = membranous septum, <i>MV</i> = mitral valve, <i>OF</i> = oval fossa, <i>R</i> = right coronary sinus, <i>RCA</i> = right coronary artery, <i>SVC</i> = superior vena cava, <i>STA</i> = septal tricuspid valve annulus, <i>TV</i> = tricuspid valve.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2017170004&amp;id=fig20c">Download as PowerPoint</a></li></ul></div></figcaption></figure></div></section><section id="bibliography" role="doc-bibliography"><h2>References</h2><div role="list"><div role="listitem" data-has="label"><div class="label">1.</div><div id="r1" class="citations"><div class="citation"><div cla