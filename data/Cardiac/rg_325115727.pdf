        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="CT and MR Imaging of the Aortic Valve: Radiologic-Pathologic Correlation" /><meta name="dc.Creator" content="Christopher J.  Bennett" /><meta name="dc.Creator" content="Joseph J.  Maleszewski" /><meta name="dc.Creator" content="Philip A.  Araoz" /><meta name="dc.Description" content="Current CT and MR imaging techniques allow reliable characterization of various disorders that affect the aortic valve, including stenosis, regurgitation, aneurysmal dilatation, and dissection." /><meta name="Description" content="Current CT and MR imaging techniques allow reliable characterization of various disorders that affect the aortic valve, including stenosis, regurgitation, aneurysmal dilatation, and dissection." /><meta name="dc.Description" content="Valvular disease is estimated to account for as many as 20% of cardiac surgical procedures performed in the United States. It may be congenital in origin or secondary to another disease process. On..." /><meta name="Description" content="Valvular disease is estimated to account for as many as 20% of cardiac surgical procedures performed in the United States. It may be congenital in origin or secondary to another disease process. On..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2012-08-31" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="publisher-id" content="115727" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.325115727" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.325115727" /><meta name="dc.Language" content="en" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2012" />
        
        

        
