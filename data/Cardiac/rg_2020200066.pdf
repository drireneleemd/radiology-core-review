        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Chest Imaging</span></div><div class="meta-panel__onlineDate">Oct 2 2020</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Minimal Aortic Injury: Mechanisms, Imaging Manifestations, Natural History, and Management</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Harit</span> <span property="familyName">Kapoor</span>, <span property="honorificSuffix">MBBS, MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-2426-0643" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-2426-0643</a> <a href="/cdn-cgi/l/email-protection#076f66756e736c667768687547606a666e6b2964686a" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="92faf3e0fbe6f9f3e2fdfde0d2f5fff3fbfebcf1fdff">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">James T.</span> <span property="familyName">Lee</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-7054-9048" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-7054-9048</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Nathan T.</span> <span property="familyName">Orr</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-7935-5386" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-7935-5386</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Michael J.</span> <span property="familyName">Nisiewicz</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Barbara K.</span> <span property="familyName">Pawley</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Marianna</span> <span property="familyName">Zagurovskaya</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-3880-8051" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-3880-8051</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">40</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">7</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2020200066" property="sameAs">https://doi.org/10.1148/rg.2020200066</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
