        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Imaging Physics</span></div><div class="meta-panel__onlineDate">Oct 21 2016</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Artifacts at Cardiac CT: Physics and Solutions</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Kevin</span> <span property="familyName">Kalisz</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Ji</span> <span property="familyName">Buethe</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Sachin S.</span> <span property="familyName">Saboo</span>, <span property="honorificSuffix">MD, FRCR</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Suhny</span> <span property="familyName">Abbara</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Sandra</span> <span property="familyName">Halliburton</span>, <span property="honorificSuffix">PhD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Prabhakar</span> <span property="familyName">Rajiah</span>, <span property="honorificSuffix">MD, FRCR</span></a> <a href="/cdn-cgi/l/email-protection#7f0d1e1b0f0d1e1d171e141e0d3f18121e1613511c1012" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="592b383d292b383b313832382b193e34383035773a3634">[email&#160;protected]</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">36</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">7</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2016160079" property="sameAs">https://doi.org/10.1148/rg.2016160079</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
