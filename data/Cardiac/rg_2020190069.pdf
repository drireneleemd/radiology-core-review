        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Cardiac Imaging</span></div><div class="meta-panel__onlineDate">May 22 2020</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Trends in Diagnostic Imaging of Cardiac Amyloidosis: Emerging Knowledge and Concepts</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Seitaro</span> <span property="familyName">Oda</span>, <span property="honorificSuffix">MD, PhD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-0609-2191" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-0609-2191</a> <a href="/cdn-cgi/l/email-protection#3f4c5a564c5a560f0b0c0f7f5156594b46115c5052" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="5122343822343861656261113f383725287f323e3c">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Masafumi</span> <span property="familyName">Kidoh</span>, <span property="honorificSuffix">MD, PhD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-9589-7054" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-9589-7054</a></span>, <span property="author" ty