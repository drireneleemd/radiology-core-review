        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Cardiac Imaging</span></div><div class="meta-panel__onlineDate">Jan 22 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Multimodality Imaging of Transposition of the Great Arteries</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Arzu</span> <span property="familyName">Canan</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-3303-8318" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-3303-8318</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Ravi</span> <span property="familyName">Ashwath</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Prachi P.</span> <span property="familyName">Agarwal</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-4439-6970" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-4439-6970</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Christopher</span> <span property="familyName">François</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-5254-1181" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-5254-1181</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Prabhakar</span> <span property="familyName">Rajiah</span>, <span property="honorificSuffix">MBBS, MD, FRCR, FSCMR</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-7538-385X" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-7538-385X</a> <a href="/cdn-cgi/l/email-protection#611300051113565221060c00080d4f020e0c" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="1b697a7f6b692c285b7c767a727735787476">[email&#160;protected]</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">41</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">2</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2021200069" property="sameAs">https://doi.org/10.1148/rg.2021200069</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
