        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Cardiac Imaging</span></div><div class="meta-panel__onlineDate">Nov 23 2018</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Transcatheter Aortic Valve Replacement: Alternative Access beyond the Femoral Arterial Approach</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Demetrios A.</span> <span property="familyName">Raptis</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Michael A.</span> <span property="familyName">Beal</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-7845-7957" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-7845-7957</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">David C.</span> <span property="familyName">Kraft</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Hersh S.</span> <span property="familyName">Maniar</span>, <span property="honorificSuffix">MD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Andrew J.</span> <span property="familyName">Bierhals</span>, <span property="honorificSuffix">MD, MPH</span></a> <a href="/cdn-cgi/l/email-protection#482a212d3a2029243b29083f3d3b3c24662d2c3d" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="6e0c070b1c060f021d0f2e191b1d1a02400b0a1b">[email&#160;protected]</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">39</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">1</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2019180059" property="sameAs">https://doi.org/10.1148/rg.2019180059</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
