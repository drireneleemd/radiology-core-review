        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Pediatric Cardiac Tumors: Clinical and Imaging Features" /><meta name="dc.Creator" content="Ting Y.  Tao" /><meta name="dc.Creator" content="Noushin  Yahyavi-Firouz-Abadi" /><meta name="dc.Creator" content="Gautam K.  Singh" /><meta name="dc.Creator" content="Sanjeev  Bhalla" /><meta name="dc.Description" content="Benign and malignant pediatric cardiac tumors, including rhabdomyoma, fibroma, and sarcoma, are reviewed, with emphasis on their clinical and imaging features." /><meta name="Description" content="Benign and malignant pediatric cardiac tumors, including rhabdomyoma, fibroma, and sarcoma, are reviewed, with emphasis on their clinical and imaging features." /><meta name="dc.Description" content="Cardiac tumors in children are rare, are more commonly benign, and differ in types when compared with those in adults. Rhabdomyoma, teratoma, and fibroma are the most common cardiac tumors in fetus..." /><meta name="Description" content="Cardiac tumors in children are rare, are more commonly benign, and differ in types when compared with those in adults. Rhabdomyoma, teratoma, and fibroma are the most common cardiac tumors in fetus..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2014-07-14" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="manuscript" content="135163" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.344135163" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.344135163" /><meta name="dc.Language" content="EN" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="2014 by the Radiological Society of North America, Inc." />
        
        

        
