        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="CT of Left Ventricular Assist Devices1 " /><meta name="dc.Creator" content="Carrie M.  Carr" /><meta name="dc.Creator" content="Jaisy  Jacob" /><meta name="dc.Creator" content="Soon J.  Park" /><meta name="dc.Creator" content="Barry L.  Karon" /><meta name="dc.Creator" content="Eric E.  Williamson" /><meta name="dc.Creator" content="Philip A.  Araoz" /><meta name="dc.Description" content="Four types of left ventricular assist devices are discussed, with emphasis on normal CT appearances and the CT features of common complications in the early and late postoperative periods." /><meta name="Description" content="Four types of left ventricular assist devices are discussed, with emphasis on normal CT appearances and the CT features of common complications in the early and late postoperative periods." /><meta name="dc.Description" content="Left ventricular assist devices (LVADs) have become an increasingly beneficial option for patients with heart failure, especially in light of the insufficient availability of donor hearts. LVADs ha..." /><meta name="Description" content="Left ventricular assist devices (LVADs) have become an increasingly beneficial option for patients with heart failure, especially in light of the insufficient availability of donor hearts. LVADs ha..." /><meta name="dc.Publisher" content=" Radiological Society of North America " /><meta name="dc.Date" scheme="WTN8601" content="2010-03-08" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.302095734" /><meta name="dc.Identifier" scheme="publisher-id" content="30095734" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.302095734" /><meta name="dc.Language" content="en" /><meta name="dc.Coverage" content="world" /><meta name="d