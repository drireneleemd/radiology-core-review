        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Cardiac Imaging</span></div><div class="meta-panel__onlineDate">Oct 5 2018</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">IgG4-related Cardiovascular Disease from the Aorta to the Coronary Arteries: Multidetector CT and PET/CT</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Noriko</span> <span property="familyName">Oyama-Manabe</span>, <span property="honorificSuffix">MD, PhD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-0394-0095" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-0394-0095</a> <a href="/cdn-cgi/l/email-protection#d0bebfa2b9bbbfbfa9b1bdb190bdb5b4feb8bfbba5b4b1b9feb1b3febaa0" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="deb0b1acb7b5b1b1a7bfb3bf9eb3bbbaf0b6b1b5abbabfb7f0bfbdf0b4ae">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Satoshi</span> <span property="familyName">Yabusaki</span>, <span property="honorificSuffix">MD, PhD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Osamu</span> <span property="familyName">Manabe</span>, <span property="honorificSuffix">MD, PhD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Fumi</span> <span property="familyName">Kato</span>, <span property="honorificSuffix">MD, PhD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Hiromi</span> <span property="familyName">Kanno-Okada</span>, <span property="honorificSuffix">MD, PhD</span></a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Kohsuke</span> <span property="familyName">Kudo</span>, <span property="honorificSuffix">MD, PhD</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">38</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">7</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2018180049" property="sameAs">https://doi.org/10.1148/rg.2018180049</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
        <div class="article-tools"><a href="/personalize/addFavoritePublication?doi=10.1148%2Frg.2018180049" target="_blank" class="article-tools__favorite btn btn--slim btn--inverse" data-toggle="tooltip" data-trigger="hover" data-original-title="Add to favorites"><i aria-hidden="true" class="icon-add-favorite"></i><span class="sr-only">Add to favorites</span></a><a href="/action/addCitationAlert?doi=10.1148%2Frg.2018180049" target="_blank" class="article-tools__citation btn btn--slim btn--inverse" data-toggle="tooltip" data-trigger="hover" data-original-title="Track Citations"><i aria-hidden="true" class="icon-alert-bell"></i><span class="sr-only">Track Citations</span></a></div>
</div><div class="info-panel__citations info-panel__item"><a href="#tab-citations" class="btn btn--inverse btn--slim" data-toggle="tooltip" data-original-title="View Citations" aria-label="View Citations"><i aria-hidden="true" class="icon-format_quote"></i></a></div><div class="info-panel__formats info-panel__item"><a href="#core-collateral-purchase-access" class="btn btn--access" data-toggle="tooltip" data-original-title="Go to purchase options" aria-label="Go to purchase options"><i aria-hidden="true" class="icon-lock-open"></i><span class="link-text">Get Access</span></a></div></div></div></div></header><div data-core-nav="header" data-extent="frontmatter"><div class="core-nav-wrapper core-container" aria-label="Article navigation"><div><button aria-controls="article_sections_menu" aria-expanded="false" aria-label="Toggle section navigation menu"><i class="icon-list" aria-hidden="true"></i><span>Contents</span></button><nav id="article_sections_menu" aria-label="Contents" data-core-nav="article"><ul><li><a href="#abstract">Abstract</a></li><li><a href="#core-sec-figures">Figures</a></li><li><a href="#bibliography">References</a></li></ul></nav></div><nav id="article_collateral_menu"><ul class="collateral-pill" data-core-nav="collateral"><li><a href="#core-collateral-info" aria-controls="core-collateral-info" aria-disabled="true" disabled="true" data-toggle="tooltip" data-placement="left" data-original-title="Information & Authors" title="Information & Authors" aria-expanded="false"><i aria-hidden="true" class="icon-info"></i><span class="sr-only">Information & Authors</span></a></li><li><a href="#core-collateral-metrics" aria-controls="core-collateral-metrics" aria-disabled="true" disabled="true" data-toggle="tooltip" data-placement="left" data-original-title="Metrics & Citations" title="Metrics & Citations" aria-expanded="false"><i aria-hidden="true" class="icon-metrics"></i><span class="sr-only">Metrics & Citations</span></a></li><li><a href="#core-collateral-purchase-access" aria-controls="core-collateral-purchase-access" aria-disabled="true" disabled="true" data-toggle="tooltip" data-placement="left" data-original-title="Get Access" title="Get Access" aria-expanded="false"><i aria-hidden="true" class="icon-lock-open"></i><span class="sr-only">Get Access</span></a></li><li><a href="#core-collateral-references" aria-controls="core-collateral-references" aria-disabled="true" disabled="true" data-toggle="tooltip" data-placement="left" data-original-title="References" title="References" aria-expanded="false"><i aria-hidden="true" class="icon-references"></i><span class="sr-only">References</span></a></li><li><a href="#core-collateral-figures" aria-controls="core-collateral-figures" aria-disabled="true" disabled="true" data-toggle="tooltip" data-placement="left" data-original-title="Figures" title="Figures" aria-expanded="false"><i aria-hidden="true" class="icon-photo"></i><span class="sr-only">Figures</span></a></li><li><a href="#core-collateral-tables" aria-controls="core-collateral-tables" aria-disabled="true" disabled="true" data-toggle="tooltip" data-placement="left" data-original-title="Tables" title="Tables" aria-expanded="false"><i aria-hidden="true" class="icon-table"></i><span class="sr-only">Tables</span></a></li><li><a href="#core-collateral-media" aria-controls="core-collateral-media" aria-disabled="true" disabled="true" data-toggle="tooltip" data-placement="left" data-original-title="Media" title="Media" aria-expanded="false"><i aria-hidden="true" class="icon-play-circle-filled"></i><span class="sr-only">Media</span></a></li><li><a href="#core-collateral-share" aria-controls="core-collateral-share" aria-disabled="true" disabled="true" data-toggle="tooltip" data-placement="left" data-original-title="Share" title="Share" aria-expanded="false"><i aria-hidden="true" class="icon-share"></i><span class="sr-only">Share</span></a></li></ul></nav></div></div><div data-core-wrapper="content"><div id="abstracts" data-extent="frontmatter"><div class="core-container"><section id="abstract" property="abstract" typeof="Text" role="doc-abstract"><h2 property="name">Abstract</h2><div role="paragraph">Immunoglobulin G4 (IgG4)–related disease can affect the cardiovascular system, including the coronary arteries and pericardium and especially the walls of large and medium-sized vessels. The presence of coronary involvement is critical, as this condition can cause myocardial ischemia or sudden cardiac death. Although histopathologic examination remains the reference standard for detecting organ involvement and diagnosing IgG4-related disease, obtaining biopsy or surgical specimens from the vessel wall is still challenging. Because patients may be only mildly symptomatic, noninvasive imaging evaluation of IgG4-related cardiovascular disease (CVD) has an essential role in not only the diagnosis but also the management of this condition. Multidetector CT is a useful noninvasive examination for establishing the primary diagnosis and defining anatomic landmarks and their relationships. The spectrum of vessel involvement is vast, with varied manifestations. Radiologists should be familiar with inflammatory vasculitis, aneurysmal change, and pseudotumor formation in all vessels and the distribution of these conditions throughout the body. Electrocardiographically gated CT enables accurate, fast, and noninvasive characterization of coronary pathologic conditions and thus has an important advantage over catheter angiography. Combined PET/CT can depict inflammatory processes and help distinguish IgG4-related CVD from atherosclerosis. Familiarity with the PET/CT and CT findings of inflammatory processes involved in IgG4-related CVD is important for accurate diagnosis and evaluation of therapeutic response during follow-up. The multidetector CT and PET/CT characteristics of IgG4-related CVD, such as aortitis, periaortitis, arteritis, and periarteritis and including coronary artery involvement and pericarditis, are reviewed. In addition, the inflammatory process, quantification of active inflammation, and therapeutic response during follow-up associated with IgG4-related CVD are described.</div><div role="paragraph"><a href="https://images.rsna.org/index.html?doi=10.1148/rg.2018180049"><i>Online DICOM image stacks are available for this article.</i></a></div><div role="paragraph"><sup>©</sup>RSNA, 2018</div></section></div></div><section id="bodymatter" data-extent="bodymatter" property="articleBody" typeof="Text"><div class="core-container"><section aria-labelledby="denial-block-title" class="denial-block "><h2 id="denial-block-title" class="denial-block__title">Get full access to this article</h2><p class="denial-block__text">View all available purchase options and get full access to this article.</p><div class="denial-block__cta"><a href="#core-collateral-purchase-access" class="btn btn--access"><i aria-hidden="true" class="icon-lock-open"></i><span>Get Access</span></a></div><footer class="denial-block__footer"><span>Already a Subscriber? </span><span>Sign in as an </span><a href="/action/showLogin?redirectUri=/doi/10.1148/rg.2018180049">individual</a><span> or via your </span><a href="/action/ssostart?uri=/doi/10.1148/rg.2018180049">institution</a></footer></section></div></section><section id="backmatter" data-extent="backmatter"><div class="core-container"><section id="core-sec-figures" data-type="figures"><h2>Figures</h2><div class="figure-wrap"><figure id="fig1a" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig1a.jpeg" height="1400" width="1875" aria-labelledby="fig1a" loading="lazy" /><figcaption><span class="heading">Figure 1a</span>. IgG4-related inflammatory aortic aneurysm in an 83-year-old woman. <b>(a, b)</b> Cross-sectional macroscopic images of a resected abdominal aortic wall with hematoxylin-eosin <b>(a)</b> and Verhoeff–Masson trichrome <b>(b)</b> staining show lymphoplasmacytic infiltration (arrowheads in <b>a</b>) with irregular thickening involving mainly the adventitia (white arrow) and to a lesser extent the media (ie, inner layer) (black arrow). (Original magnification, ×20.) The specimen with Verhoeff–Masson trichrome staining shows dense fibrosis. <b>(c, d)</b> High-power-field photomicrographs stained with hematoxylin-eosin <b>(c)</b> and immunostained for IgG4 <b>(d)</b> show the lymphoplasmacytic infiltrate <b>(c)</b> and extensive dense infiltrate of IgG4-positive plasma cells <b>(d)</b> within the aortic wall, mainly in the adventitia. (Original magnification, ×400.) The ratio of IgG4-positive cells to IgG-positive cells was almost 100%.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig1a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig1b" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig1b.jpeg" height="1406" width="1882" aria-labelledby="fig1b" loading="lazy" /><figcaption><span class="heading">Figure 1b</span>. IgG4-related inflammatory aortic aneurysm in an 83-year-old woman. <b>(a, b)</b> Cross-sectional macroscopic images of a resected abdominal aortic wall with hematoxylin-eosin <b>(a)</b> and Verhoeff–Masson trichrome <b>(b)</b> staining show lymphoplasmacytic infiltration (arrowheads in <b>a</b>) with irregular thickening involving mainly the adventitia (white arrow) and to a lesser extent the media (ie, inner layer) (black arrow). (Original magnification, ×20.) The specimen with Verhoeff–Masson trichrome staining shows dense fibrosis. <b>(c, d)</b> High-power-field photomicrographs stained with hematoxylin-eosin <b>(c)</b> and immunostained for IgG4 <b>(d)</b> show the lymphoplasmacytic infiltrate <b>(c)</b> and extensive dense infiltrate of IgG4-positive plasma cells <b>(d)</b> within the aortic wall, mainly in the adventitia. (Original magnification, ×400.) The ratio of IgG4-positive cells to IgG-positive cells was almost 100%.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig1b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig1c" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig1c.jpeg" height="1406" width="1875" aria-labelledby="fig1c" loading="lazy" /><figcaption><span class="heading">Figure 1c</span>. IgG4-related inflammatory aortic aneurysm in an 83-year-old woman. <b>(a, b)</b> Cross-sectional macroscopic images of a resected abdominal aortic wall with hematoxylin-eosin <b>(a)</b> and Verhoeff–Masson trichrome <b>(b)</b> staining show lymphoplasmacytic infiltration (arrowheads in <b>a</b>) with irregular thickening involving mainly the adventitia (white arrow) and to a lesser extent the media (ie, inner layer) (black arrow). (Original magnification, ×20.) The specimen with Verhoeff–Masson trichrome staining shows dense fibrosis. <b>(c, d)</b> High-power-field photomicrographs stained with hematoxylin-eosin <b>(c)</b> and immunostained for IgG4 <b>(d)</b> show the lymphoplasmacytic infiltrate <b>(c)</b> and extensive dense infiltrate of IgG4-positive plasma cells <b>(d)</b> within the aortic wall, mainly in the adventitia. (Original magnification, ×400.) The ratio of IgG4-positive cells to IgG-positive cells was almost 100%.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig1c">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig1d" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig1d.jpeg" height="1406" width="1875" aria-labelledby="fig1d" loading="lazy" /><figcaption><span class="heading">Figure 1d</span>. IgG4-related inflammatory aortic aneurysm in an 83-year-old woman. <b>(a, b)</b> Cross-sectional macroscopic images of a resected abdominal aortic wall with hematoxylin-eosin <b>(a)</b> and Verhoeff–Masson trichrome <b>(b)</b> staining show lymphoplasmacytic infiltration (arrowheads in <b>a</b>) with irregular thickening involving mainly the adventitia (white arrow) and to a lesser extent the media (ie, inner layer) (black arrow). (Original magnification, ×20.) The specimen with Verhoeff–Masson trichrome staining shows dense fibrosis. <b>(c, d)</b> High-power-field photomicrographs stained with hematoxylin-eosin <b>(c)</b> and immunostained for IgG4 <b>(d)</b> show the lymphoplasmacytic infiltrate <b>(c)</b> and extensive dense infiltrate of IgG4-positive plasma cells <b>(d)</b> within the aortic wall, mainly in the adventitia. (Original magnification, ×400.) The ratio of IgG4-positive cells to IgG-positive cells was almost 100%.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig1d">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig2a" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig2a.jpeg" height="1497" width="1152" aria-labelledby="fig2a" loading="lazy" /><figcaption><span class="heading">Figure 2a</span>. IgG4-related aortitis and periaortitis in a 69-year-old man. <b>(a, b)</b> Axial contrast-enhanced delayed phase CT images show homogeneously enhanced wall thickening of the left subclavian and brachiocephalic arteries (arrows in <b>a</b>) and abdominal aorta (arrowheads in <b>b</b>). <b>(c)</b> Coronal FDG PET/CT fusion image shows abnormal focal FDG uptake, indicative of active inflammation, at the levels of the left subclavian and brachiocephalic arteries (arrows) and abdominal aorta (arrowhead).<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig2a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig2b" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig2b.jpeg" height="1497" width="1594" aria-labelledby="fig2b" loading="lazy" /><figcaption><span class="heading">Figure 2b</span>. IgG4-related aortitis and periaortitis in a 69-year-old man. <b>(a, b)</b> Axial contrast-enhanced delayed phase CT images show homogeneously enhanced wall thickening of the left subclavian and brachiocephalic arteries (arrows in <b>a</b>) and abdominal aorta (arrowheads in <b>b</b>). <b>(c)</b> Coronal FDG PET/CT fusion image shows abnormal focal FDG uptake, indicative of active inflammation, at the levels of the left subclavian and brachiocephalic arteries (arrows) and abdominal aorta (arrowhead).<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig2b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig2c" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig2c.jpeg" height="1497" width="962" aria-labelledby="fig2c" loading="lazy" /><figcaption><span class="heading">Figure 2c</span>. IgG4-related aortitis and periaortitis in a 69-year-old man. <b>(a, b)</b> Axial contrast-enhanced delayed phase CT images show homogeneously enhanced wall thickening of the left subclavian and brachiocephalic arteries (arrows in <b>a</b>) and abdominal aorta (arrowheads in <b>b</b>). <b>(c)</b> Coronal FDG PET/CT fusion image shows abnormal focal FDG uptake, indicative of active inflammation, at the levels of the left subclavian and brachiocephalic arteries (arrows) and abdominal aorta (arrowhead).<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig2c">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig3a" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig3a.jpeg" height="1455" width="1681" aria-labelledby="fig3a" loading="lazy" /><figcaption><span class="heading">Figure 3a</span>. IgG4-related abdominal aortitis in a 75-year-old man. <b>(a)</b> Axial contrast-enhanced delayed phase CT image shows marked wall thickening of the abdominal aorta (black arrow) and normal bilateral urinary tract (white arrows). <a href="https://images.rsna.org/index.html?doi=10.1148/rg.2018180049&amp;fig=fig3a">(A full DICOM image stack is available online.)</a> <b>(b)</b> Corresponding axial FDG PET/CT fusion image shows abnormal FDG uptake (black arrow). Note the physiologic uptake of FDG in the bilateral urinary tracts (white arrows).<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig3a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig3b" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig3b.jpeg" height="1455" width="1669" aria-labelledby="fig3b" loading="lazy" /><figcaption><span class="heading">Figure 3b</span>. IgG4-related abdominal aortitis in a 75-year-old man. <b>(a)</b> Axial contrast-enhanced delayed phase CT image shows marked wall thickening of the abdominal aorta (black arrow) and normal bilateral urinary tract (white arrows). <a href="https://images.rsna.org/index.html?doi=10.1148/rg.2018180049&amp;fig=fig3b">(A full DICOM image stack is available online.)</a> <b>(b)</b> Corresponding axial FDG PET/CT fusion image shows abnormal FDG uptake (black arrow). Note the physiologic uptake of FDG in the bilateral urinary tracts (white arrows).<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig3b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig4a" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig4a.jpeg" height="1448" width="1600" aria-labelledby="fig4a" loading="lazy" /><figcaption><span class="heading">Figure 4a</span>. IgG4-related inflammatory aortic aneurysm in a 77-year-old man. <b>(a)</b> Coronal contrast-enhanced early phase CT image shows an abdominal aortic aneurysm (arrow). The left common iliac artery aneurysm (arrowhead) has a thickened and enhanced wall, representing inflammation. <b>(b)</b> Axial contrast-enhanced CT image obtained at the level of the abdominal aorta (arrow) shows an enhanced inner lumen, a nonenhanced thrombus layer (<b>*</b>), and enhanced thickening of the tunica adventitia, known as the “mantle” sign. <b>(c)</b> Axial contrast-enhanced CT image obtained at the level of the left common iliac artery (arrowhead) shows an irregularly shaped pseudotumor.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig4a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig4b" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig4b.jpeg" height="1505" width="1360" aria-labelledby="fig4b" loading="lazy" /><figcaption><span class="heading">Figure 4b</span>. IgG4-related inflammatory aortic aneurysm in a 77-year-old man. <b>(a)</b> Coronal contrast-enhanced early phase CT image shows an abdominal aortic aneurysm (arrow). The left common iliac artery aneurysm (arrowhead) has a thickened and enhanced wall, representing inflammation. <b>(b)</b> Axial contrast-enhanced CT image obtained at the level of the abdominal aorta (arrow) shows an enhanced inner lumen, a nonenhanced thrombus layer (<b>*</b>), and enhanced thickening of the tunica adventitia, known as the “mantle” sign. <b>(c)</b> Axial contrast-enhanced CT image obtained at the level of the left common iliac artery (arrowhead) shows an irregularly shaped pseudotumor.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig4b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig4c" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig4c.jpeg" height="1514" width="1595" aria-labelledby="fig4c" loading="lazy" /><figcaption><span class="heading">Figure 4c</span>. IgG4-related inflammatory aortic aneurysm in a 77-year-old man. <b>(a)</b> Coronal contrast-enhanced early phase CT image shows an abdominal aortic aneurysm (arrow). The left common iliac artery aneurysm (arrowhead) has a thickened and enhanced wall, representing inflammation. <b>(b)</b> Axial contrast-enhanced CT image obtained at the level of the abdominal aorta (arrow) shows an enhanced inner lumen, a nonenhanced thrombus layer (<b>*</b>), and enhanced thickening of the tunica adventitia, known as the “mantle” sign. <b>(c)</b> Axial contrast-enhanced CT image obtained at the level of the left common iliac artery (arrowhead) shows an irregularly shaped pseudotumor.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig4c">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig5a" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig5a.jpeg" height="1374" width="1464" aria-labelledby="fig5a" loading="lazy" /><figcaption><span class="heading">Figure 5a</span>. Autoimmune pancreatitis in a 64-year-old man. Axial contrast-enhanced early phase CT images show diffuse swelling of the pancreas, which has a capsule-like rim <b>(a)</b>; wall thickening of the splenic artery (arrows) <b>(b)</b>; the abdominal aorta and inferior mesenteric artery (arrow) <b>(c)</b>; and a pseudotumor formation encircling the umbilical portion of the portal vein, which demonstrates luminal narrowing (arrowheads) <b>(d)</b>.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig5a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig5b" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig5b.jpeg" height="1374" width="1482" aria-labelledby="fig5b" loading="lazy" /><figcaption><span class="heading">Figure 5b</span>. Autoimmune pancreatitis in a 64-year-old man. Axial contrast-enhanced early phase CT images show diffuse swelling of the pancreas, which has a capsule-like rim <b>(a)</b>; wall thickening of the splenic artery (arrows) <b>(b)</b>; the abdominal aorta and inferior mesenteric artery (arrow) <b>(c)</b>; and a pseudotumor formation encircling the umbilical portion of the portal vein, which demonstrates luminal narrowing (arrowheads) <b>(d)</b>.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig5b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig5c" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig5c.jpeg" height="1376" width="1378" aria-labelledby="fig5c" loading="lazy" /><figcaption><span class="heading">Figure 5c</span>. Autoimmune pancreatitis in a 64-year-old man. Axial contrast-enhanced early phase CT images show diffuse swelling of the pancreas, which has a capsule-like rim <b>(a)</b>; wall thickening of the splenic artery (arrows) <b>(b)</b>; the abdominal aorta and inferior mesenteric artery (arrow) <b>(c)</b>; and a pseudotumor formation encircling the umbilical portion of the portal vein, which demonstrates luminal narrowing (arrowheads) <b>(d)</b>.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig5c">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig5d" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig5d.jpeg" height="1376" width="1571" aria-labelledby="fig5d" loading="lazy" /><figcaption><span class="heading">Figure 5d</span>. Autoimmune pancreatitis in a 64-year-old man. Axial contrast-enhanced early phase CT images show diffuse swelling of the pancreas, which has a capsule-like rim <b>(a)</b>; wall thickening of the splenic artery (arrows) <b>(b)</b>; the abdominal aorta and inferior mesenteric artery (arrow) <b>(c)</b>; and a pseudotumor formation encircling the umbilical portion of the portal vein, which demonstrates luminal narrowing (arrowheads) <b>(d)</b>.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig5d">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig6a" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig6a.jpeg" height="1375" width="1240" aria-labelledby="fig6a" loading="lazy" /><figcaption><span class="heading">Figure 6a</span>. IgG4-related sclerosing mesenteritis in a 60-year-old man. <b>(a)</b> Axial contrast-enhanced early phase CT image shows pseudotumor formation (arrowheads) around the branch of the superior mesenteric artery. <b>(b)</b> Axial follow-up contrast-enhanced CT image obtained 1½ years later, with no treatment having been administered, shows that the pseudotumor (arrowheads) has decreased in size, while the common iliac arteries have diffuse wall thickening (arrow) with enhancement, consistent with IgG4-related aortitis. During follow-up, the patient also experienced severe dyspnea and was diagnosed as having congestive heart failure. <b>(c)</b> ECG-gated coronary CT angiography was performed. The right coronary artery (RCA) (arrow) and left circumflex artery (arrowhead) show diffuse wall thickening. <b>(d)</b> Curved multiplanar reconstruction CT image of the RCA shows multiple severe stenoses (arrows), rather than atherosclerotic changes, due to periarterial fibrosclerotic thickening without calcification.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig6a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig6b" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig6b.jpeg" height="1375" width="1071" aria-labelledby="fig6b" loading="lazy" /><figcaption><span class="heading">Figure 6b</span>. IgG4-related sclerosing mesenteritis in a 60-year-old man. <b>(a)</b> Axial contrast-enhanced early phase CT image shows pseudotumor formation (arrowheads) around the branch of the superior mesenteric artery. <b>(b)</b> Axial follow-up contrast-enhanced CT image obtained 1½ years later, with no treatment having been administered, shows that the pseudotumor (arrowheads) has decreased in size, while the common iliac arteries have diffuse wall thickening (arrow) with enhancement, consistent with IgG4-related aortitis. During follow-up, the patient also experienced severe dyspnea and was diagnosed as having congestive heart failure. <b>(c)</b> ECG-gated coronary CT angiography was performed. The right coronary artery (RCA) (arrow) and left circumflex artery (arrowhead) show diffuse wall thickening. <b>(d)</b> Curved multiplanar reconstruction CT image of the RCA shows multiple severe stenoses (arrows), rather than atherosclerotic changes, due to periarterial fibrosclerotic thickening without calcification.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig6b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig6c" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig6c.jpeg" height="1375" width="1394" aria-labelledby="fig6c" loading="lazy" /><figcaption><span class="heading">Figure 6c</span>. IgG4-related sclerosing mesenteritis in a 60-year-old man. <b>(a)</b> Axial contrast-enhanced early phase CT image shows pseudotumor formation (arrowheads) around the branch of the superior mesenteric artery. <b>(b)</b> Axial follow-up contrast-enhanced CT image obtained 1½ years later, with no treatment having been administered, shows that the pseudotumor (arrowheads) has decreased in size, while the common iliac arteries have diffuse wall thickening (arrow) with enhancement, consistent with IgG4-related aortitis. During follow-up, the patient also experienced severe dyspnea and was diagnosed as having congestive heart failure. <b>(c)</b> ECG-gated coronary CT angiography was performed. The right coronary artery (RCA) (arrow) and left circumflex artery (arrowhead) show diffuse wall thickening. <b>(d)</b> Curved multiplanar reconstruction CT image of the RCA shows multiple severe stenoses (arrows), rather than atherosclerotic changes, due to periarterial fibrosclerotic thickening without calcification.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig6c">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig6d" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig6d.jpeg" height="922" width="1699" aria-labelledby="fig6d" loading="lazy" /><figcaption><span class="heading">Figure 6d</span>. IgG4-related sclerosing mesenteritis in a 60-year-old man. <b>(a)</b> Axial contrast-enhanced early phase CT image shows pseudotumor formation (arrowheads) around the branch of the superior mesenteric artery. <b>(b)</b> Axial follow-up contrast-enhanced CT image obtained 1½ years later, with no treatment having been administered, shows that the pseudotumor (arrowheads) has decreased in size, while the common iliac arteries have diffuse wall thickening (arrow) with enhancement, consistent with IgG4-related aortitis. During follow-up, the patient also experienced severe dyspnea and was diagnosed as having congestive heart failure. <b>(c)</b> ECG-gated coronary CT angiography was performed. The right coronary artery (RCA) (arrow) and left circumflex artery (arrowhead) show diffuse wall thickening. <b>(d)</b> Curved multiplanar reconstruction CT image of the RCA shows multiple severe stenoses (arrows), rather than atherosclerotic changes, due to periarterial fibrosclerotic thickening without calcification.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig6d">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig7a" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig7a.jpeg" height="1487" width="1223" aria-labelledby="fig7a" loading="lazy" /><figcaption><span class="heading">Figures 7a</span>. IgG4-related coronary aneurysms in a 79-year-old man. <b>(a, b)</b> Axial early phase ECG-gated coronary CT angiographic findings <b>(a)</b> could not be used to differentiate thrombosis (<b>*</b>) at a left circumflex aneurysm from enhanced mural thickening (arrow) at an RCA aneurysm; however, these entities were clearly differentiated on the corresponding delayed phase CT angiogram <b>(b)</b>. During steroid therapy, coronary thrombosis resulted in myocardial infarction.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig7a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig7b" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig7b.jpeg" height="1487" width="1232" aria-labelledby="fig7b" loading="lazy" /><figcaption><span class="heading">Figures 7b</span>. IgG4-related coronary aneurysms in a 79-year-old man. <b>(a, b)</b> Axial early phase ECG-gated coronary CT angiographic findings <b>(a)</b> could not be used to differentiate thrombosis (<b>*</b>) at a left circumflex aneurysm from enhanced mural thickening (arrow) at an RCA aneurysm; however, these entities were clearly differentiated on the corresponding delayed phase CT angiogram <b>(b)</b>. During steroid therapy, coronary thrombosis resulted in myocardial infarction.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig7b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig8a" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig8a.jpeg" height="1433" width="1232" aria-labelledby="fig8a" loading="lazy" /><figcaption><span class="heading">Figures 8a</span>. IgG4-related coronary aneurysm in the 77-year-old man in <a href="#fig4a">Figure 4</a>. <b>(a)</b> Axial ECG-gated coronary CT angiogram shows an RCA aneurysm with diffuse wall thickening (oval). <b>(b)</b> Corresponding non–ECG-gated coronary CT angiogram shows the wall thickening (oval), with severe motion artifact. <b>(c)</b> Axial FDG PET/CT image shows focal FDG uptake (maximum standardized uptake value [SUV<sub>max</sub>], 3.4) (oval) in the RCA aneurysm.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig8a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig8b" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig8b.jpeg" height="1433" width="1157" aria-labelledby="fig8b" loading="lazy" /><figcaption><span class="heading">Figures 8b</span>. IgG4-related coronary aneurysm in the 77-year-old man in <a href="#fig4a">Figure 4</a>. <b>(a)</b> Axial ECG-gated coronary CT angiogram shows an RCA aneurysm with diffuse wall thickening (oval). <b>(b)</b> Corresponding non–ECG-gated coronary CT angiogram shows the wall thickening (oval), with severe motion artifact. <b>(c)</b> Axial FDG PET/CT image shows focal FDG uptake (maximum standardized uptake value [SUV<sub>max</sub>], 3.4) (oval) in the RCA aneurysm.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig8b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig8c" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig8c.jpeg" height="1433" width="1314" aria-labelledby="fig8c" loading="lazy" /><figcaption><span class="heading">Figures 8c</span>. IgG4-related coronary aneurysm in the 77-year-old man in <a href="#fig4a">Figure 4</a>. <b>(a)</b> Axial ECG-gated coronary CT angiogram shows an RCA aneurysm with diffuse wall thickening (oval). <b>(b)</b> Corresponding non–ECG-gated coronary CT angiogram shows the wall thickening (oval), with severe motion artifact. <b>(c)</b> Axial FDG PET/CT image shows focal FDG uptake (maximum standardized uptake value [SUV<sub>max</sub>], 3.4) (oval) in the RCA aneurysm.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig8c">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig9a" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig9a.jpeg" height="1321" width="1522" aria-labelledby="fig9a" loading="lazy" /><figcaption><span class="heading">Figure 9a</span>. IgG4-related coronary aneurysm in a 73-year-old man. <b>(a)</b> Axial FDG PET/CT image shows focal uptake of FDG in a pseudotumor (arrow), with an SUV<sub>max</sub> of 4.0, at the right atrioventricular groove. <b>(b–d)</b> ECG-gated coronary CT angiographic volume-rendered reconstruction <b>(b)</b>, curved planar reconstruction <b>(c)</b>, and axial image <b>(d)</b> show a large pseudotumor (arrow), seen as the pigs-in-a-blanket sign, in an RCA aneurysm (diameter, 27 mm) without luminal stenosis or dilatation. The patient also has a left circumflex artery aneurysm. <b>(e)</b> Follow-up axial CT image obtained 1 year later, after steroid administration, shows a marked treatment response: The diameter of the RCA aneurysm has decreased to 12 mm (arrow).<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig9a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig9b" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig9b.jpeg" height="1321" width="1427" aria-labelledby="fig9b" loading="lazy" /><figcaption><span class="heading">Figure 9b</span>. IgG4-related coronary aneurysm in a 73-year-old man. <b>(a)</b> Axial FDG PET/CT image shows focal uptake of FDG in a pseudotumor (arrow), with an SUV<sub>max</sub> of 4.0, at the right atrioventricular groove. <b>(b–d)</b> ECG-gated coronary CT angiographic volume-rendered reconstruction <b>(b)</b>, curved planar reconstruction <b>(c)</b>, and axial image <b>(d)</b> show a large pseudotumor (arrow), seen as the pigs-in-a-blanket sign, in an RCA aneurysm (diameter, 27 mm) without luminal stenosis or dilatation. The patient also has a left circumflex artery aneurysm. <b>(e)</b> Follow-up axial CT image obtained 1 year later, after steroid administration, shows a marked treatment response: The diameter of the RCA aneurysm has decreased to 12 mm (arrow).<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig9b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig9c" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig9c.jpeg" height="1483" width="1022" aria-labelledby="fig9c" loading="lazy" /><figcaption><span class="heading">Figure 9c</span>. IgG4-related coronary aneurysm in a 73-year-old man. <b>(a)</b> Axial FDG PET/CT image shows focal uptake of FDG in a pseudotumor (arrow), with an SUV<sub>max</sub> of 4.0, at the right atrioventricular groove. <b>(b–d)</b> ECG-gated coronary CT angiographic volume-rendered reconstruction <b>(b)</b>, curved planar reconstruction <b>(c)</b>, and axial image <b>(d)</b> show a large pseudotumor (arrow), seen as the pigs-in-a-blanket sign, in an RCA aneurysm (diameter, 27 mm) without luminal stenosis or dilatation. The patient also has a left circumflex artery aneurysm. <b>(e)</b> Follow-up axial CT image obtained 1 year later, after steroid administration, shows a marked treatment response: The diameter of the RCA aneurysm has decreased to 12 mm (arrow).<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig9c">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig9d" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig9d.jpeg" height="1484" width="1395" aria-labelledby="fig9d" loading="lazy" /><figcaption><span class="heading">Figure 9d</span>. IgG4-related coronary aneurysm in a 73-year-old man. <b>(a)</b> Axial FDG PET/CT image shows focal uptake of FDG in a pseudotumor (arrow), with an SUV<sub>max</sub> of 4.0, at the right atrioventricular groove. <b>(b–d)</b> ECG-gated coronary CT angiographic volume-rendered reconstruction <b>(b)</b>, curved planar reconstruction <b>(c)</b>, and axial image <b>(d)</b> show a large pseudotumor (arrow), seen as the pigs-in-a-blanket sign, in an RCA aneurysm (diameter, 27 mm) without luminal stenosis or dilatation. The patient also has a left circumflex artery aneurysm. <b>(e)</b> Follow-up axial CT image obtained 1 year later, after steroid administration, shows a marked treatment response: The diameter of the RCA aneurysm has decreased to 12 mm (arrow).<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig9d">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig9e" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig9e.jpeg" height="1484" width="1288" aria-labelledby="fig9e" loading="lazy" /><figcaption><span class="heading">Figure 9e</span>. IgG4-related coronary aneurysm in a 73-year-old man. <b>(a)</b> Axial FDG PET/CT image shows focal uptake of FDG in a pseudotumor (arrow), with an SUV<sub>max</sub> of 4.0, at the right atrioventricular groove. <b>(b–d)</b> ECG-gated coronary CT angiographic volume-rendered reconstruction <b>(b)</b>, curved planar reconstruction <b>(c)</b>, and axial image <b>(d)</b> show a large pseudotumor (arrow), seen as the pigs-in-a-blanket sign, in an RCA aneurysm (diameter, 27 mm) without luminal stenosis or dilatation. The patient also has a left circumflex artery aneurysm. <b>(e)</b> Follow-up axial CT image obtained 1 year later, after steroid administration, shows a marked treatment response: The diameter of the RCA aneurysm has decreased to 12 mm (arrow).<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig9e">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig10a" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig10a.jpeg" height="1419" width="1459" aria-labelledby="fig10a" loading="lazy" /><figcaption><span class="heading">Figure 10a</span>. IgG4-related pericarditis in a 43-year-old man. <b>(a)</b> Axial nonenhanced CT image shows a thickened pericardium (arrow) without pericardial effusion. <b>(b)</b> Corresponding FDG PET/CT image shows focal FDG uptake (SUV<sub>max</sub>, 3.7) in the thickened pericardium (arrow).<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig10a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig10b" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig10b.jpeg" height="1419" width="1491" aria-labelledby="fig10b" loading="lazy" /><figcaption><span class="heading">Figure 10b</span>. IgG4-related pericarditis in a 43-year-old man. <b>(a)</b> Axial nonenhanced CT image shows a thickened pericardium (arrow) without pericardial effusion. <b>(b)</b> Corresponding FDG PET/CT image shows focal FDG uptake (SUV<sub>max</sub>, 3.7) in the thickened pericardium (arrow).<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig10b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig11a" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig11a.jpeg" height="1345" width="1537" aria-labelledby="fig11a" loading="lazy" /><figcaption><span class="heading">Figure 11a</span>. IgG4-related periaortitis of the left common iliac artery in a 77-year-old man. Axial contrast-enhanced CT <b>(a)</b> and FDG PET/CT fusion <b>(b)</b> images show the left common iliac artery (arrow), with marked wall thickening in <b>a</b> and abnormal focal FDG uptake (SUV<sub>max</sub>, 5.0; TBR, 2.2) in <b>b.</b> The right common iliac artery (arrowhead) shows atherosclerotic change (calcification) in <b>a</b> and no abnormal FDG uptake (SUV<sub>max</sub>, 2.6; TBR, 1.1) in <b>b.</b><div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig11a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig11b" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig11b.jpeg" height="1345" width="1413" aria-labelledby="fig11b" loading="lazy" /><figcaption><span class="heading">Figure 11b</span>. IgG4-related periaortitis of the left common iliac artery in a 77-year-old man. Axial contrast-enhanced CT <b>(a)</b> and FDG PET/CT fusion <b>(b)</b> images show the left common iliac artery (arrow), with marked wall thickening in <b>a</b> and abnormal focal FDG uptake (SUV<sub>max</sub>, 5.0; TBR, 2.2) in <b>b.</b> The right common iliac artery (arrowhead) shows atherosclerotic change (calcification) in <b>a</b> and no abnormal FDG uptake (SUV<sub>max</sub>, 2.6; TBR, 1.1) in <b>b.</b><div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig11b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig12a" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig12a.jpeg" height="1470" width="1419" aria-labelledby="fig12a" loading="lazy" /><figcaption><span class="heading">Figure 12a</span>. IgG4-related coronary arteritis in a 64-year-old man. <b>(a)</b> Axial ECG-gated coronary CT angiogram shows diffuse circumferential mural thickening of the left anterior descending artery (arrowheads). <b>(b)</b> On the corresponding FDG PET/CT fusion image, the increased uptake in the left anterior descending artery (arrowheads) at the anterior interventricular groove, unlike the uptake seen in <a href="#fig8a">Figures 8</a> and <a href="#fig9a">9</a>, is barely distinguishable from physiologic myocardial uptake.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig12a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig12b" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig12b.jpeg" height="1470" width="1531" aria-labelledby="fig12b" loading="lazy" /><figcaption><span class="heading">Figure 12b</span>. IgG4-related coronary arteritis in a 64-year-old man. <b>(a)</b> Axial ECG-gated coronary CT angiogram shows diffuse circumferential mural thickening of the left anterior descending artery (arrowheads). <b>(b)</b> On the corresponding FDG PET/CT fusion image, the increased uptake in the left anterior descending artery (arrowheads) at the anterior interventricular groove, unlike the uptake seen in <a href="#fig8a">Figures 8</a> and <a href="#fig9a">9</a>, is barely distinguishable from physiologic myocardial uptake.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig12b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig13a" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig13a.jpeg" height="1421" width="1556" aria-labelledby="fig13a" loading="lazy" /><figcaption><span class="heading">Figure 13a</span>. Takayasu arteritis in a 41-year-old man. Axial contrast-enhanced CT <b>(a)</b> and FDG PET/CT fusion <b>(b)</b> images show diffuse wall thickening (arrows in <b>a</b>) of the pulmonary artery, with high FDG uptake (arrows in <b>b</b>).<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig13a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig13b" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig13b.jpeg" height="1421" width="1395" aria-labelledby="fig13b" loading="lazy" /><figcaption><span class="heading">Figure 13b</span>. Takayasu arteritis in a 41-year-old man. Axial contrast-enhanced CT <b>(a)</b> and FDG PET/CT fusion <b>(b)</b> images show diffuse wall thickening (arrows in <b>a</b>) of the pulmonary artery, with high FDG uptake (arrows in <b>b</b>).<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig13b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig14a" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig14a.jpeg" height="1388" width="1463" aria-labelledby="fig14a" loading="lazy" /><figcaption><span class="heading">Figure 14a</span>. Large diffuse cardiac B-cell lymphoma in a 78-year-old man. Axial ECG-gated coronary CT angiogram <b>(a)</b> and FDG PET/CT image <b>(b)</b> show a soft-tissue–attenuation tumor (arrow), with high FDG uptake (SUV<sub>max</sub>, 29.0), at the right atrioventricular groove.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig14a">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig14b" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig14b.jpeg" height="1388" width="1488" aria-labelledby="fig14b" loading="lazy" /><figcaption><span class="heading">Figure 14b</span>. Large diffuse cardiac B-cell lymphoma in a 78-year-old man. Axial ECG-gated coronary CT angiogram <b>(a)</b> and FDG PET/CT image <b>(b)</b> show a soft-tissue–attenuation tumor (arrow), with high FDG uptake (SUV<sub>max</sub>, 29.0), at the right atrioventricular groove.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig14b">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig15" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig15.jpeg" height="1582" width="1500" aria-labelledby="fig15" loading="lazy" /><figcaption><span class="heading">Figure 15</span>. Kawasaki disease in a 23-year-old man. Axial ECG-gated coronary CT angiogram of a proximal RCA aneurysm shows diffuse calcification (arrow).<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig15">Download as PowerPoint</a></li></ul></div></figcaption></figure></div><div class="figure-wrap"><figure id="fig16" class="graphic"><img src="/cms/10.1148/rg.2018180049/asset/images/large/rg.2018180049.fig16.jpeg" height="1920" width="3200" aria-labelledby="fig16" loading="lazy" /><figcaption><span class="heading">Figure 16</span>. Diagram illustrates the authors’ imaging approach to assessing IgG4-related CVD. Using a combination of diagnostic imaging clues and clinical dialogue can lead to an accurate diagnosis.<div class="core-figure-tools"><ul><li><a class="core-figure-download-powerpoint" href="/action/downloadFigures?doi=10.1148%2Frg.2018180049&amp;id=fig16">Download as PowerPoint</a></li></ul></div></figcaption></figure></div></section><section id="bibliography" role="doc-bibliography"><h2>References</h2><div role="list"><div role="listitem" data-has="label"><div class="label">1.</div><div id="r1" class="citations"><div class="citation"><div class="citation-content">Hamano H, Kawa S, Horiuchi A, et al. High serum IgG4 concentrations in patients with sclerosing pancreatitis. <em>N Engl J Med</em> 2001;344(10):732–738.</div><div class="external-links"><div class="core-xlink-crossref"><a href="https://doi.org/10.1056/NEJM200103083441005">Crossref</a></div><div class="core-xlink-pubmed"><a href="https://pubmed.ncbi.nlm.nih.gov/11236777/">PubMed</a></div><div class="core-xlink-google-scholar"><a href="https://scholar.google.com/scholar_lookup?title=High+serum+IgG4+concentrations+in+patients+with+sclerosing+pancreatitis&amp;author=H+Hamano&amp;author=S+Kawa&amp;author=A+Horiuchi&amp;publication_year=2001&amp;journal=N+Engl+J+Med&amp;pages=732-738&amp;doi=10.1056%2FNEJM200103083441005&amp;pmid=11236777">Google Scholar</a></div></div></div></div></div><div role="listitem" data-has="label"><div class="label">2.</div><div id="r2" class="citations"><div class="citation"><div class="citation-content">Kamisawa T, Funata N, Hayashi Y, et al. A new clinicopathological entity of IgG4-related autoimmune disease. <em>J Gastroenterol</em> 2003;38(10):982–984.</div><div class="external-links"><div class="core-xlink-crossref"><a href="https://doi.org/10.1007/s00535-003-1175-y">Crossref</a></div><div class="core-xlink-pubmed"><a href="https://pubmed.ncbi.nlm.nih.gov/14614606/">PubMed</a></div><div class="core-xlink-google-scholar"><a href="https://scholar.google.com/scholar_lookup?title=A+new+clinicopathological+entity+of+IgG4-related+autoimmune+disease&amp;author=T+Kamisawa