        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Cardiac Imaging</span></div><div class="meta-panel__onlineDate">Jan 31 2020</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Comprehensive Assessment of Endomyocardial Fibrosis with Cardiac MRI: Morphology, Function, and Tissue Characterization</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Filipe Penna</span> <span property="familyName">de Carvalho</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-6377-8069" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-6377-8069</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Clerio Francisco</span> <span property="familyName">Azevedo</span>, <span property="honorificSuffix">MD, PhD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-9493-0687" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-9493-0687</a> <a href="/cdn-cgi/l/email-protection#b6d5dad3c4dfd998d7ccd3c0d3d2d9f6d2c3ddd398d3d2c3" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="b9dad5dccbd0d697d8c3dccfdcddd6f9ddccd2dc97dcddcc">[email&#160;protected]</span></a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">40</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">2</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2020190148" property="sameAs">https://doi.org/10.1148/rg.2020190148</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
