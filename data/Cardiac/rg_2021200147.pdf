        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Cardiac Imaging</span></div><div class="meta-panel__onlineDate">Apr 2 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">Imaging Features of Complications after Coronary Interventions and Surgical Procedures</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Harold</span> <span property="familyName">Goerne</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-5592-4348" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-5592-4348</a> <a href="/cdn-cgi/l/email-protection#87efe6f5e8ebe3e0e8e2f5e9e2c7efe8f3eae6eeeba9e4e8ea" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="650d04170a0901020a00170b00250d0a1108040c094b060a08">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Diego</span> <span property="familyName">de la Fuente</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-5052-7693" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-5052-7693</a></span>, <span propert