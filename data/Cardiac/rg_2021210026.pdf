        <link id="build-style-article" rel="stylesheet" type="text/css" href="/products/rsna/releasedAssets/css/build-article-8932601a697666afa607.css"/><article xmlns="http://www.w3.org/1999/xhtml" data-design="pill" data-has="right-rail" data-type="research-article" vocab="http://schema.org/" typeof="ScholarlyArticle" lang="en" dir="ltr"><header data-extent="frontmatter"><div class="core-container"><div data-article-access="no" data-article-access-type="other" class="meta-panel"><div class="meta-panel__left-content"><div class="meta-panel__label"><span>Chest Imaging</span></div><div class="meta-panel__onlineDate">Aug 20 2021</div></div><div class="meta-panel__right-content"><div class="meta-panel__share"></div></div></div><h1 property="name">CT of Postoperative Repair of the Ascending Aorta and Aortic Arch</h1><div class="contributors"><span class="authors"><span class="heading">Authors</span>: <span role="list"><span property="author" typeof="Person" role="listitem"><a href="#con1"><span property="givenName">Kaitlin M.</span> <span property="familyName">Marquis</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-8540-2361" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-8540-2361</a> <a href="/cdn-cgi/l/email-protection#4b20262a393a3e22380b3c3e383f27652e2f3e" property="email" aria-label="Email address"><span class="__cf_email__" data-cfemail="adc6c0ccdfdcd8c4deeddad8ded9c183c8c9d8">[email&#160;protected]</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con2"><span property="givenName">Muhammad</span> <span property="familyName">Naeem</span>, <span property="honorificSuffix">MBBS</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-8626-0916" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-8626-0916</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con3"><span property="givenName">Mohamed Zak</span> <span property="familyName">Rajput</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con4"><span property="givenName">Demetrios A.</span> <span property="familyName">Raptis</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-2324-0253" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-2324-0253</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Kacie L.</span> <span property="familyName">Steinbrecher</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-8795-5827" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-8795-5827</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">J. Westley</span> <span property="familyName">Ohman</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-6996-8912" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-6996-8912</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Sanjeev</span> <span property="familyName">Bhalla</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0002-1262-8925" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0002-1262-8925</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Constantine A.</span> <span property="familyName">Raptis</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0003-0924-2447" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0003-0924-2447</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">41</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">5</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2021210026" property="sameAs">https://doi.org/10.1148/rg.2021210026</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
