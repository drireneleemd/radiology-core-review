        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="CT of Postoperative Repair of the Ascending Aorta and Aortic Arch" /><meta name="dc.Creator" content="Kaitlin M.  Marquis" /><meta name="dc.Creator" content="Muhammad  Naeem" /><meta name="dc.Creator" content="Mohamed Zak  Rajput" /><meta name="dc.Creator" content="Demetrios A.  Raptis" /><meta name="dc.Creator" content="Kacie L.  Steinbrecher" /><meta name="dc.Creator" content="J. Westley  Ohman" /><meta name="dc.Creator" content="Sanjeev  Bhalla" /><meta name="dc.Creator" content="Constantine A.  Raptis" /><meta name="dc.Description" content="The diagnostic radiologist has a pivotal role in evaluation and management of patients after proximal aortic repair, and a structured approach that identifies key CT findings allows detailed unders..." /><meta name="Description" content="The diagnostic radiologist has a pivotal role in evaluation and management of patients after proximal aortic repair, and a structured approach that identifies key CT findings allows detailed unders..." /><meta name="dc.Description" content="While many of the classic open surgical repairs are still used to repair the ascending aorta, management of the aortic arch has become more complex via implementation of newer open surgical and end..." /><meta name="Description" content="While many of the classic open surgical repairs are still used to repair the ascending aorta, management of the aortic arch has become more complex via implementation of newer open surgical and end..." /><meta name="dc.Publisher" content=" Radiological Society of North America " /><meta name="dc.Date" scheme="WTN8601" content="2021-08-20" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="manuscript" content="210026" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.20