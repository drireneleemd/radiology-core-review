"Person" role="listitem"><a href="#con4"><span property="givenName">Alberto</span> <span property="familyName">Hidalgo</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con5"><span property="givenName">Daniel</span> <span property="familyName">Vargas</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-8207-4609" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-8207-4609</a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con6"><span property="givenName">Eric</span> <span property="familyName">Williamson</span>, <span property="honorificSuffix">MD</span></a></span>, <span property="author" typeof="Person" role="listitem"><a href="#con7"><span property="givenName">Fernando</span> <span property="familyName">Gutiérrez</span>, <span property="honorificSuffix">MD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-6808-1044" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-6808-1044</a></span>, and <span property="author" typeof="Person" role="listitem"><a href="#con8"><span property="givenName">Antonio</span> <span property="familyName">Luna</span>, <span property="honorificSuffix">MD, PhD</span></a> <a class="orcid-id" href="https://orcid.org/0000-0001-9358-3396" property="identifier" aria-label="ORCID identifier" target="_blank">https://orcid.org/0000-0001-9358-3396</a></span></span></span><a href="#tab-contributors" class="to-authors-affiliations" data-id="article-authors-viewall">Authors Info &amp; Affiliations</a></div><div class="core-self-citation"><div property="isPartOf" typeof="Periodical"><span class="heading">Publication</span>: <span property="name">RadioGraphics</span></div><div class="core-enumeration"><span property="isPartOf" typeof="PublicationVolume">Volume <span property="volumeNumber">41</span></span><span class="delimiter">, </span><span property="isPartOf" typeof="PublicationIssue">Number <span property="issueNumber">1</span></span></div><div class="doi"><a href="https://doi.org/10.1148/rg.2021200084" property="sameAs">https://doi.org/10.1148/rg.2021200084</a></div></div><div class="info-panel"><div class="info-panel__left-content"><div class="info-panel__metrics info-panel__item"></div></div><div class="info-panel__right-content"><div class="info-panel__article_tools info-panel__item">



        
