        <link rel="schema.DC" href="https://purl.org/DC/elements/1.0/" /><meta name="citation_journal_title" content="RadioGraphics" /><meta name="dc.Title" content="Multidetector CT Angiography in Evaluation of Prosthetic Heart Valve Dysfunction" /><meta name="dc.Creator" content="Jesse  Habets" /><meta name="dc.Creator" content="Willem P. T. M.  Mali" /><meta name="dc.Creator" content="Ricardo P. J.  Budde" /><meta name="dc.Description" content="Practical aspects of evaluation of prosthetic heart valves with multidetector CT angiography are presented, with emphasis on indications for CT evaluation; optimal image acquisition, reconstruction..." /><meta name="Description" content="Practical aspects of evaluation of prosthetic heart valves with multidetector CT angiography are presented, with emphasis on indications for CT evaluation; optimal image acquisition, reconstruction..." /><meta name="dc.Description" content="Prosthetic heart valves (PHVs) are commonly implanted to replace diseased native heart valves. PHV dysfunction is an infrequent but potentially life-threatening condition. In daily clinical practic..." /><meta name="Description" content="Prosthetic heart valves (PHVs) are commonly implanted to replace diseased native heart valves. PHV dysfunction is an infrequent but potentially life-threatening condition. In daily clinical practic..." /><meta name="dc.Publisher" content="Radiological Society of North America" /><meta name="dc.Date" scheme="WTN8601" content="2012-11-01" /><meta name="dc.Type" content="research-article" /><meta name="dc.Format" content="text/HTML" /><meta name="dc.Identifier" scheme="publisher-id" content="125702" /><meta name="dc.Identifier" scheme="doi" content="10.1148/rg.327125702" /><meta name="dc.Source" content="https://doi.org/10.1148/rg.327125702" /><meta name="dc.Language" content="en" /><meta name="dc.Coverage" content="world" /><meta name="dc.Rights" content="© RSNA, 2012" />
        
        

        
